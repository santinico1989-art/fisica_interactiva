<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Desafío Físico: Baloncesto 3D Pro</title>
    <!-- Tailwind CSS para diseño moderno -->
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #060814;
            overflow: hidden;
        }
        .font-orbitron {
            font-family: 'Orbitron', sans-serif;
        }
        /* Cristalera esmerilada premium (Glassmorphism) */
        .glass-panel {
            background: rgba(10, 15, 30, 0.85);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.25s ease;
        }

        /* ===== RESPONSIVE MÓVIL ===== */
        @media (max-width: 768px) {
            /* En móvil el panels-wrapper se convierte en cajón deslizante desde abajo */
            #panels-wrapper {
                position: fixed !important;
                left: 0 !important;
                right: 0 !important;
                bottom: 0 !important;
                top: auto !important;
                width: 100% !important;
                height: auto !important;
                max-height: 72vh;
                background: rgba(6, 8, 20, 0.97);
                backdrop-filter: blur(20px);
                border-top: 1px solid rgba(249, 115, 22, 0.35);
                border-radius: 18px 18px 0 0;
                flex-direction: column !important;
                overflow-y: auto;
                overflow-x: hidden;
                padding: 12px 12px 80px 12px;
                gap: 8px;
                z-index: 35 !important;
                transform: translateY(100%);
                transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
                pointer-events: auto !important;
                display: flex !important;
            }
            #panels-wrapper.drawer-open {
                transform: translateY(0%);
            }
            /* El side-panel ocupa todo el ancho en móvil */
            #side-panel {
                position: relative !important;
                left: auto !important;
                top: auto !important;
                bottom: auto !important;
                width: 100% !important;
                transform: none !important;
                flex-direction: column;
                gap: 8px;
            }
            /* El right-panel se apila debajo del side-panel */
            #right-panel {
                position: relative !important;
                bottom: auto !important;
                right: auto !important;
                width: 100% !important;
            }
            /* Ocultar el botón desktop de mostrar/ocultar panel */
            #togglePanelBtn {
                display: none !important;
            }
            /* El botón flotante de cajón sólo visible en móvil */
            #mobile-drawer-toggle {
                display: flex !important;
            }
            /* Controles de cámara más pequeños y reposicionados */
            #camera-controls {
                bottom: 60px !important;
                right: 8px !important;
                flex-direction: column !important;
            }
        }
        @media (min-width: 769px) {
            /* En escritorio el botón flotante de cajón no se muestra */
            #mobile-drawer-toggle {
                display: none !important;
            }
        }
    </style>

    <!-- Cargando Three.js y sus controles de órbita -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
</head>
<body class="w-full h-screen text-gray-100 relative select-none">

    <!-- CONTENEDOR DE LA ESCENA 3D -->
    <div id="canvas-container" class="absolute inset-0 w-full h-full z-0">
        <!-- Canvas de Three.js se inserta aquí dinámicamente -->
    </div>

    <!-- BOTÓN DE MOSTRAR/OCULTAR PANEL -->
    <div id="togglePanelBtn" class="absolute left-[220px] top-3 z-30 pointer-events-auto transition-all duration-300">
        <button onclick="toggleSidebar()" class="w-8 h-8 bg-gray-900/90 hover:bg-orange-500 text-orange-400 hover:text-white border border-gray-800 rounded-lg flex items-center justify-center transition-all shadow-lg backdrop-blur-md" title="Ocultar/Mostrar Interfaz">
            <svg id="toggleIcon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
        </button>
    </div>

    <!-- CONTENEDOR ENVOLVENTE DE PANELES (Para control responsivo en móviles) -->
    <div id="panels-wrapper" class="absolute inset-0 pointer-events-none z-20 flex justify-between mobile-hidden">
        <!-- INTERFAZ FLOTANTE LATERAL IZQUIERDA (Menú vertical ultra-compacto de 210px) -->
        <div id="side-panel" class="absolute left-2.5 top-2.5 bottom-2.5 w-[210px] z-10 pointer-events-none flex flex-col gap-1.5 justify-start transition-transform duration-300 transform">
            
            <!-- 0. Botón Volver -->
            <a href="./index.html" class="glass-panel rounded-lg p-1.5 pointer-events-auto shadow-md flex items-center justify-center gap-1.5 text-[8.5px] text-orange-400 hover:text-orange-300 font-bold uppercase tracking-wider font-orbitron transition-all">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Volver al Inicio
            </a>

            <!-- 1. Cabecera -->
            <div class="glass-panel rounded-lg p-2 pointer-events-auto shadow-md flex items-center gap-2">
                <div class="w-6 h-6 bg-gradient-to-br from-orange-500 to-red-600 rounded-full flex items-center justify-center">
                    <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <div>
                    <h1 class="font-orbitron text-[10px] font-black tracking-wider text-orange-500 leading-none">BALONCESTO 3D</h1>
                    <p class="text-[6.5px] text-gray-400 font-semibold uppercase tracking-widest leading-none mt-0.5">Desafío Cinemático</p>
                </div>
            </div>

            <!-- 2. Estado de Puntos e Intentos -->
            <div class="glass-panel rounded-lg p-1.5 pointer-events-auto shadow-md flex justify-around text-center gap-1">
                <div class="flex-1 border-r border-gray-800">
                    <small class="text-gray-400 text-[8px] font-black block leading-none">PUNTOS</small>
                    <span id="score-display" class="font-orbitron text-xs font-black text-green-400 leading-none block mt-0.5">0</span>
                </div>
                <div class="flex-1">
                    <small class="text-gray-400 text-[8px] font-black block leading-none">INTENTOS</small>
                    <span id="attempts-count" class="font-orbitron text-xs font-black text-red-500 leading-none block mt-0.5">3</span>
                </div>
            </div>

            <!-- 3. Panel de Variables e Input del Desafío -->
            <div class="glass-panel rounded-xl p-2.5 pointer-events-auto shadow-md flex flex-col gap-2.5">
                <div>
                    <h3 class="text-[8.5px] font-bold text-orange-400 uppercase tracking-wider mb-1">Variables:</h3>
                    <div id="variables-dadas" class="grid grid-cols-2 gap-1">
                        <!-- Generado dinámicamente -->
                    </div>
                </div>

                <!-- Entrada de Datos -->
                <div class="border-t border-gray-800/80 pt-1.5">
                    <h3 id="input-title" class="text-[8.5px] font-bold text-gray-300 mb-1 uppercase tracking-wider">Calcula:</h3>
                    
                    <!-- Entrada Manual (Intento 1) -->
                    <div id="manual-input-wrapper">
                        <div class="relative rounded-md overflow-hidden border border-orange-500 shadow-md">
                            <input type="number" id="manual-input" step="0.1" 
                                   class="w-full bg-yellow-400 text-black placeholder-gray-700 text-center font-orbitron text-sm font-black py-0.5 px-1.5 focus:outline-none focus:bg-yellow-300 transition-all" 
                                   placeholder="0.0">
                            <span id="unit-label" class="absolute right-2 top-1/2 transform -translate-y-1/2 text-red-700 font-black font-orbitron text-[10px]"></span>
                        </div>
                    </div>

                    <!-- Opciones Múltiples (Intento 2 y 3) - Sin scroll -->
                    <div id="options-container" class="hidden flex flex-col gap-1">
                        <!-- Las opciones se inyectan dinámicamente en JS -->
                    </div>
                </div>
            </div>

            <!-- 4. Panel de Feedback (Mini) -->
            <div id="feedback-panel" class="glass-panel rounded-lg p-2 pointer-events-auto shadow-md text-center min-h-[38px] flex flex-col justify-center border-t border-blue-500">
                <p id="feedback" class="text-[9px] font-bold text-blue-400 leading-tight">Preparando simulador...</p>
                <p id="correct-answer-display" class="text-[7.5px] text-gray-400 mt-0.5 leading-none"></p>
            </div>
        </div>

        <!-- TARJETA DE ACCIONES INDEPENDIENTE (Flotante inferior derecho) -->
        <div id="right-panel" class="absolute bottom-16 md:bottom-16 right-3 z-10 pointer-events-auto w-48 sm:w-52 flex flex-col gap-1.5">
            <div class="glass-panel rounded-xl p-2.5 shadow-xl border-t border-orange-500 flex flex-col gap-1.5">
                <!-- Botón Lanzar Balón -->
                <button id="lanzarBtn" class="w-full bg-gradient-to-r from-orange-500 to-red-600 hover:from-orange-600 hover:to-red-700 disabled:opacity-50 disabled:cursor-not-allowed text-white font-black py-1.5 px-3 rounded-md shadow-md transform hover:-translate-y-0.5 transition-all text-[10px] uppercase tracking-wider font-orbitron flex items-center justify-center gap-1">
                    <svg class="w-3.5 h-3.5 text-white animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    Lanzar Balón
                </button>
                <!-- Botón Siguiente Ejercicio (Permanentemente visible e independiente) -->
                <button id="resetBtn" class="w-full bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white font-black py-1.5 px-3 rounded-md transition-all text-[10px] uppercase tracking-wider font-orbitron shadow-md flex items-center justify-center gap-1">
                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                    </svg>
                    Siguiente Ejercicio
                </button>
            </div>
        </div>
    </div>

    <!-- BOTÓN FLOTANTE PARA DESPLEGAR PANEL EN MÓVILES (oculto en desktop via CSS) -->
    <button id="mobile-drawer-toggle" onclick="toggleMobileDrawer()" class="fixed bottom-4 left-1/2 transform -translate-x-1/2 z-40 font-orbitron font-extrabold text-[10px] uppercase tracking-wider px-4 py-2.5 bg-gradient-to-r from-orange-500 to-red-600 hover:from-orange-400 hover:to-red-500 text-white rounded-xl shadow-[0_0_20px_rgba(249,115,22,0.5)] border border-orange-300/30 transition-all duration-300 items-center gap-2 pointer-events-auto" style="display:none">
        <svg id="mobile-drawer-icon" class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        <span id="mobile-drawer-text">Ver Datos y Resolver</span>
    </button>

    <!-- CONTROLES DE CÁMARA (Alineados abajo a la derecha) -->
    <div id="camera-controls" class="absolute bottom-3 right-3 z-10 pointer-events-auto flex flex-col sm:flex-row gap-1 bg-gray-950/90 p-1 rounded-xl border border-gray-800 backdrop-blur-md">
        <button onclick="changeCamera('lateral')" class="px-2 py-1 bg-gray-900 hover:bg-orange-500 hover:text-white rounded-md text-[9px] font-bold uppercase tracking-wider transition-all text-gray-400 font-orbitron">
            Lateral
        </button>
        <button onclick="changeCamera('jugador')" class="px-2 py-1 bg-gray-900 hover:bg-orange-500 hover:text-white rounded-md text-[9px] font-bold uppercase tracking-wider transition-all text-gray-400 font-orbitron">
            Tirador
        </button>
        <button onclick="changeCamera('canasta')" class="px-2 py-1 bg-gray-900 hover:bg-orange-500 hover:text-white rounded-md text-[9px] font-bold uppercase tracking-wider transition-all text-gray-400 font-orbitron">
            Canasta
        </button>
        <button onclick="changeCamera('orbital')" class="px-2 py-1 bg-gray-900 hover:bg-orange-500 hover:text-white rounded-md text-[9px] font-bold uppercase tracking-wider transition-all text-gray-400 font-orbitron">
            Libre ↺
        </button>
    </div>

    <!-- BOTÓN DE AYUDA / FÓRMULAS -->
    <div class="absolute top-3 right-3 z-10 pointer-events-auto">
        <button onclick="toggleHelpModal()" class="w-7 h-7 bg-gray-900/90 hover:bg-orange-500 text-orange-400 hover:text-white border border-gray-800 rounded-lg flex items-center justify-center transition-all shadow-lg backdrop-blur-md">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364.364l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </button>
    </div>

    <!-- MODAL DE TEORÍA Y FÓRMULAS -->
    <div id="help-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/75 backdrop-blur-sm hidden pointer-events-auto">
        <div class="glass-panel w-full max-w-lg rounded-2xl p-6 shadow-2xl relative">
            <button onclick="toggleHelpModal()" class="absolute top-4 right-4 text-gray-400 hover:text-white text-2xl font-bold">&times;</button>
            <h2 class="font-orbitron text-lg font-bold text-orange-500 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                Formularios de Lanzamiento
            </h2>
            
            <div class="space-y-4 text-xs text-gray-300 overflow-y-auto max-h-[60vh] pr-2 custom-scrollbar">
                <p>El movimiento parabólico de un balón de baloncesto se rige por las ecuaciones de la cinemática en dos dimensiones (despreciando la resistencia del aire):</p>
                
                <div class="bg-gray-950/80 p-2.5 rounded-lg border border-gray-850">
                    <h3 class="font-bold text-orange-400 mb-1 font-orbitron text-[10px] uppercase tracking-wider">Eje Horizontal (M.R.U.):</h3>
                    <p class="font-mono text-center text-xs text-orange-200">d = v₀ · cos(θ) · t</p>
                </div>

                <div class="bg-gray-950/80 p-2.5 rounded-lg border border-gray-850">
                    <h3 class="font-bold text-orange-400 mb-1 font-orbitron text-[10px] uppercase tracking-wider">Eje Vertical (M.R.U.A.):</h3>
                    <p class="font-mono text-center text-xs text-orange-200">h = v₀ · sin(θ) · t - 0.5 · g · t²</p>
                    <p class="text-[10px] text-gray-400 mt-1.5 text-center">Donde g = 9.81 m/s² y h es la altura relativa final de la canasta respecto al punto de lanzamiento (1.55m).</p>
                </div>

                <div class="bg-gray-950/80 p-2.5 rounded-lg border border-gray-850 space-y-1">
                    <h3 class="font-bold text-orange-400 mb-0.5 font-orbitron text-[10px] uppercase tracking-wider">Despejes Rápidos:</h3>
                    <ul class="list-disc pl-5 space-y-1 font-mono text-[11px] text-gray-300">
                        <li>Velocidad: v₀ = d / (t · cos(θ))</li>
                        <li>Ángulo: θ = arccos( d / (v₀ · t) )</li>
                        <li>Tiempo: t = d / (v₀ · cos(θ))</li>
                    </ul>
                </div>
            </div>
            
            <div class="mt-4">
                <button onclick="toggleHelpModal()" class="w-full bg-orange-500 hover:bg-orange-600 py-2 rounded-lg font-bold font-orbitron uppercase text-[10px] tracking-wider transition-all">Entendido</button>
            </div>
        </div>
    </div>

    <!-- LOGICA DEL SIMULADOR -->
    <script>
        // --- SINTETIZADOR DE SONIDOS (Web Audio API) ---
        class SoundFX {
            constructor() {
                this.ctx = null;
            }
            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
            }
            playTick() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(800, this.ctx.currentTime);
                gain.gain.setValueAtTime(0.05, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.05);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.05);
            }
            playShoot() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(120, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(500, this.ctx.currentTime + 0.1);
                gain.gain.setValueAtTime(0.3, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.1);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.1);
            }
            playBounce() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(100, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(50, this.ctx.currentTime + 0.15);
                gain.gain.setValueAtTime(0.4, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.15);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.15);
            }
            playSwish() {
                this.init();
                const bufferSize = this.ctx.sampleRate * 0.2;
                const buffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
                const data = buffer.getChannelData(0);
                for (let i = 0; i < bufferSize; i++) {
                    data[i] = Math.random() * 2 - 1;
                }
                const noise = this.ctx.createBufferSource();
                noise.buffer = buffer;
                
                const filter = this.ctx.createBiquadFilter();
                filter.type = 'bandpass';
                filter.frequency.value = 1200;
                filter.Q.value = 3.0;

                const gain = this.ctx.createGain();
                noise.connect(filter);
                filter.connect(gain);
                gain.connect(this.ctx.destination);

                gain.gain.setValueAtTime(0.35, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.2);
                noise.start();
            }
            playSuccess() {
                this.init();
                const chord = [261.63, 329.63, 392.00, 523.25]; // Do Mayor
                chord.forEach((freq, i) => {
                    const osc = this.ctx.createOscillator();
                    const gain = this.ctx.createGain();
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(freq, this.ctx.currentTime + i * 0.08);
                    gain.gain.setValueAtTime(0.15, this.ctx.currentTime + i * 0.08);
                    gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + i * 0.08 + 0.4);
                    osc.start(this.ctx.currentTime + i * 0.08);
                    osc.stop(this.ctx.currentTime + i * 0.08 + 0.4);
                });
            }
            playFailure() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(130, this.ctx.currentTime);
                osc.frequency.linearRampToValueAtTime(80, this.ctx.currentTime + 0.4);
                gain.gain.setValueAtTime(0.2, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.4);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.4);
            }
        }
        const sfx = new SoundFX();

        // --- SISTEMA 3D CON THREE.JS ---
        let scene, camera, renderer, controls;
        let basketball, courtPlane, flightCurve;
        const GRAVITY = 9.81;
        const LAUNCH_HEIGHT = 1.55; // Altura perfecta desde las manos del tirador

        // --- PANEO HORIZONTAL DE CÁMARA (MÓVIL) ---
        let cameraPanX = 0;
        let smoothPanX = 0;
        let isPanningCamera = false;
        let panStartX = 0;
        let panStartCamX = 0;
        
        // Estructuras de Soporte agrupadas limpiamente
        let basketGroup, poleMesh, boardMesh, boardBorderMesh, hoopRim, hoopNet;
        
        // Personaje Maniquí 3D Articulado
        let playerGroup, shoulderPivotLeft, shoulderPivotRight, forearmLeft, forearmRight;

        let confettiArray = [];
        let trajectoryPoints = [];
        let isShooting = false;
        let simTime = 0;
        let ballRotationSpeed = { x: 0, y: 0 };
        
        // Parámetros Físicos y de simulación
        let problemParameters = {};
        let displayedParameters = {}; // Almacena valores redondeados consistentes expuestos en pantalla
        let missingVariableType = "";
        let correctAnswer = 0;
        let attemptsLeft = 3;
        let currentScore = 0;
        let currentOptions = [];
        const ABS_TOLERANCE = 0.15; // Tolerancia amigable adaptada para cálculos a 1 decimal

        const variableKeys = ["angle", "velocity", "distance", "height", "time"];
        const variableMeta = {
            velocity: { label: "Velocidad (v₀)", unit: "m/s", name: "velocidad inicial" },
            angle: { label: "Ángulo (θ)", unit: "°", name: "ángulo" },
            distance: { label: "Distancia (d)", unit: "m", name: "distancia" },
            height: { label: "Altura (h)", unit: "m", name: "altura" },
            time: { label: "Tiempo (t)", unit: "s", name: "tiempo de vuelo" }
        };

        function init3D() {
            const container = document.getElementById("canvas-container");
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x050711);
            scene.fog = new THREE.FogExp2(0x050711, 0.012);

            // Cámara
            camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 100);
            camera.position.set(-6, 4.5, 9);

            // Renderer
            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            container.appendChild(renderer.domElement);

            // Controls
            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.maxPolarAngle = Math.PI / 2 - 0.02; // No cruzar el piso
            controls.minDistance = 2;
            controls.maxDistance = 25;
            controls.target.set(3.5, 1.8, 0);

            // Luces Ambientales y de Foco
            const ambient = new THREE.AmbientLight(0xffffff, 0.25);
            scene.add(ambient);

            const spot1 = new THREE.SpotLight(0xffffff, 1.3, 40, Math.PI / 4, 0.4, 1);
            spot1.position.set(-4, 12, 6);
            spot1.castShadow = true;
            spot1.shadow.mapSize.width = 1024;
            spot1.shadow.mapSize.height = 1024;
            spot1.shadow.bias = -0.001;
            scene.add(spot1);

            const spot2 = new THREE.SpotLight(0xffa15a, 0.9, 35, Math.PI / 3, 0.5, 1);
            spot2.position.set(12, 10, -5);
            scene.add(spot2);

            // Luz suave ambiental directa al aro
            const hoopLight = new THREE.PointLight(0xff5500, 1.2, 6);
            hoopLight.position.set(10, 3.2, 0);
            scene.add(hoopLight);

            // --- ESCENARIO ---
            const courtTex = generateCourtTexture();
            const courtMat = new THREE.MeshStandardMaterial({
                map: courtTex,
                roughness: 0.35,
                metalness: 0.05
            });
            courtPlane = new THREE.Mesh(new THREE.PlaneGeometry(35, 18), courtMat);
            courtPlane.rotation.x = -Math.PI / 2;
            courtPlane.position.set(7, 0, 0);
            courtPlane.receiveShadow = true;
            scene.add(courtPlane);

            // Balón de Baloncesto
            const ballTex = generateBasketballTexture();
            const ballMat = new THREE.MeshStandardMaterial({
                map: ballTex,
                roughness: 0.45,
                metalness: 0.05
            });
            basketball = new THREE.Mesh(new THREE.SphereGeometry(0.12, 32, 32), ballMat);
            basketball.castShadow = true;
            scene.add(basketball);

            // --- CONSTRUCCIÓN DEL TIRADOR HUMANO (MANIQUÍ 3D) ---
            buildShooterMannequin();

            // --- CONSTRUCCIÓN DE LA ESTRUCTURA DE LA CANASTA ---
            buildBasketStructure();

            // --- TRAZADO DE PARÁBOLA ---
            const curveMat = new THREE.LineBasicMaterial({ color: 0x38bdf8, transparent: true, opacity: 0.6 });
            const curveGeo = new THREE.BufferGeometry();
            flightCurve = new THREE.Line(curveGeo, curveMat);
            scene.add(flightCurve);

            window.addEventListener("resize", onWindowResize);

            // --- EVENTOS DE PANEO HORIZONTAL DE CÁMARA ---
            renderer.domElement.addEventListener("pointerdown", (e) => {
                // Solo si no hay controles orbitales activos y es toque/arrastre horizontal
                if (controls && controls.enabled) return;
                isPanningCamera = true;
                panStartX = e.clientX;
                panStartCamX = cameraPanX;
                renderer.domElement.setPointerCapture(e.pointerId);
            });
            renderer.domElement.addEventListener("pointermove", (e) => {
                if (!isPanningCamera) return;
                const dx = e.clientX - panStartX;
                cameraPanX = panStartCamX - dx * 0.015;
                cameraPanX = Math.max(-6, Math.min(6, cameraPanX));
            });
            renderer.domElement.addEventListener("pointerup", () => { isPanningCamera = false; });
            renderer.domElement.addEventListener("pointercancel", () => { isPanningCamera = false; });
        }

        // --- CONSTRUCTOR DEL TIRADOR HUMANO COMPACTO ---
        function buildShooterMannequin() {
            playerGroup = new THREE.Group();
            playerGroup.position.set(-0.18, 0, 0);
            scene.add(playerGroup);

            const skinMat = new THREE.MeshStandardMaterial({ color: 0xffd0a5, roughness: 0.5 }); 
            const jerseyMat = new THREE.MeshStandardMaterial({ color: 0xff4f00, roughness: 0.4 }); // Jersey Naranja
            const shortsMat = new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.4 }); // Pantaloneta Negra
            const shoesMat = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.2 }); // Tenis Blancos

            // Piernas
            const legGeo = new THREE.CylinderGeometry(0.055, 0.045, 0.7, 8);
            const leftLeg = new THREE.Mesh(legGeo, skinMat);
            leftLeg.position.set(0, 0.35, -0.14);
            leftLeg.castShadow = true;
            playerGroup.add(leftLeg);

            const rightLeg = new THREE.Mesh(legGeo, skinMat);
            rightLeg.position.set(0, 0.35, 0.14);
            rightLeg.castShadow = true;
            playerGroup.add(rightLeg);

            // Shorts
            const shortGeo = new THREE.CylinderGeometry(0.075, 0.065, 0.35, 8);
            const leftShort = new THREE.Mesh(shortGeo, shortsMat);
            leftShort.position.set(0, 0.7, -0.14);
            leftShort.castShadow = true;
            playerGroup.add(leftShort);

            const rightShort = new THREE.Mesh(shortGeo, shortsMat);
            rightShort.position.set(0, 0.7, 0.14);
            rightShort.castShadow = true;
            playerGroup.add(rightShort);

            // Tenis Deportivos
            const shoeGeo = new THREE.BoxGeometry(0.22, 0.08, 0.09);
            const leftShoe = new THREE.Mesh(shoeGeo, shoesMat);
            leftShoe.position.set(0.04, 0.04, -0.14);
            leftShoe.castShadow = true;
            playerGroup.add(leftShoe);

            const rightShoe = new THREE.Mesh(shoeGeo, shoesMat);
            rightShoe.position.set(0.04, 0.04, 0.14);
            rightShoe.castShadow = true;
            playerGroup.add(rightShoe);

            // Torso con camiseta
            const torsoGeo = new THREE.CylinderGeometry(0.18, 0.15, 0.7, 8);
            const torso = new THREE.Mesh(torsoGeo, jerseyMat);
            torso.position.set(0, 1.15, 0);
            torso.castShadow = true;
            playerGroup.add(torso);

            // Cabeza
            const headGeo = new THREE.SphereGeometry(0.13, 16, 16);
            const head = new THREE.Mesh(headGeo, skinMat);
            head.position.set(0, 1.62, 0);
            head.castShadow = true;
            playerGroup.add(head);

            // Gorra deportiva
            const capGeo = new THREE.SphereGeometry(0.135, 16, 16, 0, Math.PI * 2, 0, Math.PI / 2);
            const capMat = new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.6 });
            const cap = new THREE.Mesh(capGeo, capMat);
            cap.position.set(0, 1.63, 0);
            cap.rotation.y = Math.PI / 2; 
            cap.rotation.x = -0.25;
            playerGroup.add(cap);

            // Visor protector de neón
            const visorGeo = new THREE.TorusGeometry(0.12, 0.015, 8, 12, Math.PI);
            const visorMat = new THREE.MeshBasicMaterial({ color: 0x00f0ff });
            const visor = new THREE.Mesh(visorGeo, visorMat);
            visor.position.set(0.05, 1.62, 0);
            visor.rotation.y = 0; 
            playerGroup.add(visor);

            // PIVOTES DE LOS HOMBROS
            shoulderPivotLeft = new THREE.Group();
            shoulderPivotLeft.position.set(0, 1.42, -0.21);
            playerGroup.add(shoulderPivotLeft);

            shoulderPivotRight = new THREE.Group();
            shoulderPivotRight.position.set(0, 1.42, 0.21);
            playerGroup.add(shoulderPivotRight);

            // Brazos Superiores
            const armGeo = new THREE.CylinderGeometry(0.04, 0.035, 0.35, 8);
            armGeo.translate(0, -0.175, 0);
            
            const upperArmLeft = new THREE.Mesh(armGeo, skinMat);
            shoulderPivotLeft.add(upperArmLeft);

            const upperArmRight = new THREE.Mesh(armGeo, skinMat);
            shoulderPivotRight.add(upperArmRight);

            // Antebrazos
            const forearmGeo = new THREE.CylinderGeometry(0.035, 0.03, 0.35, 8);
            forearmGeo.translate(0, -0.175, 0);

            forearmLeft = new THREE.Mesh(forearmGeo, skinMat);
            forearmLeft.position.set(0, -0.35, 0);
            upperArmLeft.add(forearmLeft);

            forearmRight = new THREE.Mesh(forearmGeo, skinMat);
            forearmRight.position.set(0, -0.35, 0);
            upperArmRight.add(forearmRight);
        }

        // --- CONSTRUCTOR DE LA CANASTA (POSTE METÁLICO) ---
        function buildBasketStructure() {
            basketGroup = new THREE.Group();
            scene.add(basketGroup);

            const poleMat = new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.3, metalness: 0.8 });
            const boardMat = new THREE.MeshStandardMaterial({ color: 0xffffff, transparent: true, opacity: 0.65, roughness: 0.1, metalness: 0.9 });
            const borderMat = new THREE.MeshBasicMaterial({ color: 0xef4444, wireframe: true });
            const rimMat = new THREE.MeshStandardMaterial({ color: 0xff6200, roughness: 0.2, metalness: 0.8 });
            const netMat = new THREE.MeshBasicMaterial({ color: 0xffffff, wireframe: true, transparent: true, opacity: 0.8 });

            // Aro Metálico (Rim)
            const rimGeo = new THREE.TorusGeometry(0.24, 0.015, 8, 24);
            rimGeo.rotateX(Math.PI / 2);
            hoopRim = new THREE.Mesh(rimGeo, rimMat);
            hoopRim.castShadow = true;
            basketGroup.add(hoopRim);

            // Red de la canasta
            const netGeo = new THREE.CylinderGeometry(0.24, 0.15, 0.4, 16, 4, true);
            hoopNet = new THREE.Mesh(netGeo, netMat);
            basketGroup.add(hoopNet);

            // Tablero de Cristal Translúcido
            const boardGeo = new THREE.BoxGeometry(0.08, 1.4, 2.0);
            boardMesh = new THREE.Mesh(boardGeo, boardMat);
            basketGroup.add(boardMesh);

            // Bordes rojos del tablero
            const borderGeo = new THREE.BoxGeometry(0.09, 1.42, 2.02);
            boardBorderMesh = new THREE.Mesh(borderGeo, borderMat);
            basketGroup.add(boardBorderMesh);

            // Poste Único vertical estilizado
            const poleGeo = new THREE.CylinderGeometry(0.08, 0.1, 1, 16);
            poleMesh = new THREE.Mesh(poleGeo, poleMat);
            poleMesh.castShadow = true;
            basketGroup.add(poleMesh);
        }

        // --- PROCEDURAL TEXTURES ---
        function generateCourtTexture() {
            const canvas = document.createElement("canvas");
            canvas.width = 1024;
            canvas.height = 512;
            const ctx = canvas.getContext("2d");

            // Base Madera Caoba
            ctx.fillStyle = "#2a1a0f";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Tablones
            ctx.strokeStyle = "#160d07";
            ctx.lineWidth = 1;
            for (let y = 0; y < canvas.height; y += 16) {
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(canvas.width, y);
                ctx.stroke();
                
                const offset = (y % 32 === 0) ? 0 : 32;
                for (let x = offset; x < canvas.width; x += 64) {
                    ctx.beginPath();
                    ctx.moveTo(x + Math.sin(y) * 2, y);
                    ctx.lineTo(x + Math.sin(y) * 2, y + 16);
                    ctx.stroke();
                }
            }

            const gradient = ctx.createRadialGradient(canvas.width / 2, canvas.height / 2, 10, canvas.width / 2, canvas.height / 2, canvas.width);
            gradient.addColorStop(0, "rgba(249, 115, 22, 0.18)");
            gradient.addColorStop(1, "rgba(0,0,0,0.7)");
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Líneas pintadas
            ctx.strokeStyle = "rgba(255, 255, 255, 0.55)";
            ctx.lineWidth = 4;
            ctx.strokeRect(0, canvas.height / 2 - 100, 180, 200);
            
            ctx.beginPath();
            ctx.moveTo(canvas.width / 2, 0);
            ctx.lineTo(canvas.width / 2, canvas.height);
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(canvas.width / 2, canvas.height / 2, 60, 0, Math.PI * 2);
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(0, canvas.height / 2, 340, -Math.PI / 2.5, Math.PI / 2.5);
            ctx.stroke();

            return new THREE.CanvasTexture(canvas);
        }

        function generateBasketballTexture() {
            const canvas = document.createElement("canvas");
            canvas.width = 512;
            canvas.height = 256;
            const ctx = canvas.getContext("2d");

            ctx.fillStyle = "#e05307";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            ctx.fillStyle = "rgba(0,0,0,0.08)";
            for (let i = 0; i < 3000; i++) {
                ctx.fillRect(Math.random() * canvas.width, Math.random() * canvas.height, 1.5, 1.5);
            }

            ctx.strokeStyle = "#111111";
            ctx.lineWidth = 5;
            ctx.beginPath();
            ctx.moveTo(0, canvas.height / 2);
            ctx.lineTo(canvas.width, canvas.height / 2);
            ctx.stroke();

            ctx.beginPath();
            ctx.moveTo(canvas.width / 4, 0);
            ctx.lineTo(canvas.width / 4, canvas.height);
            ctx.moveTo(3 * canvas.width / 4, 0);
            ctx.lineTo(3 * canvas.width / 4, canvas.height);
            ctx.stroke();

            ctx.beginPath();
            ctx.arc(canvas.width / 4, canvas.height / 2, 70, 0, Math.PI * 2);
            ctx.arc(3 * canvas.width / 4, canvas.height / 2, 70, 0, Math.PI * 2);
            ctx.stroke();

            return new THREE.CanvasTexture(canvas);
        }

        // --- SISTEMA DE CONFETI EN 3D ---
        function createConfetti(position) {
            const colors = [0xff5500, 0xffd700, 0x00ffcc, 0xff00ff, 0x33ff33];
            for (let i = 0; i < 80; i++) {
                const material = new THREE.MeshBasicMaterial({
                    color: colors[Math.floor(Math.random() * colors.length)],
                    side: THREE.DoubleSide
                });
                const size = 0.04 + Math.random() * 0.05;
                const geo = new THREE.PlaneGeometry(size, size);
                const mesh = new THREE.Mesh(geo, material);
                
                mesh.position.copy(position);
                mesh.position.x += (Math.random() - 0.5) * 0.4;
                mesh.position.z += (Math.random() - 0.5) * 0.4;

                const force = 4 + Math.random() * 5;
                const angleXZ = Math.random() * Math.PI * 2;
                const velocity = new THREE.Vector3(
                    Math.cos(angleXZ) * (Math.random() * 2),
                    force,
                    Math.sin(angleXZ) * (Math.random() * 2)
                );

                confettiArray.push({
                    mesh: mesh,
                    vel: velocity,
                    rotSpeed: new THREE.Vector3(Math.random() * 10, Math.random() * 10, Math.random() * 10),
                    life: 1.0 + Math.random() * 1.5
                });
                scene.add(mesh);
            }
        }

        // --- MOVIMIENTO DE CONFETI ---
        function updateConfetti(dt) {
            for (let i = confettiArray.length - 1; i >= 0; i--) {
                const c = confettiArray[i];
                c.mesh.position.addScaledVector(c.vel, dt);
                c.vel.y -= 9.8 * dt;

                c.mesh.rotation.x += c.rotSpeed.x * dt;
                c.mesh.rotation.y += c.rotSpeed.y * dt;
                c.mesh.rotation.z += c.rotSpeed.z * dt;

                c.life -= dt;
                if (c.life <= 0) {
                    scene.remove(c.mesh);
                    c.mesh.geometry.dispose();
                    c.mesh.material.dispose();
                    confettiArray.splice(i, 1);
                }
            }
        }

        // --- CÁMARAS CINEMATOGRÁFICAS ---
        function changeCamera(mode) {
            if (!controls) return;
            controls.enabled = false;

            const targetPos = new THREE.Vector3();
            const lookAtTarget = new THREE.Vector3(4, 1.8, 0);
            
            const distance = displayedParameters.distance || 8;
            const absoluteRimHeight = LAUNCH_HEIGHT + (displayedParameters.height || 1.2);

            switch (mode) {
                case "lateral":
                    targetPos.set(distance / 2, 3.2, distance * 1.1);
                    lookAtTarget.set(distance / 2, 1.8, 0);
                    break;
                case "jugador":
                    targetPos.set(-1.8, 2.3, 0);
                    lookAtTarget.set(distance, absoluteRimHeight, 0);
                    break;
                case "canasta":
                    targetPos.set(distance + 2.0, absoluteRimHeight + 1.2, 2.2);
                    lookAtTarget.set(distance, absoluteRimHeight - 0.2, 0);
                    break;
                case "orbital":
                default:
                    targetPos.set(-4, 4, 8);
                    lookAtTarget.set(distance / 2, 1.5, 0);
                    controls.enabled = true;
                    break;
            }

            const startPos = camera.position.clone();
            const startLook = controls.target.clone();
            const duration = 1200;
            const startTime = performance.now();

            function easeInOutCubic(t) {
                return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
            }

            function step(now) {
                const elapsed = now - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const ease = easeInOutCubic(progress);

                camera.position.lerpVectors(startPos, targetPos, ease);
                controls.target.lerpVectors(startLook, lookAtTarget, ease);
                camera.lookAt(controls.target);

                if (progress < 1) {
                    requestAnimationFrame(step);
                } else {
                    if (mode === "orbital") controls.enabled = true;
                }
            }
            requestAnimationFrame(step);
        }

        function onWindowResize() {
            const container = document.getElementById("canvas-container");
            camera.aspect = container.clientWidth / container.clientHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(container.clientWidth, container.clientHeight);
        }

        // --- LÓGICA DE FÍSICA Y CONTROL DEL JUEGO ---

        function generateValidProblem() {
            let v0, angleDeg, timeToHoop, targetDist, targetHeightRel;
            let possible = false;
            let iterations = 0;
            
            while (!possible && iterations < 200) {
                iterations++;
                v0 = Math.random() * 8 + 7; // v0 (7 a 15 m/s)
                angleDeg = Math.random() * 45 + 25; // Ángulo (25° a 70°)
                const angleRad = angleDeg * (Math.PI / 180);
                const vx = v0 * Math.cos(angleRad);
                const vy = v0 * Math.sin(angleRad);
                
                const t_peak = vy / GRAVITY;
                const minTimeFactor = 1.1;
                const maxTimeFactor = 1.8;
                timeToHoop = t_peak * (minTimeFactor + Math.random() * (maxTimeFactor - minTimeFactor));
                
                if (timeToHoop < 0.4) continue;
                
                targetDist = vx * timeToHoop;
                targetHeightRel = vy * timeToHoop - 0.5 * GRAVITY * timeToHoop * timeToHoop;
                
                if (targetDist > 3 && targetDist < 16 && targetHeightRel > 0.3 && targetHeightRel < 3.5) {
                    possible = true;
                    problemParameters = {
                        velocity: v0,
                        angle: angleDeg,
                        distance: targetDist,
                        height: targetHeightRel,
                        time: timeToHoop
                    };
                }
            }

            if (!possible) {
                problemParameters = { velocity: 11.2, angle: 45, distance: 8.0, height: 1.1, time: 1.0 };
            }
            
            missingVariableType = variableKeys[Math.floor(Math.random() * variableKeys.length)];
            
            // --- CONVERSIÓN A PARÁMETROS MOSTRADOS TOTALMENTE COHERENTES (FÍSICA EXACTA DE 1 DECIMAL) ---
            // Tomamos 3 variables independientes reales del problema, las redondeamos a 1 decimal fijo,
            // recalculamos la variable incógnita del ejercicio en base a estas mostradas,
            // y recalculamos de forma consistente la variable dependiente restante de la UI.
            if (missingVariableType === "velocity") {
                const angle_disp = parseFloat(problemParameters.angle.toFixed(1));
                const distance_disp = parseFloat(problemParameters.distance.toFixed(1));
                const time_disp = parseFloat(problemParameters.time.toFixed(1));
                
                // v₀ = d / (t · cos(θ))
                correctAnswer = parseFloat((distance_disp / (time_disp * Math.cos(angle_disp * Math.PI / 180))).toFixed(1));
                // Recalculamos la altura mostrada para que coincida perfectamente: h = v₀ · sin(θ) · t - 0.5 · g · t²
                const height_disp = parseFloat((correctAnswer * Math.sin(angle_disp * Math.PI / 180) * time_disp - 0.5 * GRAVITY * time_disp * time_disp).toFixed(1));
                
                displayedParameters = {
                    velocity: correctAnswer,
                    angle: angle_disp,
                    distance: distance_disp,
                    time: time_disp,
                    height: height_disp
                };
            } else if (missingVariableType === "angle") {
                const velocity_disp = parseFloat(problemParameters.velocity.toFixed(1));
                const distance_disp = parseFloat(problemParameters.distance.toFixed(1));
                const time_disp = parseFloat(problemParameters.time.toFixed(1));
                
                // θ = arccos(d / (v₀ · t))
                const cosAngle = distance_disp / (velocity_disp * time_disp);
                correctAnswer = parseFloat((Math.acos(Math.max(-1, Math.min(1, cosAngle))) * 180 / Math.PI).toFixed(1));
                // Altura consistente:
                const height_disp = parseFloat((velocity_disp * Math.sin(correctAnswer * Math.PI / 180) * time_disp - 0.5 * GRAVITY * time_disp * time_disp).toFixed(1));
                
                displayedParameters = {
                    velocity: velocity_disp,
                    angle: correctAnswer,
                    distance: distance_disp,
                    time: time_disp,
                    height: height_disp
                };
            } else if (missingVariableType === "distance") {
                const velocity_disp = parseFloat(problemParameters.velocity.toFixed(1));
                const angle_disp = parseFloat(problemParameters.angle.toFixed(1));
                const time_disp = parseFloat(problemParameters.time.toFixed(1));
                
                // d = v₀ · cos(θ) · t
                correctAnswer = parseFloat((velocity_disp * Math.cos(angle_disp * Math.PI / 180) * time_disp).toFixed(1));
                // Altura consistente:
                const height_disp = parseFloat((velocity_disp * Math.sin(angle_disp * Math.PI / 180) * time_disp - 0.5 * GRAVITY * time_disp * time_disp).toFixed(1));
                
                displayedParameters = {
                    velocity: velocity_disp,
                    angle: angle_disp,
                    distance: correctAnswer,
                    time: time_disp,
                    height: height_disp
                };
            } else if (missingVariableType === "time") {
                const velocity_disp = parseFloat(problemParameters.velocity.toFixed(1));
                const angle_disp = parseFloat(problemParameters.angle.toFixed(1));
                const distance_disp = parseFloat(problemParameters.distance.toFixed(1));
                
                // t = d / (v₀ · cos(θ))
                correctAnswer = parseFloat((distance_disp / (velocity_disp * Math.cos(angle_disp * Math.PI / 180))).toFixed(1));
                // Altura consistente:
                const height_disp = parseFloat((velocity_disp * Math.sin(angle_disp * Math.PI / 180) * correctAnswer - 0.5 * GRAVITY * correctAnswer * correctAnswer).toFixed(1));
                
                displayedParameters = {
                    velocity: velocity_disp,
                    angle: angle_disp,
                    distance: distance_disp,
                    time: correctAnswer,
                    height: height_disp
                };
            } else if (missingVariableType === "height") {
                const velocity_disp = parseFloat(problemParameters.velocity.toFixed(1));
                const angle_disp = parseFloat(problemParameters.angle.toFixed(1));
                const time_disp = parseFloat(problemParameters.time.toFixed(1));
                
                // h = v₀ · sin(θ) · t - 0.5 · g · t²
                correctAnswer = parseFloat((velocity_disp * Math.sin(angle_disp * Math.PI / 180) * time_disp - 0.5 * GRAVITY * time_disp * time_disp).toFixed(1));
                // Distancia consistente:
                const distance_disp = parseFloat((velocity_disp * Math.cos(angle_disp * Math.PI / 180) * time_disp).toFixed(1));
                
                displayedParameters = {
                    velocity: velocity_disp,
                    angle: angle_disp,
                    distance: distance_disp,
                    time: time_disp,
                    height: correctAnswer
                };
            }
        }

        function drawSetup() {
            // El balón inicia exactamente en las manos virtuales del tirador (LAUNCH_HEIGHT = 1.55)
            basketball.position.set(0, LAUNCH_HEIGHT, 0);
            
            const angleVal = displayedParameters.angle;
            const angleRad = angleVal * (Math.PI / 180);

            // ARTICULAR EL MANIQUÍ PARA RECREAR LA POSTURA DE TIRO NATURAL
            shoulderPivotLeft.rotation.set(0, 0, 0);
            shoulderPivotRight.rotation.set(0, 0, 0);
            forearmLeft.rotation.set(0, 0, 0);
            forearmRight.rotation.set(0, 0, 0);

            // Rotar hombros hacia adelante y arriba según el ángulo de tiro
            shoulderPivotLeft.rotation.z = angleRad - 0.2;
            shoulderPivotRight.rotation.z = angleRad - 0.2;

            // Inclinar los brazos hacia el centro para sostener la pelota en (Z = 0)
            shoulderPivotLeft.rotation.y = 0.28;
            shoulderPivotRight.rotation.y = -0.28;

            // Flexionar codos de forma natural
            forearmLeft.rotation.z = -1.1;
            forearmRight.rotation.z = -1.1;

            // POSICIONAR LA CANASTA (SÓLO EL POSTE METÁLICO VERTICAL)
            const dist = displayedParameters.distance;
            const relHeight = displayedParameters.height;
            const absoluteHeight = LAUNCH_HEIGHT + relHeight;

            basketGroup.position.set(dist, 0, 0);
            hoopRim.position.set(0, absoluteHeight, 0);
            hoopNet.position.set(0, absoluteHeight - 0.2, 0);
            
            boardMesh.position.set(0.45, absoluteHeight + 0.55, 0);
            boardBorderMesh.position.set(0.45, absoluteHeight + 0.55, 0);

            // Ajustar el poste único a la duela de la cancha
            poleMesh.position.set(0.55, (absoluteHeight + 0.55) / 2, 0);
            poleMesh.scale.set(1, absoluteHeight + 0.55, 1);

            // Trayectoria guía estática sutil
            const v0 = displayedParameters.velocity;
            const vx = v0 * Math.cos(angleRad);
            const vy = v0 * Math.sin(angleRad);
            const points = [];
            
            for (let t = 0; t <= displayedParameters.time; t += 0.05) {
                const px = vx * t;
                const py = LAUNCH_HEIGHT + vy * t - 0.5 * GRAVITY * t * t;
                points.push(new THREE.Vector3(px, py, 0));
            }
            points.push(new THREE.Vector3(dist, absoluteHeight, 0));
            
            flightCurve.geometry.setFromPoints(points);
            flightCurve.visible = true;
        }

        function showUIProblem() {
            const varsDiv = document.getElementById("variables-dadas");
            varsDiv.innerHTML = "";

            variableKeys.forEach(key => {
                const meta = variableMeta[key];
                if (key !== missingVariableType) {
                    // Mostrar las variables dadas formateadas a 1 decimal
                    const value = displayedParameters[key].toFixed(1);
                    varsDiv.innerHTML += `
                        <div class="bg-gray-950/50 border border-gray-800/80 flex flex-col justify-center items-center px-1.5 py-0.5 rounded text-center">
                            <span class="text-[7.5px] text-gray-400 font-bold uppercase tracking-wider">${meta.label}</span>
                            <span class="font-orbitron font-black text-[9.5px] text-orange-400 leading-tight">${value} <span class="text-[7.5px] text-gray-300 font-sans">${meta.unit}</span></span>
                        </div>
                    `;
                } else {
                    document.getElementById("input-title").textContent = `Calcula: ${meta.label}`;
                    document.getElementById("unit-label").textContent = meta.unit;
                    document.getElementById("manual-input").value = "";
                }
            });

            if (attemptsLeft === 3) {
                document.getElementById("manual-input-wrapper").classList.remove("hidden");
                document.getElementById("options-container").classList.add("hidden");
                document.getElementById("manual-input").focus();
            } else {
                document.getElementById("manual-input-wrapper").classList.add("hidden");
                document.getElementById("options-container").classList.remove("hidden");
                generateMultipleChoices();
            }

            document.getElementById("attempts-count").textContent = attemptsLeft;
            document.getElementById("score-display").textContent = currentScore;
            document.getElementById("lanzarBtn").disabled = false;
        }

        // Selección visual y asignación interactiva limpia
        function selectOption(el) {
            const siblings = el.parentNode.children;
            for (let sibling of siblings) {
                sibling.classList.remove("border-red-600", "bg-yellow-300");
                sibling.classList.add("border-orange-500", "bg-yellow-400");
            }
            el.classList.remove("border-orange-500", "bg-yellow-400");
            el.classList.add("border-red-600", "bg-yellow-300");
        }

        function generateMultipleChoices() {
            const container = document.getElementById("options-container");
            container.innerHTML = "";

            if (currentOptions.length === 0) {
                const set = new Set();
                set.add(correctAnswer);

                let attempts = 0;
                const targetSize = (attemptsLeft === 2 ? 4 : 2);

                while (set.size < targetSize && attempts < 200) {
                    attempts++;
                    // Generar variaciones de error con 1 decimal
                    const mult = 0.65 + Math.random() * 0.7;
                    let val = parseFloat((correctAnswer * mult).toFixed(1));
                    if (val <= 0) val = parseFloat((correctAnswer + (Math.random() * 3 + 1)).toFixed(1));
                    
                    // Asegurar diferencia mínima de 0.2 para evitar confusiones al redondear
                    let isFarEnough = true;
                    for (let existing of set) {
                        if (Math.abs(val - existing) < 0.2) {
                            isFarEnough = false;
                            break;
                        }
                    }
                    if (isFarEnough) {
                        set.add(val);
                    }
                }

                // Fallback de seguridad en caso de valores muy pequeños
                let fallbackOffset = 0.3;
                while (set.size < targetSize) {
                    let valPositive = parseFloat((correctAnswer + fallbackOffset).toFixed(1));
                    let valNegative = parseFloat((correctAnswer - fallbackOffset).toFixed(1));
                    
                    if (valPositive > 0) {
                        let ok = true;
                        for (let existing of set) {
                            if (Math.abs(valPositive - existing) < 0.19) ok = false;
                        }
                        if (ok) set.add(valPositive);
                    }
                    if (set.size < targetSize && valNegative > 0) {
                        let ok = true;
                        for (let existing of set) {
                            if (Math.abs(valNegative - existing) < 0.19) ok = false;
                        }
                        if (ok) set.add(valNegative);
                    }
                    fallbackOffset += 0.3;
                }

                currentOptions = Array.from(set).sort(() => Math.random() - 0.5);
            }

            // Opciones sumamente compactas sin scroll lateral
            currentOptions.forEach((opt, idx) => {
                container.innerHTML += `
                    <div class="flex items-center justify-between bg-yellow-400 hover:bg-yellow-300 text-black px-2 py-1 rounded cursor-pointer select-none transition-all border border-orange-500 shadow-sm text-[10px] h-[22px]" onclick="document.getElementById('opt-radio-${idx}').checked=true; selectOption(this)">
                        <div class="flex items-center gap-1.5">
                            <input type="radio" id="opt-radio-${idx}" name="optionGroup" value="${opt}" class="w-3 h-3 accent-orange-700 cursor-pointer">
                            <span class="font-orbitron text-xs text-black font-black leading-none">${opt.toFixed(1)}</span>
                        </div>
                        <span class="text-[7.5px] text-red-700 font-bold font-orbitron uppercase tracking-wider leading-none">${variableMeta[missingVariableType].unit}</span>
                    </div>
                `;
            });
        }

        function getUserAnswer() {
            if (attemptsLeft === 3) {
                const val = parseFloat(document.getElementById("manual-input").value);
                if (isNaN(val) || val <= 0) {
                    showFeedback("Por favor, introduce una respuesta positiva válida.", "text-yellow-400");
                    return null;
                }
                return val;
            } else {
                const selected = document.querySelector('input[name="optionGroup"]:checked');
                if (!selected) {
                    showFeedback("Selecciona una opción antes de lanzar.", "text-yellow-400");
                    return null;
                }
                return parseFloat(selected.value);
            }
        }

        function showFeedback(text, colorClass = "text-blue-400") {
            const fb = document.getElementById("feedback");
            fb.className = `text-[10px] font-bold ${colorClass} leading-tight`;
            fb.textContent = text;
        }

        // --- SIMULACIÓN DEL TIRO EN TIEMPO REAL ---
        let currentLaunchId = 0;
        function triggerLaunch() {
            if (isShooting) return;

            const userVal = getUserAnswer();
            if (userVal === null || isNaN(userVal)) return;

            // Cerrar el cajón móvil para ver la simulación
            closeMobileDrawer();

            currentLaunchId++;
            const myLaunchId = currentLaunchId;

            isShooting = true;
            document.getElementById("lanzarBtn").disabled = true;
            flightCurve.visible = false;

            sfx.playShoot();

            let simV0 = displayedParameters.velocity;
            let simAngleDeg = displayedParameters.angle;

            if (missingVariableType === "velocity") {
                simV0 = userVal;
            } else if (missingVariableType === "angle") {
                simAngleDeg = userVal;
            } else {
                const diffRatio = userVal / correctAnswer;
                if (Math.abs(diffRatio - 1) > 0.01) {
                    if (missingVariableType === "distance") {
                        simV0 = simV0 * Math.sqrt(diffRatio);
                    } else if (missingVariableType === "height") {
                        simAngleDeg = simAngleDeg + (userVal - correctAnswer) * 8;
                    } else if (missingVariableType === "time") {
                        simV0 = simV0 * diffRatio;
                    }
                }
            }

            const simAngleRad = simAngleDeg * (Math.PI / 180);
            const vx = simV0 * Math.cos(simAngleRad);
            const vy = simV0 * Math.sin(simAngleRad);

            simTime = 0;
            trajectoryPoints = [];
            ballRotationSpeed = { x: (Math.random() - 0.5) * 5, y: -7.0 }; 

            const totalTimeLimit = 8.0;
            let hasBounced = false;
            let bXVel = vx;
            let bYVel = vy;
            let startSimPos = new THREE.Vector3(0, LAUNCH_HEIGHT, 0);

            // Comparación amigable usando la tolerancia adaptada
            const isCorrect = Math.abs(userVal - correctAnswer) <= ABS_TOLERANCE;

            changeCamera("canasta");

            const clock = new THREE.Clock();

            function simLoop() {
                if (myLaunchId !== currentLaunchId) return;
                if (!isShooting) return;

                const dt = Math.min(clock.getDelta(), 0.03);
                simTime += dt;

                // MOVIMIENTO DE EXTENSIÓN DE BRAZOS DEL MANIQUÍ AL LANZAR (FLICK)
                if (simTime < 0.35) {
                    forearmLeft.rotation.z = THREE.MathUtils.lerp(forearmLeft.rotation.z, -0.15, 0.18);
                    forearmRight.rotation.z = THREE.MathUtils.lerp(forearmRight.rotation.z, -0.15, 0.18);
                    shoulderPivotLeft.rotation.z = THREE.MathUtils.lerp(shoulderPivotLeft.rotation.z, simAngleRad + 0.15, 0.18);
                    shoulderPivotRight.rotation.z = THREE.MathUtils.lerp(shoulderPivotRight.rotation.z, simAngleRad + 0.15, 0.18);
                }

                if (!hasBounced) {
                    px = startSimPos.x + vx * simTime;
                    py = startSimPos.y + vy * simTime - 0.5 * GRAVITY * simTime * simTime;
                    basketball.rotation.z += ballRotationSpeed.y * dt;
                } else {
                    bYVel -= GRAVITY * dt;
                    basketball.position.x += bXVel * dt;
                    basketball.position.y += bYVel * dt;
                    
                    px = basketball.position.x;
                    py = basketball.position.y;
                    basketball.rotation.x += ballRotationSpeed.x * dt;
                }

                if (!hasBounced) {
                    basketball.position.set(px, py, 0);
                }

                const hoopX = displayedParameters.distance;
                const hoopY = LAUNCH_HEIGHT + displayedParameters.height;

                // 1. Swish - Enceste Limpio
                if (!hasBounced && isCorrect && Math.abs(px - hoopX) < 0.15 && Math.abs(py - hoopY) < 0.15 && vy - GRAVITY * simTime < 0) {
                    sfx.playSwish();
                    createConfetti(new THREE.Vector3(hoopX, hoopY, 0));
                    
                    hoopNet.scale.set(1.3, 0.8, 1.3);
                    setTimeout(() => hoopNet.scale.set(1, 1, 1), 500);

                    hasBounced = true;
                    bXVel = 0.1;
                    bYVel = -1.5;
                }

                // 2. Colisión con el Aro
                if (!hasBounced && !isCorrect) {
                    const distToRimCenter = Math.sqrt(Math.pow(px - hoopX, 2) + Math.pow(py - hoopY, 2));
                    if (distToRimCenter < 0.28 && distToRimCenter > 0.18) {
                        sfx.playBounce();
                        hasBounced = true;
                        bXVel = -vx * 0.45 - (Math.random() * 0.5);
                        bYVel = Math.abs(vy - GRAVITY * simTime) * 0.45;
                        ballRotationSpeed.x = 10.0;
                    }
                }

                // 3. Colisión con el Tablero
                if (!hasBounced && px >= (hoopX + 0.4) && Math.abs(py - (hoopY + 0.5)) < 0.7) {
                    sfx.playBounce();
                    hasBounced = true;
                    bXVel = -vx * 0.5;
                    bYVel = (vy - GRAVITY * simTime) * 0.3;
                }

                // 4. Choque con el Suelo de Madera (Si falla rebota y rueda libremente)
                if (basketball.position.y <= 0.12) {
                    basketball.position.y = 0.12;
                    if (!hasBounced) {
                        hasBounced = true;
                        bXVel = vx * 0.2;
                        bYVel = Math.abs(vy - GRAVITY * simTime) * 0.4;
                    } else {
                        bYVel = -bYVel * 0.4;
                        bXVel *= 0.6;
                    }
                    sfx.playBounce();
                    if (Math.abs(bYVel) < 0.2) bYVel = 0;
                }

                if (simTime > totalTimeLimit || (hasBounced && Math.abs(bXVel) < 0.05 && Math.abs(bYVel) < 0.05) || px > hoopX + 8) {
                    isShooting = false;
                    processScoreResult(isCorrect, userVal);
                    return;
                }

                requestAnimationFrame(simLoop);
            }

            requestAnimationFrame(simLoop);
        }

        function processScoreResult(isCorrect, userVal) {
            const meta = variableMeta[missingVariableType];
            
            if (isCorrect) {
                let pointsEarned = 0;
                let msg = "";
                
                if (attemptsLeft === 3) {
                    pointsEarned = 100;
                    msg = "¡TIRO PERFECTO! +100 PTS";
                } else if (attemptsLeft === 2) {
                    pointsEarned = 50;
                    msg = "¡BUEN TIRO! +50 PTS";
                } else {
                    pointsEarned = 20;
                    msg = "¡ENCESTADO! +20 PTS";
                }

                sfx.playSuccess();
                currentScore += pointsEarned;
                document.getElementById("score-display").textContent = currentScore;
                
                showFeedback(msg, "text-green-400 font-black tracking-wider text-[10px] animate-bounce");
                document.getElementById("correct-answer-display").textContent = `Respuesta exacta: ${correctAnswer.toFixed(1)} ${meta.unit}`;
                
                document.getElementById("lanzarBtn").classList.add("hidden");
                // Abrir cajón para mostrar el resultado en móvil
                openMobileDrawer();
            } else {
                attemptsLeft--;
                sfx.playFailure();
                document.getElementById("attempts-count").textContent = attemptsLeft;

                // Transición rápida (800ms) para que el alumno no espere demasiado
                if (attemptsLeft === 2) {
                    showFeedback("¡Fallaste! Intentemos con opciones múltiples.", "text-red-400");
                    currentOptions = [];
                    setTimeout(() => {
                        showUIProblem();
                        changeCamera("lateral");
                        openMobileDrawer();
                    }, 800);
                } else if (attemptsLeft === 1) {
                    showFeedback("¡Incorrecto! Intento final con opción 50/50.", "text-red-400");
                    currentOptions = [correctAnswer, currentOptions.find(o => o !== correctAnswer)].sort(() => Math.random() - 0.5);
                    setTimeout(() => {
                        showUIProblem();
                        changeCamera("lateral");
                        openMobileDrawer();
                    }, 800);
                } else {
                    showFeedback(`Juego Terminado. Respuesta: ${correctAnswer.toFixed(1)} ${meta.unit}`, "text-red-500 font-extrabold");
                    document.getElementById("correct-answer-display").textContent = `¡Sigue practicando las fórmulas!`;
                    
                    document.getElementById("lanzarBtn").classList.add("hidden");
                    // Abrir cajón para mostrar resultado final
                    openMobileDrawer();
                }
            }
        }

        function resetExercise() {
            currentLaunchId++;
            attemptsLeft = 3;
            currentOptions = [];
            isShooting = false;
            confettiArray = [];
            
            document.getElementById("lanzarBtn").classList.remove("hidden");
            document.getElementById("correct-answer-display").textContent = "";
            showFeedback("Nuevo problema listo. ¡Haz tus cálculos!", "text-blue-400");

            generateValidProblem();
            drawSetup();
            showUIProblem();
            changeCamera("lateral");
            // Abrir cajón automáticamente al iniciar nuevo ejercicio en móvil
            openMobileDrawer();
        }

        let isPanelHidden = false;
        function toggleSidebar() {
            if (typeof sfx !== 'undefined' && sfx.playTick) sfx.playTick();
            const panel = document.getElementById("side-panel");
            const btn = document.getElementById("togglePanelBtn");
            const icon = document.getElementById("toggleIcon");
            
            isPanelHidden = !isPanelHidden;
            if (isPanelHidden) {
                panel.style.transform = "translateX(-225px)";
                btn.style.left = "12px";
                icon.innerHTML = `
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                `;
            } else {
                panel.style.transform = "translateX(0px)";
                btn.style.left = "220px";
                icon.innerHTML = `
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                `;
            }
        }

        // --- CAJÓN MÓVIL ---
        let isMobileDrawerOpen = false;
        function toggleMobileDrawer() {
            isMobileDrawerOpen = !isMobileDrawerOpen;
            const wrapper = document.getElementById('panels-wrapper');
            const text = document.getElementById('mobile-drawer-text');
            const icon = document.getElementById('mobile-drawer-icon');

            if (isMobileDrawerOpen) {
                wrapper.classList.add('drawer-open');
                text.textContent = 'Ocultar Panel';
                icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>`;
            } else {
                wrapper.classList.remove('drawer-open');
                text.textContent = 'Ver Datos y Resolver';
                icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>`;
            }
        }

        function openMobileDrawer() {
            if (window.innerWidth <= 768 && !isMobileDrawerOpen) toggleMobileDrawer();
        }
        function closeMobileDrawer() {
            if (window.innerWidth <= 768 && isMobileDrawerOpen) toggleMobileDrawer();
        }

        function toggleHelpModal() {
            const modal = document.getElementById("help-modal");
            modal.classList.toggle("hidden");
        }

        // --- ANIMACIÓN PRINCIPAL DE THREE.JS ---
        const systemClock = new THREE.Clock();
        function animate() {
            requestAnimationFrame(animate);
            const dt = systemClock.getDelta();

            if (controls && controls.enabled) {
                controls.update();
            }

            // Suavizar paneo horizontal de cámara
            smoothPanX += (cameraPanX - smoothPanX) * 0.1;
            if (!controls.enabled) {
                camera.position.x += (smoothPanX - camera.position.x) * 0.0; // desplazamiento directo
                // Trasladar la cámara en el eje X según el paneo
                camera.position.x = camera.position.x + smoothPanX * 0.02;
            }

            updateConfetti(dt);

            if (renderer && scene && camera) {
                renderer.render(scene, camera);
            }
        }

        window.onload = function() {
            init3D();
            resetExercise();
            animate();
            
            document.getElementById("lanzarBtn").addEventListener("click", triggerLaunch);
            document.getElementById("resetBtn").addEventListener("click", resetExercise);
            
            document.getElementById("manual-input").addEventListener("keypress", function(e) {
                if (e.key === "Enter") {
                    triggerLaunch();
                }
            });
        };
    </script>
</body>
</html>