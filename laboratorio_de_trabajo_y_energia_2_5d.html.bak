<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laboratorio de Trabajo y Energía 2.5D</title>
    <!-- Tailwind CSS para diseño moderno -->
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <!-- KaTeX para renderizar ecuaciones matemáticas LaTeX -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js"></script>
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #03050d;
            overflow: hidden;
        }
        .font-orbitron {
            font-family: 'Orbitron', sans-serif;
        }
        /* Glassmorphism de última generación */
        .glass-panel {
            background: rgba(8, 12, 28, 0.85);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 243, 255, 0.15);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            background: rgba(0, 243, 255, 0.05);
            border-color: rgba(0, 243, 255, 0.3);
        }
        /* Neon glowing lines & buttons */
        .neon-border-blue {
            box-shadow: 0 0 10px rgba(0, 243, 255, 0.4);
        }
        .neon-text-blue {
            text-shadow: 0 0 8px rgba(0, 243, 255, 0.6);
        }
        .neon-text-green {
            text-shadow: 0 0 8px rgba(16, 185, 129, 0.6);
        }
        .neon-text-red {
            text-shadow: 0 0 8px rgba(239, 68, 68, 0.6);
        }
        /* Custom scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.2);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(0, 243, 255, 0.4);
            border-radius: 2px;
        }
        /* Sliding classes (for robust panel hiding) */
        .left-panel-hidden {
            transform: translateX(-275px) !important;
        }
        .right-panel-hidden {
            transform: translateX(275px) !important;
        }
        /* Input styling */
        input[type="number"]::-webkit-inner-spin-button,
        input[type="number"]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        
        /* Estilos legibles para el selector de modos */
        #mode-selector {
            background-color: #080c18 !important;
            color: #00f3ff !important;
            border: 1px solid rgba(0, 243, 255, 0.3) !important;
        }
        #mode-selector option {
            background-color: #080c18 !important;
            color: #e2e8f0 !important;
        }
        
        /* Botón de despliegue móvil */
        #mobile-drawer-toggle {
            position: fixed !important;
            bottom: 16px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 40;
            display: none !important; /* Oculto en PC */
            transition: bottom 0.4s cubic-bezier(0.25, 1, 0.5, 1), transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.2s, box-shadow 0.2s !important;
        }
        .hidden-force {
            display: none !important;
        }

        /* --- ESTILOS RESPONSIVOS PARA MÓVILES Y TABLETS --- */
        @media (max-width: 768px) {
            /* Mostrar botón de despliegue */
            #mobile-drawer-toggle {
                display: flex !important;
            }

            /* 1. Contenedor de Paneles en la parte inferior */
            #panels-wrapper {
                position: absolute !important;
                left: 8px !important;
                right: 8px !important;
                bottom: 8px !important;
                top: auto !important;
                width: auto !important;
                height: auto !important;
                max-height: 48vh !important;
                display: flex !important;
                flex-direction: column !important;
                gap: 8px !important;
                overflow-y: auto !important;
                pointer-events: auto !important;
                z-index: 30 !important;
                padding-right: 4px;
                padding-bottom: 74px !important;
                transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease-out !important;
            }

            #panels-wrapper.mobile-hidden {
                transform: translateY(120%) !important;
                opacity: 0 !important;
                pointer-events: none !important;
            }

            /* Ocultar botones de pestañas en móviles */
            #left-panel > div:nth-child(2),
            #right-panel > div:nth-child(2) {
                display: none !important;
            }

            /* Paneles izquierdo y derecho apilados */
            #left-panel, #right-panel {
                position: relative !important;
                left: auto !important;
                right: auto !important;
                top: auto !important;
                bottom: auto !important;
                width: 100% !important;
                height: auto !important;
                transform: none !important;
                margin: 0 !important;
                padding: 0 !important;
                display: flex !important;
                flex-direction: column !important;
                pointer-events: auto !important;
                transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease-out !important;
            }

            /* Ocultamiento con animación deslizante hacia abajo de los paneles individuales (sólo por si se usan) */
            #left-panel.left-panel-hidden, #right-panel.right-panel-hidden {
                transform: translateY(150%) !important;
                opacity: 0 !important;
                pointer-events: none !important;
                position: absolute !important;
            }

            /* Ajustar ancho y alto de los paneles glass */
            #left-panel .glass-panel, #right-panel .glass-panel {
                width: 100% !important;
                height: auto !important;
                min-height: unset !important;
                padding: 12px !important;
                border-radius: 16px !important;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6) !important;
            }

            /* 2. HUD Superior Compacto */
            .hud-top-bar {
                top: 8px !important;
                left: 8px !important;
                right: 8px !important;
                gap: 6px !important;
                justify-content: center !important;
            }

            .hud-title-block {
                display: none !important; /* Ocultar título para ganar espacio */
            }

            .hud-mode-block {
                padding: 4px 8px !important;
                border-radius: 10px !important;
            }

            .hud-mode-block span {
                font-size: 7px !important;
            }

            #mode-selector {
                font-size: 9px !important;
                padding: 2px 4px !important;
            }

            .hud-score-block {
                padding: 4px 6px !important;
                gap: 8px !important;
                border-radius: 10px !important;
            }

            .hud-score-block > div {
                padding-left: 6px !important;
                padding-right: 6px !important;
            }

            .hud-score-block small {
                font-size: 7px !important;
            }

            .hud-score-block span {
                font-size: 10px !important;
            }

            /* 3. Controles de Cámara Centrados y más pequeños, posicionados debajo del HUD */
            .camera-controls {
                top: 96px !important;
                padding: 4px 8px !important;
                border-radius: 10px !important;
                gap: 4px !important;
            }

            .camera-controls button {
                width: 30px !important;
                height: 30px !important;
            }

            .camera-controls svg {
                width: 14px !important;
                height: 14px !important;
            }

            .camera-controls span {
                height: 16px !important;
            }

            /* 4. Elementos Internos de Paneles */
            #variables-dadas {
                grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
                max-height: none !important;
                overflow-y: visible !important;
                gap: 6px !important;
            }

            #variables-dadas .glass-card {
                padding: 4px 6px !important;
                border-radius: 8px !important;
            }

            #variables-dadas span {
                font-size: 10px !important;
            }

            #left-panel a {
                padding: 4px 8px !important;
                font-size: 8px !important;
                border-radius: 8px !important;
            }

            #manual-input-wrapper {
                border-radius: 10px !important;
            }

            #manual-input {
                font-size: 14px !important;
                padding-top: 6px !important;
                padding-bottom: 6px !important;
            }

            #unit-label {
                font-size: 10px !important;
                right: 8px !important;
            }

            #options-container {
                display: grid !important;
                grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
                gap: 6px !important;
            }

            #options-container.hidden {
                display: none !important;
            }

            #options-container > div {
                height: 30px !important;
                padding: 4px 8px !important;
                border-radius: 8px !important;
            }

            #options-container span {
                font-size: 10px !important;
            }

            #feedback-panel {
                min-height: unset !important;
                padding: 8px !important;
                border-radius: 10px !important;
            }

            #feedback-title {
                font-size: 8.5px !important;
            }

            #feedback {
                font-size: 10.5px !important;
            }

            #correct-answer-display {
                font-size: 9px !important;
            }

            #lanzarBtn, #resetBtn {
                padding: 8px 12px !important;
                font-size: 10px !important;
                border-radius: 10px !important;
            }

            #lanzarBtn svg, #resetBtn svg {
                width: 12px !important;
                height: 12px !important;
            }

            /* 5. Escalamiento de Badges Flotantes de Física */
            #badge-cart {
                font-size: 7.5px !important;
                padding: 2px 5px !important;
                border-radius: 5px !important;
            }

            #badge-spring-top, #badge-spring-bottom {
                font-size: 7px !important;
                padding: 1px 4px !important;
                border-radius: 5px !important;
            }

            #badge-h1, #badge-vb, #badge-vc, #badge-h2, #badge-x1, #badge-x2 {
                font-size: 7px !important;
                padding: 1px 4px !important;
                border-radius: 4px !important;
            }
        }
    </style>

    <!-- Librerías de visualización -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body class="w-full h-screen text-gray-100 relative select-none">

    <!-- CONTENEDOR DE LA ESCENA 3D (Fondo del Laboratorio) -->
    <div id="canvas-container" class="absolute inset-0 w-full h-full z-0"></div>

    <!-- ETIQUETAS FLOTANTES DE ALTA VISIBILIDAD PARA EL CARRITO Y EL RESORTE -->
    <div id="badge-cart" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-red-600 to-rose-500 text-white font-orbitron font-black text-xs px-2.5 py-1 rounded-lg shadow-[0_0_15px_rgba(239,68,68,0.6)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        CARRITO
    </div>
    <div id="badge-spring-top" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-blue-600 to-cyan-500 text-white font-orbitron font-black text-[10px] px-2 py-0.5 rounded-lg shadow-[0_0_15px_rgba(0,243,255,0.6)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        RESORTE SUP
    </div>
    <div id="badge-spring-bottom" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-blue-600 to-cyan-500 text-white font-orbitron font-black text-[10px] px-2 py-0.5 rounded-lg shadow-[0_0_15px_rgba(0,243,255,0.6)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        RESORTE INF
    </div>
    <div id="badge-h1" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-yellow-600 to-amber-500 text-white font-orbitron font-black text-[9.5px] px-2 py-0.5 rounded-md shadow-[0_0_10px_rgba(245,158,11,0.4)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        h₁ = --
    </div>
    <div id="badge-vb" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-yellow-600 to-amber-500 text-white font-orbitron font-black text-[9.5px] px-2 py-0.5 rounded-md shadow-[0_0_10px_rgba(245,158,11,0.4)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        v_B = --
    </div>
    <div id="badge-vc" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-yellow-600 to-amber-500 text-white font-orbitron font-black text-[9.5px] px-2 py-0.5 rounded-md shadow-[0_0_10px_rgba(245,158,11,0.4)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        v_C = --
    </div>
    <div id="badge-h2" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-yellow-600 to-amber-500 text-white font-orbitron font-black text-[9.5px] px-2 py-0.5 rounded-md shadow-[0_0_10px_rgba(245,158,11,0.4)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        h₂ = --
    </div>
    <div id="badge-x1" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-yellow-600 to-amber-500 text-white font-orbitron font-black text-[9.5px] px-2 py-0.5 rounded-md shadow-[0_0_10px_rgba(245,158,11,0.4)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        x₁ = --
    </div>
    <div id="badge-x2" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-yellow-600 to-amber-500 text-white font-orbitron font-black text-[9.5px] px-2 py-0.5 rounded-md shadow-[0_0_10px_rgba(245,158,11,0.4)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        x₂ = --
    </div>

    <!-- INTERFAZ HUD SUPERIOR (Dashboard de Progreso) -->
    <div class="hud-top-bar absolute top-3 left-3 right-3 z-10 pointer-events-none flex flex-wrap justify-between items-center gap-2">
        <!-- Izquierda: Título Principal -->
        <div class="hud-title-block glass-panel rounded-xl px-4 py-2 pointer-events-auto flex items-center gap-3 shadow-2xl">
            <div class="w-8 h-8 bg-gradient-to-tr from-cyan-500 to-blue-600 rounded-lg flex items-center justify-center shadow-lg neon-border-blue">
                <svg class="w-4 h-4 text-gray-950" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
            </div>
            <div>
                <h1 class="font-orbitron text-xs font-black tracking-wider text-cyan-400 leading-none">TRABAJO Y ENERGÍA</h1>
                <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest leading-none mt-1">Plataforma de Simulación Física</p>
            </div>
        </div>

        <!-- HUD Superior Central: Selector de Modos y Estado -->
        <div class="hud-mode-block glass-panel rounded-xl px-3 py-1 pointer-events-auto flex items-center gap-2 shadow-2xl border border-cyan-500/20">
            <span class="text-[8px] text-gray-400 font-bold uppercase tracking-widest font-orbitron">Modo:</span>
            <select id="mode-selector" class="bg-black/60 border border-cyan-500/30 text-cyan-300 font-orbitron font-extrabold text-[10px] px-2 py-1 rounded-lg focus:outline-none focus:ring-1 focus:ring-cyan-400 transition-all cursor-pointer">
                <option value="basico">Básico: Conservación Em</option>
                <option value="estandar">Estándar: Trabajo y Fricción</option>
                <option value="avanzado">Avanzado: Energía Elástica</option>
            </select>
        </div>

        <!-- Derecha: Marcadores de Juego -->
        <div class="hud-score-block glass-panel rounded-xl p-1.5 pointer-events-auto flex items-center gap-6 shadow-2xl">
            <div class="px-3 border-r border-gray-800/80 text-center">
                <small class="text-gray-400 text-[8px] font-bold block tracking-wider leading-none">PUNTUACIÓN</small>
                <span id="score-display" class="font-orbitron text-sm font-black text-emerald-400 leading-none block mt-1 neon-text-green">0</span>
            </div>
            <div class="px-3 border-r border-gray-800/80 text-center">
                <small class="text-gray-400 text-[8px] font-bold block tracking-wider leading-none">INTENTOS RESTANTES</small>
                <div id="hearts-container" class="flex gap-0.5 justify-center mt-1">
                    <!-- Corazones dinámicos -->
                </div>
            </div>
            <div class="px-3 text-center">
                <small class="text-gray-400 text-[8px] font-bold block tracking-wider leading-none">FASE DE JUEGO</small>
                <span id="phase-badge" class="font-orbitron text-[9px] font-black text-cyan-400 leading-none block mt-1 bg-cyan-950/40 px-2 py-0.5 rounded border border-cyan-800/50">1 - Entrada Libre</span>
            </div>
        </div>
    </div>

    <!-- CONTENEDOR ENVOLVENTE DE PANELES (Para control responsivo en móviles) -->
    <div id="panels-wrapper" class="absolute inset-0 pointer-events-none z-20 flex justify-between mobile-hidden">
        <!-- PANEL FLOTANTE IZQUIERDO (Datos del Ejercicio) -->
        <div id="left-panel" class="absolute left-3 top-20 bottom-3 z-20 flex flex-row items-start transition-transform duration-500 ease-out pointer-events-none" style="width: 310px;">
            
            <!-- Panel Principal de Variables -->
            <div class="glass-panel rounded-2xl p-4 pointer-events-auto flex flex-col gap-3.5 shadow-2xl w-[260px] h-full justify-between border border-cyan-500/10">
                <div class="flex flex-col gap-3.5">
                    <!-- Botón Volver -->
                    <a href="./index.html" class="glass-card rounded-xl p-2 flex items-center justify-center gap-1.5 text-[8.5px] text-cyan-400 hover:text-cyan-300 font-bold uppercase tracking-wider font-orbitron transition-all">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                        Volver al Inicio
                    </a>
                    <div>
                        <span class="text-[9px] font-extrabold text-cyan-400 uppercase tracking-widest font-orbitron block mb-2">Variables Conocidas</span>
                        <div id="variables-dadas" class="grid grid-cols-2 gap-2 max-h-[50vh] overflow-y-auto pr-1 custom-scrollbar">
                            <!-- Inyectadas dinámicamente -->
                        </div>
                    </div>
                </div>

                <!-- Interruptor para Visualizar Fuerzas (DCL) -->
                <div class="border-t border-gray-800/80 pt-3 flex items-center justify-between">
                    <div class="flex flex-col">
                        <span class="text-[10px] font-bold text-gray-300">Mostrar Fuerzas (DCL)</span>
                        <span class="text-[8px] text-gray-500">Muestra los vectores físicos en 2.5D</span>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" id="toggle-fbd" class="sr-only peer" checked>
                        <div class="w-9 h-5 bg-gray-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-gray-400 after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-cyan-500 peer-checked:after:bg-gray-950"></div>
                    </label>
                </div>
            </div>

            <!-- Pestaña de Ocultar/Mostrar Acoplada al Panel -->
            <div class="pointer-events-auto ml-1.5 mt-6 self-start">
                <button id="toggle-panel-btn" class="w-10 h-10 bg-gray-950/90 hover:bg-cyan-500 text-cyan-400 hover:text-gray-950 border border-cyan-500/20 rounded-xl flex items-center justify-center transition-all shadow-xl backdrop-blur-md">
                    <svg id="toggle-panel-icon" class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 19l-7-7 7-7" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- PANEL FLOTANTE DERECHO (Resolución y Feedback) -->
        <div id="right-panel" class="absolute right-3 top-20 bottom-3 z-20 flex flex-row-reverse items-start transition-transform duration-500 ease-out pointer-events-none" style="width: 310px;">
            
            <!-- Panel Principal de Resolución -->
            <div class="glass-panel rounded-2xl p-4 pointer-events-auto flex flex-col gap-3.5 shadow-2xl w-[260px] h-full justify-between border border-cyan-500/10">
                <div class="flex flex-col gap-3.5">
                    <!-- Entrada de Datos Principal -->
                    <div>
                        <span id="input-title" class="text-[9.5px] font-extrabold text-yellow-400 uppercase tracking-widest font-orbitron block mb-2">Resolver Incógnita:</span>
                        
                        <!-- Fase 1: Entrada Numérica Libre -->
                        <div id="manual-input-wrapper" class="relative rounded-xl overflow-hidden border border-cyan-500/40 shadow-inner bg-black/40">
                            <input type="number" id="manual-input" step="0.01" 
                                   class="w-full bg-transparent text-center font-orbitron text-base font-black py-2 pl-3 pr-12 focus:outline-none focus:ring-1 focus:ring-cyan-400 text-yellow-300 transition-all placeholder-gray-600" 
                                   placeholder="0.0">
                            <span id="unit-label" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-cyan-400 font-bold font-orbitron text-xs">kg</span>
                        </div>

                        <!-- Fases 2 y 3: Opciones de Opción Múltiple -->
                        <div id="options-container" class="hidden flex flex-col gap-2 mt-1">
                            <!-- Inyectado dinámicamente -->
                        </div>
                    </div>
                </div>

                <div class="flex flex-col gap-3.5">
                    <!-- Panel de Mensajes de Feedback -->
                    <div id="feedback-panel" class="bg-black/30 rounded-xl p-3 shadow-inner flex flex-col justify-center border-l-4 border-cyan-500 transition-all duration-300 min-h-[80px]">
                        <p id="feedback-title" class="text-[10px] font-black text-cyan-400 uppercase tracking-widest font-orbitron mb-1">Diagnóstico de Sistema</p>
                        <p id="feedback" class="text-xs text-gray-300 leading-snug font-semibold">Cargando el laboratorio de trabajo y energía...</p>
                        <p id="correct-answer-display" class="text-[10px] text-emerald-400 font-orbitron font-semibold mt-1 leading-none"></p>
                    </div>

                    <!-- Botones de Control de Simulación -->
                    <div class="flex flex-col gap-2">
                        <!-- Botón Principal Simular -->
                        <button id="lanzarBtn" class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 active:scale-95 text-gray-950 font-black py-2.5 px-4 rounded-xl shadow-lg transition-all text-xs uppercase tracking-wider font-orbitron flex items-center justify-center gap-2">
                            <svg class="w-4 h-4 text-gray-950" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                            </svg>
                            Iniciar Simulación
                        </button>
                        <!-- Botón Resetear / Siguiente -->
                        <button id="resetBtn" class="w-full bg-gray-900/80 hover:bg-gray-800 text-gray-200 hover:text-white border border-gray-800 font-bold py-2 px-4 rounded-xl transition-all text-[10px] uppercase tracking-widest font-orbitron flex items-center justify-center gap-1.5">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                            </svg>
                            Siguiente Ejercicio
                        </button>
                    </div>
                </div>
            </div>

            <!-- Pestaña de Ocultar/Mostrar Acoplada al Panel Derecho -->
            <div class="pointer-events-auto mr-1.5 mt-6 self-start">
                <button id="toggle-right-panel-btn" class="w-10 h-10 bg-gray-950/90 hover:bg-cyan-500 text-cyan-400 hover:text-gray-950 border border-cyan-500/20 rounded-xl flex items-center justify-center transition-all shadow-xl backdrop-blur-md">
                    <svg id="toggle-right-panel-icon" class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- BOTÓN FLOTANTE PARA DESPLEGAR PANEL EN MÓVILES -->
    <button id="mobile-drawer-toggle" onclick="toggleMobileDrawer()" class="fixed bottom-4 left-1/2 transform -translate-x-1/2 z-40 hidden font-orbitron font-extrabold text-[10px] uppercase tracking-wider px-4 py-2.5 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-gray-950 rounded-xl shadow-[0_0_20px_rgba(0,243,255,0.5)] border border-cyan-300/30 transition-all duration-300 items-center gap-2 pointer-events-auto">
        <svg id="mobile-drawer-icon" class="w-4.5 h-4.5 text-gray-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        <span id="mobile-drawer-text">Ver Datos y Resolver</span>
    </button>

    <!-- CONTROLES CENTRALES SUPERIORES (Cámara y Ayuda) -->
    <div class="camera-controls absolute top-20 left-1/2 transform -translate-x-1/2 z-10 pointer-events-auto flex items-center gap-2 bg-gray-950/90 border border-cyan-500/20 rounded-xl px-2.5 py-1.5 shadow-xl backdrop-blur-md">
        <!-- Botón Ayuda -->
        <button onclick="toggleHelpModal()" class="w-9 h-9 bg-gray-900/60 hover:bg-cyan-500 hover:text-gray-950 text-cyan-400 border border-cyan-500/10 hover:border-cyan-400 rounded-lg flex items-center justify-center transition-all" title="Teoría y Fórmulas">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364.364l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
        </button>

        <!-- Separador -->
        <span class="w-[1px] h-5 bg-gray-800/80 mx-1"></span>

        <!-- Botones de Zoom -->
        <div class="flex items-center gap-1.5">
            <!-- Zoom + -->
            <button onclick="adjustZoom(-1.2)" class="w-9 h-9 bg-gray-900/60 hover:bg-cyan-500 hover:text-gray-950 text-cyan-400 border border-cyan-500/10 hover:border-cyan-400 rounded-lg flex items-center justify-center transition-all" title="Acercar Cámara">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
            </button>
            <!-- Zoom default (home) -->
            <button onclick="changeZoom(6.5)" class="w-9 h-9 bg-gray-900/60 hover:bg-cyan-500 hover:text-gray-950 text-cyan-400 border border-cyan-500/10 hover:border-cyan-400 rounded-lg flex items-center justify-center transition-all" title="Restaurar Cámara">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
            </button>
            <!-- Zoom - -->
            <button onclick="adjustZoom(1.2)" class="w-9 h-9 bg-gray-900/60 hover:bg-cyan-500 hover:text-gray-950 text-cyan-400 border border-cyan-500/10 hover:border-cyan-400 rounded-lg flex items-center justify-center transition-all" title="Alejar Cámara">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
                </svg>
            </button>
        </div>
    </div>

    <!-- MODAL DE TEORÍA Y FÓRMULAS -->
    <div id="help-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-md hidden pointer-events-auto">
        <div class="glass-panel w-full max-w-lg rounded-3xl p-6 shadow-2xl relative border border-cyan-500/30">
            <button onclick="toggleHelpModal()" class="absolute top-4 right-4 text-gray-400 hover:text-white text-2xl font-bold transition-all">&times;</button>
            <h2 class="font-orbitron text-sm font-bold text-cyan-400 mb-4 flex items-center gap-2 tracking-wide uppercase">
                <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
                Física del Trabajo y la Energía
            </h2>
            
            <div class="space-y-4 text-xs text-gray-300 overflow-y-auto max-h-[60vh] pr-2 custom-scrollbar">
                <p class="leading-relaxed">El teorema del Trabajo y la Energía relaciona el cambio de energía mecánica de un objeto con el trabajo realizado por fuerzas no conservativas (como la fricción):</p>
                
                <div class="bg-black/40 p-3 rounded-xl border border-gray-800">
                    <h3 class="font-bold text-cyan-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Ecuación Fundamental:</h3>
                    <p class="font-mono text-center text-yellow-300 my-2 text-xs">
                        $$E_{m1} + W_{fnc} = E_{m2}$$
                    </p>
                    <p class="text-[9.5px] text-gray-400 leading-snug">Donde la energía mecánica $E_m$ es la suma de las energías cinética, potencial gravitatoria y potencial elástica.</p>
                </div>

                <div class="bg-black/40 p-3 rounded-xl border border-gray-800">
                    <h3 class="font-bold text-cyan-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Componentes de Energía:</h3>
                    <ul class="list-disc pl-4 space-y-1.5 text-[11px] text-gray-300">
                        <li><b class="text-cyan-300">Energía Cinética:</b> $E_c = \frac{1}{2} m \cdot v^2$ (asociada al movimiento).</li>
                        <li><b class="text-emerald-400">E. Potencial Gravitatoria:</b> $E_{pg} = m \cdot g \cdot h$ (asociada a la altura).</li>
                        <li><b class="text-blue-400">E. Potencial Elástica:</b> $E_{pe} = \frac{1}{2} k \cdot x^2$ (asociada a la compresión $x$ de un resorte).</li>
                    </ul>
                </div>

                <div class="bg-black/40 p-3 rounded-xl border border-gray-800">
                    <h3 class="font-bold text-cyan-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Trabajo de Fricción (Fuerzas No Conservativas):</h3>
                    <p class="font-mono text-center text-yellow-300 text-xs my-2">$$W_f = - f_r \cdot d = - \mu \cdot m \cdot g \cdot d$$</p>
                    <p class="text-[9.5px] text-gray-400">El trabajo de fricción es negativo porque la fuerza se opone al desplazamiento, disipando energía en forma de calor.</p>
                </div>
                
                <div class="bg-black/40 p-3 rounded-xl border border-gray-800">
                    <h3 class="font-bold text-cyan-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Constantes:</h3>
                    <p class="leading-relaxed">Aceleración de la gravedad: <b>g = 9.8 m/s²</b>.</p>
                </div>
            </div>
            
            <div class="mt-4 pt-3 border-t border-gray-800">
                <button onclick="toggleHelpModal()" class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 text-gray-950 hover:from-cyan-400 hover:to-blue-500 py-2.5 rounded-xl font-bold font-orbitron uppercase text-[10px] tracking-wider transition-all">Entendido</button>
            </div>
        </div>
    </div>

    <!-- LOGICA DEL SIMULADOR -->
    <script>
        // --- SINTETIZADOR DE EFECTOS DE SONIDO (WEB AUDIO API) ---
        class SoundFX {
            constructor() {
                this.ctx = null;
            }
            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
                if (this.ctx && this.ctx.state === 'suspended') {
                    this.ctx.resume();
                }
            }
            playClank() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(120, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(25, this.ctx.currentTime + 0.35);
                gain.gain.setValueAtTime(0.5, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.35);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.35);
            }
            playHum(accelerate = false) {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(90, this.ctx.currentTime);
                if (accelerate) {
                    osc.frequency.linearRampToValueAtTime(240, this.ctx.currentTime + 1.2);
                } else {
                    osc.frequency.linearRampToValueAtTime(110, this.ctx.currentTime + 0.8);
                }
                gain.gain.setValueAtTime(0.15, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 1.2);
                osc.start();
                osc.stop(this.ctx.currentTime + 1.2);
            }
            playSuccess() {
                this.init();
                const chord = [261.63, 329.63, 392.00, 523.25]; // Do Mayor
                chord.forEach((freq, i) => {
                    const osc = this.ctx.createOscillator();
                    const gain = this.ctx.createGain();
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(freq, this.ctx.currentTime + i * 0.08);
                    gain.gain.setValueAtTime(0.15, this.ctx.currentTime + i * 0.08);
                    gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + i * 0.08 + 0.6);
                    osc.start(this.ctx.currentTime + i * 0.08);
                    osc.stop(this.ctx.currentTime + i * 0.08 + 0.6);
                });
            }
            playFailure() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(120, this.ctx.currentTime);
                osc.frequency.linearRampToValueAtTime(60, this.ctx.currentTime + 0.6);
                gain.gain.setValueAtTime(0.2, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.6);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.6);
            }
            playTick() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(650, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(350, this.ctx.currentTime + 0.05);
                gain.gain.setValueAtTime(0.08, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.05);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.05);
            }
        }
        const sfx = new SoundFX();

        let scene, camera, renderer;
        const GRAVITY = 9.8;

        // --- SISTEMA DE GESTIÓN DE MEMORIA THREE.JS ---
        function disposeNode(node) {
            if (!node) return;
            if (node.geometry) {
                node.geometry.dispose();
            }
            if (node.material) {
                if (Array.isArray(node.material)) {
                    node.material.forEach(mat => mat.dispose());
                } else {
                    node.material.dispose();
                }
            }
        }

        function disposeHierarchy(obj) {
            if (!obj) return;
            obj.traverse(disposeNode);
        }

        // Elementos tridimensionales de la escena
        let trackMeshLeft, trackMeshRight, trackTies = [];
        let supportPillars = [];
        let cartGroup;
        let springGroupTop, springCoilTop, springBaseBlockTop;
        let springGroupBottom, springCoilBottom, springBaseBlockBottom;
        let frictionZoneWarning;

        // Elementos DCL (Vectores de fuerzas como flechas 3D)
        let forceArrows = {};

        // Sistema de Partículas para las chispas de fricción
        let particleSystem;
        const particleCount = 80;
        const particlesData = [];

        // Parámetros de simulación física y del problema activo
        let mode = "basico"; // basico | estandar | avanzado
        let problemParameters = {};
        let missingVariableType = "";
        let correctAnswer = 0;
        let attemptsLeft = 3;
        let currentScore = 0;
        let currentOptions = [];
        let trackCurve = null; // Spline del riel para la animación

        const variableMeta = {
            m: { label: "Masa (m)", unit: "kg" },
            h1: { label: "Altura Inicial (h₁)", unit: "m" },
            vB: { label: "Vel. Base Rampa (v_B)", unit: "m/s" },
            vC: { label: "Vel. Post-Valle (v_C)", unit: "m/s" },
            h2: { label: "Altura Alcanzada (h₂)", unit: "m" },
            mu: { label: "Coef. Fricción (μ)", unit: "" },
            d: { label: "Largo del Valle (d)", unit: "m" },
            Wf: { label: "Trabajo Fricción (W_f)", unit: "J" },
            k1: { label: "Constante Resorte Sup. (k₁)", unit: "N/m" },
            x1: { label: "Compresión Máx Sup. (x₁)", unit: "m" },
            k2: { label: "Constante Resorte Inf. (k₂)", unit: "N/m" },
            x2: { label: "Compresión Máx Inf. (x₂)", unit: "m" },
            Ep: { label: "E. Potencial Grav (E_p)", unit: "J" },
            Ek: { label: "E. Cinética Base (E_k)", unit: "J" }
        };

        // Variables de estado de simulación física
        let isSimulating = false;
        let simTime = 0;
        let displacement = 0; // Distancia recorrida a lo largo de la pista
        let cartSpeed = 0; // Velocidad del carrito en tiempo real
        let simDuration = 0;
        let simTimeline = []; // Lista de tiempos e hitos para la animación
        let mouseX = 0, mouseY = 0;
        let isPanelHidden = false;
        let isRightPanelHidden = false;
        let cameraZoomZ = 6.5;
        let cameraPanX = 0; // Paneo horizontal de la cámara (deslizar pantalla)
        let smoothPanX = 0; // Paneo horizontal suavizado para el lookAt

        function changeZoom(zVal) {
            if (typeof sfx !== 'undefined' && sfx.playTick) sfx.playTick();
            cameraZoomZ = zVal;
            cameraPanX = 0; // Resetear paneo al restaurar vista
            smoothPanX = 0;
        }

        function adjustZoom(amount) {
            let targetZ = cameraZoomZ + amount;
            if (targetZ < 3.2) targetZ = 3.2;
            if (targetZ > 19.5) targetZ = 19.5; // Límite de alejamiento ampliado (3 niveles más)
            if (targetZ !== cameraZoomZ) {
                changeZoom(targetZ);
            }
        }

        function onWindowResize() {
            const container = document.getElementById("canvas-container");
            if (!container) return;
            const w = container.clientWidth;
            const h = container.clientHeight;
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
            renderer.setSize(w, h);
        }

        window.addEventListener("mousemove", (e) => {
            mouseX = (e.clientX / window.innerWidth) - 0.5;
            mouseY = (e.clientY / window.innerHeight) - 0.5;
        });

        // --- SISTEMA DE PANEO HORIZONTAL DE CÁMARA (Para celulares y arrastre táctil/mouse) ---
        let isPointerDragging = false;
        let previousPointerX = 0;

        window.addEventListener("pointerdown", (e) => {
            // Evitar arrastrar cámara al hacer clic sobre controles, inputs o menús
            if (e.target.closest("canvas") === null) {
                return;
            }
            isPointerDragging = true;
            previousPointerX = e.clientX;
        });

        window.addEventListener("pointermove", (e) => {
            if (!isPointerDragging) return;
            const deltaX = e.clientX - previousPointerX;
            previousPointerX = e.clientX;
            
            // Ajustar sensibilidad respecto al zoom (a mayor alejamiento, mayor paneo)
            const sensitivity = 0.0055 * (cameraZoomZ / 6.5);
            cameraPanX -= deltaX * sensitivity;
            
            // Límites para evitar perder la rampa de vista
            if (cameraPanX < -4.5) cameraPanX = -4.5;
            if (cameraPanX > 4.5) cameraPanX = 4.5;
        });

        window.addEventListener("pointerup", () => { isPointerDragging = false; });
        window.addEventListener("pointercancel", () => { isPointerDragging = false; });

        // --- INICIALIZACIÓN DE LA ESCENA 3D ---
        function init3D() {
            const container = document.getElementById("canvas-container");
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x020409);
            scene.fog = new THREE.FogExp2(0x020409, 0.04);

            camera = new THREE.PerspectiveCamera(32, container.clientWidth / container.clientHeight, 0.1, 100);
            camera.position.set(0, 1.2, 6.5);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            container.appendChild(renderer.domElement);

            // --- LUCES ---
            const ambient = new THREE.AmbientLight(0xffffff, 0.15);
            scene.add(ambient);

            const dirLight = new THREE.DirectionalLight(0x00f3ff, 1.8);
            dirLight.position.set(3, 8, 4);
            dirLight.castShadow = true;
            dirLight.shadow.mapSize.width = 1024;
            dirLight.shadow.mapSize.height = 1024;
            dirLight.shadow.bias = -0.0006;
            scene.add(dirLight);

            const fillLight = new THREE.DirectionalLight(0x9d4edd, 0.6);
            fillLight.position.set(-5, 3, 2);
            scene.add(fillLight);

            const pointLight = new THREE.PointLight(0x00f3ff, 2.5, 8);
            pointLight.position.set(0, 1.0, 0.2);
            scene.add(pointLight);

            // --- SUELO ---
            const floorGeo = new THREE.PlaneGeometry(18, 18);
            const floorMat = new THREE.MeshStandardMaterial({ 
                color: 0x050816, 
                roughness: 0.9, 
                metalness: 0.15 
            });
            const floor = new THREE.Mesh(floorGeo, floorMat);
            floor.rotation.x = -Math.PI / 2;
            floor.receiveShadow = true;
            scene.add(floor);

            const grid = new THREE.GridHelper(18, 36, 0x00f3ff, 0x06112a);
            grid.position.y = 0.005;
            scene.add(grid);

            // --- SISTEMA DE PARTÍCULAS ---
            buildSparkSystem();

            window.addEventListener("resize", onWindowResize);
        }

        // --- SISTEMA DE PARTÍCULAS (Chispas) ---
        function buildSparkSystem() {
            const geo = new THREE.BufferGeometry();
            const positions = new Float32Array(particleCount * 3);
            const colors = new Float32Array(particleCount * 3);

            for (let i = 0; i < particleCount; i++) {
                positions[i*3] = 0;
                positions[i*3+1] = -10;
                positions[i*3+2] = 0;

                colors[i*3] = 1.0;
                colors[i*3+1] = 0.5 + Math.random() * 0.3;
                colors[i*3+2] = 0.0;
                
                particlesData.push({
                    active: false,
                    velocity: new THREE.Vector3(),
                    life: 0,
                    maxLife: 0
                });
            }

            geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

            const mat = new THREE.PointsMaterial({
                size: 0.04,
                vertexColors: true,
                transparent: true,
                opacity: 0.95,
                blending: THREE.AdditiveBlending
            });

            particleSystem = new THREE.Points(geo, mat);
            scene.add(particleSystem);
        }

        function triggerSparks(originPos, speedFactor) {
            const posAttr = particleSystem.geometry.attributes.position;
            
            for (let i = 0; i < 3; i++) {
                const idx = particlesData.findIndex(p => !p.active);
                if (idx !== -1) {
                    const p = particlesData[idx];
                    p.active = true;
                    p.life = 0;
                    p.maxLife = 15 + Math.random() * 15;
                    
                    posAttr.setXYZ(idx, originPos.x, originPos.y + 0.02, originPos.z + (Math.random() - 0.5) * 0.15);
                    
                    p.velocity.set(
                        (Math.random() - 0.7) * speedFactor * 0.5,
                        0.3 + Math.random() * 0.6,
                        (Math.random() - 0.5) * 0.3
                    );
                }
            }
            posAttr.needsUpdate = true;
        }

        function updateParticles() {
            if (!particleSystem) return;
            const posAttr = particleSystem.geometry.attributes.position;
            let updated = false;

            for (let i = 0; i < particleCount; i++) {
                const p = particlesData[i];
                if (p.active) {
                    const px = posAttr.getX(i);
                    const py = posAttr.getY(i);
                    const pz = posAttr.getZ(i);

                    p.velocity.y -= 0.08; // Gravedad de chispa
                    posAttr.setXYZ(
                        i,
                        px + p.velocity.x * 0.016,
                        py + p.velocity.y * 0.016,
                        pz + p.velocity.z * 0.016
                    );

                    p.life++;
                    if (p.life >= p.maxLife) {
                        p.active = false;
                        posAttr.setXYZ(i, 0, -10, 0);
                    }
                    updated = true;
                }
            }
            if (updated) posAttr.needsUpdate = true;
        }

        // --- SISTEMA DCL VECTORIAL 3D ---
        function createForceArrow(colorHex) {
            const group = new THREE.Group();
            
            const shaftGeo = new THREE.CylinderGeometry(0.007, 0.007, 0.28, 8);
            shaftGeo.translate(0, 0.14, 0); // Pivote en la base
            const shaftMat = new THREE.MeshBasicMaterial({ color: colorHex, transparent: true, opacity: 0.85 });
            const shaft = new THREE.Mesh(shaftGeo, shaftMat);
            group.add(shaft);

            const headGeo = new THREE.ConeGeometry(0.022, 0.07, 8);
            headGeo.translate(0, 0.28, 0);
            const head = new THREE.Mesh(headGeo, shaftMat);
            group.add(head);

            return group;
        }

        function buildFBDVectors() {
            Object.values(forceArrows).forEach(a => {
                scene.remove(a);
                disposeHierarchy(a);
            });
            forceArrows = {};

            const display = document.getElementById("toggle-fbd").checked;
            if (!display) return;

            const colWeight = 0xef4444;   // Peso (Rojo)
            const colNormal = 0x10b981;   // Normal (Verde)
            const colFriction = 0xf59e0b; // Fricción (Ámbar)
            const colSpring = 0x00f3ff;   // Fuerza Elástica (Celeste)

            forceArrows.weight = createForceArrow(colWeight);
            forceArrows.normal = createForceArrow(colNormal);
            
            if (problemParameters.mu > 0) {
                forceArrows.friction = createForceArrow(colFriction);
            }
            if (mode === "avanzado") {
                if (problemParameters.hasTopSpring) {
                    forceArrows.springTop = createForceArrow(colSpring);
                }
                if (problemParameters.hasBottomSpring) {
                    forceArrows.springBottom = createForceArrow(colSpring);
                }
            }

            Object.values(forceArrows).forEach(a => scene.add(a));
        }

        function setArrowDirection(arrow, dir) {
            arrow.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), dir.clone().normalize());
        }

        function updateFBDPositions() {
            const display = document.getElementById("toggle-fbd").checked;
            if (!display || !cartGroup) {
                Object.values(forceArrows).forEach(a => a.visible = false);
                return;
            }

            const p = problemParameters;
            const tVal = Math.min(displacement / trackCurve.getLength(), 1.0);
            const pos = trackCurve.getPointAt(tVal);
            const tangent = trackCurve.getTangentAt(tVal);
            const normalVec = new THREE.Vector3(-tangent.y, tangent.x, 0).normalize();
            if (normalVec.y < 0) normalVec.multiplyScalar(-1); // Siempre hacia arriba

            const arrowOffsetZ = 0.22;

            if (forceArrows.weight) {
                forceArrows.weight.visible = true;
                forceArrows.weight.position.copy(pos).setZ(arrowOffsetZ);
                setArrowDirection(forceArrows.weight, new THREE.Vector3(0, -1, 0));
            }

            if (forceArrows.normal) {
                forceArrows.normal.visible = true;
                forceArrows.normal.position.copy(pos).setZ(arrowOffsetZ);
                setArrowDirection(forceArrows.normal, normalVec);
            }

            // Fricción (Solo activa si estamos en la zona de fricción en el valle y hay movimiento)
            if (forceArrows.friction) {
                const inValley = (pos.x >= -1.0 && pos.x <= -1.0 + p.d);
                if (inValley && isSimulating && cartSpeed > 0.05) {
                    forceArrows.friction.visible = true;
                    forceArrows.friction.position.copy(pos).setZ(arrowOffsetZ);
                    setArrowDirection(forceArrows.friction, tangent.clone().multiplyScalar(-1));
                } else {
                    forceArrows.friction.visible = false;
                }
            }

            // Fuerza Elástica Superior
            if (forceArrows.springTop && mode === "avanzado" && p.hasTopSpring) {
                const dx1 = 2.5;
                const dy1 = p.h1;
                const S1 = Math.sqrt(dx1*dx1 + dy1*dy1);
                const tangentLeftRamp = new THREE.Vector3(dx1 / S1, -dy1 / S1, 0);
                
                // Active only if cart is in contact with top spring during launch segment
                const segment = simTimeline && simTimeline[0];
                if (displacement < 0.8 && isSimulating && segment && simTime < segment.tEnd) {
                    forceArrows.springTop.visible = true;
                    forceArrows.springTop.position.copy(pos).setZ(arrowOffsetZ);
                    const comp = 0.8 - displacement;
                    forceArrows.springTop.scale.set(1, Math.max(0.2, comp / 0.5), 1);
                    setArrowDirection(forceArrows.springTop, tangentLeftRamp);
                } else {
                    forceArrows.springTop.visible = false;
                }
            } else if (forceArrows.springTop) {
                forceArrows.springTop.visible = false;
            }

            // Fuerza Elástica Inferior
            if (forceArrows.springBottom && mode === "avanzado" && p.hasBottomSpring) {
                const springStart = -1.0 + p.d;
                if (pos.x >= springStart) {
                    forceArrows.springBottom.visible = true;
                    forceArrows.springBottom.position.copy(pos).setZ(arrowOffsetZ);
                    forceArrows.springBottom.scale.set(1, Math.max(0.2, (pos.x - springStart) / 0.5), 1);
                    setArrowDirection(forceArrows.springBottom, new THREE.Vector3(-1, 0, 0));
                } else {
                    forceArrows.springBottom.visible = false;
                }
            } else if (forceArrows.springBottom) {
                forceArrows.springBottom.visible = false;
            }
        }

        // --- MODELADO DE CARRITO FUTURISTA ---
        function buildCartMesh() {
            if (cartGroup) {
                scene.remove(cartGroup);
                disposeHierarchy(cartGroup);
                cartGroup = null;
            }

            cartGroup = new THREE.Group();
            scene.add(cartGroup);

            const chassisMat = new THREE.MeshStandardMaterial({ 
                color: 0x0a142c, 
                roughness: 0.25, 
                metalness: 0.85 
            });
            const neonMat = new THREE.MeshStandardMaterial({ 
                color: 0xff0055, 
                emissive: 0xff0033,
                roughness: 0.1, 
                metalness: 0.9 
            });
            const wheelMat = new THREE.MeshStandardMaterial({ 
                color: 0x1f2937, 
                roughness: 0.5, 
                metalness: 0.7 
            });

            // Chasis principal
            const chassis = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.1, 0.22), chassisMat);
            chassis.position.y = 0.08;
            chassis.castShadow = true;
            cartGroup.add(chassis);

            // Carrocería deportiva
            const bodyCap = new THREE.Mesh(new THREE.BoxGeometry(0.18, 0.06, 0.18), chassisMat);
            bodyCap.position.set(-0.02, 0.14, 0);
            bodyCap.castShadow = true;
            cartGroup.add(bodyCap);

            // Adorno Neon Led lateral
            const ledL = new THREE.Mesh(new THREE.BoxGeometry(0.22, 0.015, 0.01), neonMat);
            ledL.position.set(0, 0.08, 0.112);
            cartGroup.add(ledL);

            const ledR = ledL.clone();
            ledR.position.z = -0.112;
            cartGroup.add(ledR);

            // Ruedas (4 cilindros)
            const wheelGeo = new THREE.CylinderGeometry(0.045, 0.045, 0.025, 12);
            wheelGeo.rotateX(Math.PI / 2);

            const wheels = [];
            const offsets = [
                { x: -0.09, z: 0.125 },
                { x: 0.09, z: 0.125 },
                { x: -0.09, z: -0.125 },
                { x: 0.09, z: -0.125 }
            ];

            offsets.forEach(offset => {
                const w = new THREE.Mesh(wheelGeo, wheelMat);
                w.position.set(offset.x, 0.045, offset.z);
                w.castShadow = true;
                cartGroup.add(w);
                wheels.push(w);
            });

            cartGroup.wheels = wheels;
        }

        // --- MODELADO DE RESORTE HELICOIDAL 3D ---
        function buildSpringAssembly() {
            if (springGroupTop) {
                scene.remove(springGroupTop);
                disposeHierarchy(springGroupTop);
                springGroupTop = null;
            }
            if (springGroupBottom) {
                scene.remove(springGroupBottom);
                disposeHierarchy(springGroupBottom);
                springGroupBottom = null;
            }
            if (mode !== "avanzado") return;

            const p = problemParameters;
            const blockMat = new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.4, metalness: 0.7 });
            const springMat = new THREE.MeshStandardMaterial({ 
                color: 0x00f3ff, 
                emissive: 0x003344,
                roughness: 0.1, 
                metalness: 0.95 
            });

            // 1. RESORTE SUPERIOR (Si está activo)
            if (p.hasTopSpring) {
                springGroupTop = new THREE.Group();
                springGroupTop.position.set(-3.5, p.h1, 0);
                
                const dx1 = 2.5;
                const dy1 = p.h1;
                const S1 = Math.sqrt(dx1*dx1 + dy1*dy1);
                const angleLeftRamp = Math.atan2(-dy1, dx1);
                springGroupTop.rotation.z = angleLeftRamp;
                
                scene.add(springGroupTop);

                // Bloque de anclaje (en x local = -0.125, centrado en el riel)
                springBaseBlockTop = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.28, 0.35), blockMat);
                springBaseBlockTop.position.set(-0.125, 0.08, 0);
                springBaseBlockTop.receiveShadow = true;
                springBaseBlockTop.castShadow = true;
                springGroupTop.add(springBaseBlockTop);

                // Bobina helicoidal
                const coils = 9;
                const rHelix = 0.065;
                const segments = 120;
                const points = [];
                for (let i = 0; i <= segments; i++) {
                    const t = i / segments;
                    const angle = t * coils * Math.PI * 2;
                    const x = t * 0.8;
                    const y = Math.sin(angle) * rHelix;
                    const z = Math.cos(angle) * rHelix;
                    points.push(new THREE.Vector3(x, y + 0.08, z)); // Centrado con el carro
                }
                const helixCurve = new THREE.CatmullRomCurve3(points);
                const springGeo = new THREE.TubeGeometry(helixCurve, 64, 0.01, 8, false);
                
                springCoilTop = new THREE.Mesh(springGeo, springMat);
                springCoilTop.castShadow = true;
                springGroupTop.add(springCoilTop);
            }

            // 2. RESORTE INFERIOR (Si está activo)
            if (p.hasBottomSpring) {
                springGroupBottom = new THREE.Group();
                const springStartX = -1.0 + p.d;
                springGroupBottom.position.set(springStartX, 0, 0);
                
                scene.add(springGroupBottom);

                // Bloque de anclaje (en x local = 0.8 + 0.125, descansa en el suelo)
                springBaseBlockBottom = new THREE.Mesh(new THREE.BoxGeometry(0.25, 0.28, 0.35), blockMat);
                springBaseBlockBottom.position.set(0.8 + 0.125, 0.14, 0);
                springBaseBlockBottom.receiveShadow = true;
                springBaseBlockBottom.castShadow = true;
                springGroupBottom.add(springBaseBlockBottom);

                // Bobina helicoidal
                const coils = 9;
                const rHelix = 0.065;
                const segments = 120;
                const points = [];
                for (let i = 0; i <= segments; i++) {
                    const t = i / segments;
                    const angle = t * coils * Math.PI * 2;
                    const x = t * 0.8;
                    const y = Math.sin(angle) * rHelix;
                    const z = Math.cos(angle) * rHelix;
                    points.push(new THREE.Vector3(x, y + 0.08, z));
                }
                const helixCurve = new THREE.CatmullRomCurve3(points);
                const springGeo = new THREE.TubeGeometry(helixCurve, 64, 0.01, 8, false);
                
                springCoilBottom = new THREE.Mesh(springGeo, springMat);
                springCoilBottom.castShadow = true;
                springGroupBottom.add(springCoilBottom);
            }
        }

        // --- CONSTRUCCIÓN DE LA PISTA (SPLINE DE VÍAS) ---
        function buildTrackSpline() {
            // Eliminar pistas previas y liberar memoria
            if (trackMeshLeft) {
                scene.remove(trackMeshLeft);
                disposeHierarchy(trackMeshLeft);
                trackMeshLeft = null;
            }
            if (trackMeshRight) {
                scene.remove(trackMeshRight);
                disposeHierarchy(trackMeshRight);
                trackMeshRight = null;
            }
            trackTies.forEach(t => {
                scene.remove(t);
                disposeHierarchy(t);
            });
            trackTies = [];
            supportPillars.forEach(p => {
                scene.remove(p);
                disposeHierarchy(p);
            });
            supportPillars = [];
            if (frictionZoneWarning) {
                scene.remove(frictionZoneWarning);
                disposeHierarchy(frictionZoneWarning);
                frictionZoneWarning = null;
            }

            const p = problemParameters;

            // Definición de puntos clave de la trayectoria
            const points = [];
            points.push(new THREE.Vector3(-3.5, p.h1, 0));
            points.push(new THREE.Vector3(-1.0, 0, 0));
            points.push(new THREE.Vector3(-1.0 + p.d, 0, 0));

            if (mode === "avanzado" && p.hasBottomSpring) {
                // En modo resorte, el riel va horizontal hasta el anclaje del resorte
                points.push(new THREE.Vector3(-1.0 + p.d + 0.8, 0, 0));
            } else {
                // En básico/estándar, sube la rampa derecha hasta una altura estándar holgada
                points.push(new THREE.Vector3(-1.0 + p.d + 2.0, 3.0, 0));
            }

            // Crear curva de CatmullRom con esquinas suavizadas
            trackCurve = new THREE.CatmullRomCurve3(points, false, 'centripetal');

            // Riel izquierdo y derecho paralelos en Z
            const railOffsetZ = 0.125;
            const pointsLeft = [];
            const pointsRight = [];
            const steps = 100;
            
            for (let i = 0; i <= steps; i++) {
                const t = i / steps;
                const pos = trackCurve.getPointAt(t);
                pointsLeft.push(new THREE.Vector3(pos.x, pos.y, -railOffsetZ));
                pointsRight.push(new THREE.Vector3(pos.x, pos.y, railOffsetZ));
            }

            const curveLeft = new THREE.CatmullRomCurve3(pointsLeft);
            const curveRight = new THREE.CatmullRomCurve3(pointsRight);

            const railGeoLeft = new THREE.TubeGeometry(curveLeft, 80, 0.015, 8, false);
            const railGeoRight = new THREE.TubeGeometry(curveRight, 80, 0.015, 8, false);

            const railMat = new THREE.MeshStandardMaterial({ 
                color: 0x00f3ff, 
                emissive: 0x001f3f,
                roughness: 0.1, 
                metalness: 0.9 
            });

            trackMeshLeft = new THREE.Mesh(railGeoLeft, railMat);
            trackMeshRight = new THREE.Mesh(railGeoRight, railMat);
            trackMeshLeft.castShadow = true;
            trackMeshRight.castShadow = true;
            scene.add(trackMeshLeft);
            scene.add(trackMeshRight);

            // Durmientes (vínculos entre rieles)
            const tieGeo = new THREE.CylinderGeometry(0.008, 0.008, railOffsetZ * 2, 8);
            tieGeo.rotateX(Math.PI / 2);
            const tieMat = new THREE.MeshStandardMaterial({ color: 0x1f2937, roughness: 0.4, metalness: 0.7 });

            const tieCount = 35;
            for (let i = 0; i < tieCount; i++) {
                const t = i / (tieCount - 1);
                const pos = trackCurve.getPointAt(t);
                const tangent = trackCurve.getTangentAt(t);
                
                const tie = new THREE.Mesh(tieGeo, tieMat);
                tie.position.copy(pos);
                tie.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), new THREE.Vector3(-tangent.y, tangent.x, 0).normalize());
                tie.castShadow = true;
                scene.add(tie);
                trackTies.push(tie);
            }

            // Columnas de soporte vertical
            const columnGeo = new THREE.CylinderGeometry(0.015, 0.02, 1.0, 8);
            columnGeo.translate(0, -0.5, 0); // Pivote superior
            const columnMat = new THREE.MeshStandardMaterial({ color: 0x0e172a, roughness: 0.5, metalness: 0.8 });

            const supportPositionsX = [-3.0, -2.0, -1.0, -1.0 + p.d / 2, -1.0 + p.d];
            if (!(mode === "avanzado" && p.hasBottomSpring)) supportPositionsX.push(-1.0 + p.d + 1.0);

            supportPositionsX.forEach(x => {
                const t = getCurveTForX(x);
                if (t >= 0 && t <= 1) {
                    const pos = trackCurve.getPointAt(t);
                    if (pos.y > 0.08) {
                        const col = new THREE.Mesh(columnGeo, columnMat);
                        col.position.set(pos.x, pos.y, 0);
                        col.scale.set(1, pos.y, 1);
                        col.castShadow = true;
                        scene.add(col);
                        supportPillars.push(col);
                    }
                }
            });

            // Señalización visual de la Zona de Fricción en el Valle (Plataforma 3D industrial luminosa)
            if (p.mu > 0) {
                const warningWidth = p.d;
                const warningGeo = new THREE.BoxGeometry(warningWidth, 0.04, 0.28);
                const warningMat = new THREE.MeshStandardMaterial({ 
                    color: 0xff4500, // Naranja-rojo fluorescente
                    emissive: 0x992200, 
                    roughness: 0.1, 
                    metalness: 0.9,
                    transparent: true, 
                    opacity: 0.6 
                });
                frictionZoneWarning = new THREE.Mesh(warningGeo, warningMat);
                frictionZoneWarning.position.set(-1.0 + p.d / 2, -0.02, 0);
                frictionZoneWarning.receiveShadow = true;

                const edges = new THREE.EdgesGeometry(warningGeo);
                const lineMat = new THREE.LineBasicMaterial({ color: 0xff5500, linewidth: 2 });
                const line = new THREE.LineSegments(edges, lineMat);
                frictionZoneWarning.add(line);

                scene.add(frictionZoneWarning);
            }

            // Colocar el resorte si es necesario
            buildSpringAssembly();

            resetSimulationPositions();
            buildFBDVectors();
        }

        // Utilidad para buscar el parámetro T de la curva para una coordenada X dada
        function getCurveTForX(targetX) {
            let low = 0, high = 1.0;
            for (let i = 0; i < 20; i++) {
                const mid = (low + high) / 2;
                const p = trackCurve.getPointAt(mid);
                if (p.x < targetX) low = mid;
                else high = mid;
            }
            return (low + high) / 2;
        }

        // Utilidad para buscar el parámetro T de la curva para una altura Y en la rampa derecha
        function getCurveTForYRight(targetY) {
            const p = problemParameters;
            const tStart = getCurveTForX(-1.0 + p.d);
            let low = tStart, high = 1.0;
            for (let i = 0; i < 20; i++) {
                const mid = (low + high) / 2;
                const pt = trackCurve.getPointAt(mid);
                if (pt.y < targetY) low = mid;
                else high = mid;
            }
            return (low + high) / 2;
        }

        // --- ENROLLAMIENTO Y ACOPLADO PERFECTO DEL CABLE / RESORTE ---
        function updateSpringVisualDeformation(springType, compression) {
            if (mode !== "avanzado") return;
            const restLength = 0.8;
            const currentLength = restLength - compression;
            const scaleX = Math.max(0.01, currentLength / restLength);
            
            if (springType === "top" && springCoilTop) {
                springCoilTop.scale.x = scaleX;
            }
            if (springType === "bottom" && springCoilBottom) {
                springCoilBottom.scale.x = scaleX;
                springCoilBottom.position.x = compression;
            }
        }

        // --- PROYECCIÓN DE ETIQUETAS M1 Y M2 A COORDENADAS DE PANTALLA ---
        function updateScreenBadges() {
            if (!cartGroup || !trackCurve) return;
            
            const pCart = getScreenCoords(cartGroup);
            const badgeC = document.getElementById("badge-cart");
            
            if (badgeC) {
                if (pCart) {
                    badgeC.style.left = `${pCart.x}px`;
                    badgeC.style.top = `${pCart.y - 42}px`;
                    badgeC.style.display = 'block';
                } else {
                    badgeC.style.display = 'none';
                }
            }

            const badgeST = document.getElementById("badge-spring-top");
            if (badgeST) {
                if (mode === "avanzado" && problemParameters.hasTopSpring && springBaseBlockTop) {
                    const pSpringT = getScreenCoords(springBaseBlockTop);
                    if (pSpringT) {
                        badgeST.style.left = `${pSpringT.x}px`;
                        badgeST.style.top = `${pSpringT.y - 50}px`;
                        badgeST.style.display = 'block';
                    } else {
                        badgeST.style.display = 'none';
                    }
                } else {
                    badgeST.style.display = 'none';
                }
            }

            const badgeSB = document.getElementById("badge-spring-bottom");
            if (badgeSB) {
                if (mode === "avanzado" && problemParameters.hasBottomSpring && springBaseBlockBottom) {
                    const pSpringB = getScreenCoords(springBaseBlockBottom);
                    if (pSpringB) {
                        badgeSB.style.left = `${pSpringB.x}px`;
                        badgeSB.style.top = `${pSpringB.y - 50}px`;
                        badgeSB.style.display = 'block';
                    } else {
                        badgeSB.style.display = 'none';
                    }
                } else {
                    badgeSB.style.display = 'none';
                }
            }

            const p = problemParameters;
            if (!p) return;

            // 1. Badge h1 (Altura Inicial, cima de rampa izquierda)
            const badgeH1 = document.getElementById("badge-h1");
            if (badgeH1) {
                const ptH1 = new THREE.Vector3(-3.5, p.h1, 0);
                const scrH1 = getScreenCoordsFromPos(ptH1);
                if (scrH1) {
                    badgeH1.style.left = `${scrH1.x}px`;
                    badgeH1.style.top = `${scrH1.y - 25}px`;
                    badgeH1.style.display = 'block';
                    const valStr = (missingVariableType === "h1") ? "?" : `${p.h1.toFixed(1)}`;
                    badgeH1.innerHTML = `h₁ = ${valStr} m`;
                } else {
                    badgeH1.style.display = 'none';
                }
            }

            // 2. Badge vB (Velocidad en base de rampa)
            const badgeVB = document.getElementById("badge-vb");
            if (badgeVB) {
                const ptVB = new THREE.Vector3(-1.0, 0.05, 0);
                const scrVB = getScreenCoordsFromPos(ptVB);
                if (scrVB) {
                    badgeVB.style.left = `${scrVB.x}px`;
                    badgeVB.style.top = `${scrVB.y + 25}px`;
                    badgeVB.style.display = 'block';
                    const valStr = (missingVariableType === "vB") ? "?" : `${p.vB.toFixed(1)}`;
                    badgeVB.innerHTML = `v_B = ${valStr} m/s`;
                } else {
                    badgeVB.style.display = 'none';
                }
            }

            // 3. Badge vC (Velocidad post-valle)
            const badgeVC = document.getElementById("badge-vc");
            if (badgeVC) {
                if (mode !== "basico") {
                    const ptVC = new THREE.Vector3(-1.0 + p.d, 0.05, 0);
                    const scrVC = getScreenCoordsFromPos(ptVC);
                    if (scrVC) {
                        badgeVC.style.left = `${scrVC.x}px`;
                        badgeVC.style.top = `${scrVC.y + 25}px`;
                        badgeVC.style.display = 'block';
                        const valStr = (missingVariableType === "vC") ? "?" : `${p.vC.toFixed(1)}`;
                        badgeVC.innerHTML = `v_C = ${valStr} m/s`;
                    } else {
                        badgeVC.style.display = 'none';
                    }
                } else {
                    badgeVC.style.display = 'none';
                }
            }

            // 4. Badge h2 (Altura alcanzada en rampa derecha)
            const badgeH2 = document.getElementById("badge-h2");
            if (badgeH2) {
                if (mode !== "avanzado" || (mode === "avanzado" && !p.hasBottomSpring)) {
                    const tH2 = getCurveTForYRight(p.h2);
                    const ptH2 = trackCurve.getPointAt(tH2);
                    const scrH2 = getScreenCoordsFromPos(ptH2);
                    if (scrH2) {
                        badgeH2.style.left = `${scrH2.x}px`;
                        badgeH2.style.top = `${scrH2.y - 25}px`;
                        badgeH2.style.display = 'block';
                        const valStr = (missingVariableType === "h2") ? "?" : `${p.h2.toFixed(1)}`;
                        badgeH2.innerHTML = `h₂ = ${valStr} m`;
                    } else {
                        badgeH2.style.display = 'none';
                    }
                } else {
                    badgeH2.style.display = 'none';
                }
            }

            // 5. Badge x1 (Compresión de resorte superior)
            const badgeX1 = document.getElementById("badge-x1");
            if (badgeX1) {
                if (mode === "avanzado" && p.hasTopSpring) {
                    const dx1 = 2.5;
                    const dy1 = p.h1;
                    const S1 = Math.sqrt(dx1*dx1 + dy1*dy1);
                    const ptX1 = new THREE.Vector3(-3.5 + 0.4 * (dx1/S1), p.h1 - 0.4 * (dy1/S1), 0);
                    const scrX1 = getScreenCoordsFromPos(ptX1);
                    if (scrX1) {
                        badgeX1.style.left = `${scrX1.x}px`;
                        badgeX1.style.top = `${scrX1.y - 25}px`;
                        badgeX1.style.display = 'block';
                        const valStr = (missingVariableType === "x1") ? "?" : `${p.x1.toFixed(2)}`;
                        badgeX1.innerHTML = `x₁ = ${valStr} m`;
                    } else {
                        badgeX1.style.display = 'none';
                    }
                } else {
                    badgeX1.style.display = 'none';
                }
            }

            // 6. Badge x2 (Compresión de resorte inferior)
            const badgeX2 = document.getElementById("badge-x2");
            if (badgeX2) {
                if (mode === "avanzado" && p.hasBottomSpring) {
                    const ptX2 = new THREE.Vector3(-1.0 + p.d + 0.4, 0.18, 0);
                    const scrX2 = getScreenCoordsFromPos(ptX2);
                    if (scrX2) {
                        badgeX2.style.left = `${scrX2.x}px`;
                        badgeX2.style.top = `${scrX2.y - 25}px`;
                        badgeX2.style.display = 'block';
                        const valStr = (missingVariableType === "x2") ? "?" : `${p.x2.toFixed(2)}`;
                        badgeX2.innerHTML = `x₂ = ${valStr} m`;
                    } else {
                        badgeX2.style.display = 'none';
                    }
                } else {
                    badgeX2.style.display = 'none';
                }
            }
        }

        function getScreenCoordsFromPos(pos) {
            const vector = pos.clone();
            vector.project(camera);
            const container = document.getElementById("canvas-container");
            const width = container.clientWidth;
            const height = container.clientHeight;
            const x = (vector.x * 0.5 + 0.5) * width;
            const y = (vector.y * -0.5 + 0.5) * height;
            if (vector.z > 1) return null;
            return { x, y };
        }

        function getScreenCoords(mesh) {
            const vector = new THREE.Vector3();
            mesh.updateMatrixWorld();
            vector.setFromMatrixPosition(mesh.matrixWorld);
            vector.project(camera);
            
            const container = document.getElementById("canvas-container");
            const width = container.clientWidth;
            const height = container.clientHeight;
            
            const x = (vector.x * 0.5 + 0.5) * width;
            const y = (vector.y * -0.5 + 0.5) * height;
            
            if (vector.z > 1) return null;
            return { x, y };
        }

        // --- GENERADOR DE PROBLEMAS BALANCEADO Y COHERENTE ---
        function generateValidProblem() {
            let valid = false, tries = 0;
            let p = {};

            while (!valid && tries < 600) {
                tries++;
                
                p.m = parseFloat((Math.random() * 4 + 2).toFixed(1)); // 2.0 a 6.0 kg
                p.h1 = parseFloat((Math.random() * 1.4 + 1.6).toFixed(1)); // 1.6 a 3.0 m
                p.d = parseFloat((Math.random() * 1.2 + 1.2).toFixed(1)); // 1.2 a 2.4 m
                
                if (mode === "basico") {
                    p.mu = 0;
                } else {
                    // 75% fricción moderada, 25% sin fricción
                    p.mu = Math.random() > 0.25 ? parseFloat((Math.random() * 0.18 + 0.08).toFixed(2)) : 0;
                }

                if (mode === "avanzado") {
                    // Elegir aleatoriamente: top, bottom o both
                    const rand = Math.random();
                    if (rand < 0.33) {
                        p.config = "top";
                        p.hasTopSpring = true;
                        p.hasBottomSpring = false;
                    } else if (rand < 0.66) {
                        p.config = "bottom";
                        p.hasTopSpring = false;
                        p.hasBottomSpring = true;
                    } else {
                        p.config = "both";
                        p.hasTopSpring = true;
                        p.hasBottomSpring = true;
                    }
                    
                    if (p.hasTopSpring) {
                        p.k1 = Math.round(Math.random() * 4 + 2) * 50; // 100, 150, 200, 250, 300 N/m
                        p.x1 = parseFloat((Math.random() * 0.35 + 0.2).toFixed(2)); // 0.20 a 0.55 m
                    } else {
                        p.k1 = 0;
                        p.x1 = 0;
                    }
                    
                    if (p.hasBottomSpring) {
                        p.k2 = Math.round(Math.random() * 4 + 2) * 50; // 100, 150, 200, 250, 300 N/m
                    } else {
                        p.k2 = 0;
                        p.x2 = 0;
                    }
                } else {
                    p.config = "none";
                    p.hasTopSpring = false;
                    p.hasBottomSpring = false;
                    p.k1 = 0;
                    p.x1 = 0;
                    p.k2 = 0;
                    p.x2 = 0;
                }

                // --- CÁLCULO FÍSICO EXACTO ---
                const dx1 = 2.5;
                const dy1 = p.h1;
                const S1 = Math.sqrt(dx1*dx1 + dy1*dy1);
                const sinTheta1 = dy1 / S1;
                const L_top = 0.8;

                let E_initial = 0;
                if (p.hasTopSpring) {
                    // GPE + EPE inicial con el resorte comprimido x1
                    E_initial = p.m * GRAVITY * (p.h1 - (L_top - p.x1) * sinTheta1) + 0.5 * p.k1 * p.x1 * p.x1;
                } else {
                    E_initial = p.m * GRAVITY * p.h1;
                }

                const W_fric = p.mu * p.m * GRAVITY * p.d; // Magnitud del trabajo disipado

                if (E_initial > W_fric + 0.8) { // Asegura remanente energético
                    const E_after_valley = E_initial - W_fric;
                    p.vB = parseFloat(Math.sqrt((2 * E_initial) / p.m).toFixed(1));
                    p.vC = parseFloat(Math.sqrt((2 * E_after_valley) / p.m).toFixed(1));
                    p.Wf = parseFloat((-W_fric).toFixed(1));
                    p.Ep = parseFloat((p.m * GRAVITY * p.h1).toFixed(1));
                    p.Ek = parseFloat(E_initial.toFixed(1));

                    if (mode === "basico") {
                        p.h2 = p.h1;
                        valid = true;
                    } else if (mode === "estandar") {
                        p.h2 = parseFloat((E_after_valley / (p.m * GRAVITY)).toFixed(1));
                        if (p.h2 > 0.1 && p.h2 < p.h1) {
                            valid = true;
                        }
                    } else if (mode === "avanzado") {
                        if (p.hasBottomSpring) {
                            const x2_val = Math.sqrt((2 * E_after_valley) / p.k2);
                            p.x2 = parseFloat(x2_val.toFixed(2));
                            if (p.x2 > 0.1 && p.x2 < 0.75) {
                                valid = true;
                            }
                        } else {
                            p.h2 = parseFloat((E_after_valley / (p.m * GRAVITY)).toFixed(1));
                            if (p.h2 > 0.1 && p.h2 < 5.0) {
                                valid = true;
                            }
                        }
                    }
                }
            }

            if (!valid) {
                // Fallback robusto y coherente en caso de fallo
                p.m = 4.0;
                p.h1 = 2.0;
                p.d = 1.5;
                p.mu = 0.1;
                if (mode === "avanzado") {
                    p.config = "both";
                    p.hasTopSpring = true;
                    p.hasBottomSpring = true;
                    p.k1 = 200;
                    p.x1 = 0.40;
                    p.k2 = 150;
                } else {
                    p.config = "none";
                    p.hasTopSpring = false;
                    p.hasBottomSpring = false;
                    p.k1 = 0;
                    p.x1 = 0;
                    p.k2 = 0;
                    p.x2 = 0;
                }

                const dx1 = 2.5;
                const dy1 = p.h1;
                const S1 = Math.sqrt(dx1*dx1 + dy1*dy1);
                const sinTheta1 = dy1 / S1;
                const L_top = 0.8;

                let E_initial = 0;
                if (p.hasTopSpring) {
                    E_initial = p.m * GRAVITY * (p.h1 - (L_top - p.x1) * sinTheta1) + 0.5 * p.k1 * p.x1 * p.x1;
                } else {
                    E_initial = p.m * GRAVITY * p.h1;
                }

                const W_fric = p.mu * p.m * GRAVITY * p.d;
                const E_after_valley = E_initial - W_fric;
                p.vB = parseFloat(Math.sqrt((2 * E_initial) / p.m).toFixed(1));
                p.vC = parseFloat(Math.sqrt((2 * E_after_valley) / p.m).toFixed(1));
                p.Wf = parseFloat((-W_fric).toFixed(1));
                p.Ep = parseFloat((p.m * GRAVITY * p.h1).toFixed(1));
                p.Ek = parseFloat(E_initial.toFixed(1));
                
                if (p.hasBottomSpring) {
                    p.x2 = parseFloat(Math.sqrt(2 * E_after_valley / p.k2).toFixed(2));
                } else {
                    p.h2 = parseFloat((E_after_valley / (p.m * GRAVITY)).toFixed(1));
                }
            }

            problemParameters = p;

            // Determinar variable incógnita según el modo
            let eligibleVariables = [];
            if (mode === "basico") {
                eligibleVariables = ["h1", "vB", "m", "Ep", "Ek", "h2"];
            } else if (mode === "estandar") {
                eligibleVariables = ["h1", "h2", "d", "vC", "Wf"];
                if (problemParameters.mu > 0) {
                    eligibleVariables.push("mu");
                    eligibleVariables.push("m");
                }
            } else if (mode === "avanzado") {
                if (p.hasTopSpring && p.hasBottomSpring) {
                    eligibleVariables = ["x1", "k1", "x2", "k2", "m", "h1"];
                } else if (p.hasTopSpring) {
                    eligibleVariables = ["x1", "k1", "h2", "m", "h1"];
                } else {
                    eligibleVariables = ["x2", "k2", "m", "h1"];
                }
                if (problemParameters.mu > 0) eligibleVariables.push("mu");
            }

            missingVariableType = eligibleVariables[Math.floor(Math.random() * eligibleVariables.length)];
            
            // Redondeo de la respuesta correcta según tipo
            if (missingVariableType === "x1" || missingVariableType === "x2" || missingVariableType === "mu") {
                correctAnswer = parseFloat(problemParameters[missingVariableType].toFixed(2));
            } else {
                correctAnswer = parseFloat(problemParameters[missingVariableType].toFixed(1));
            }
        }

        // --- ACTUALIZACIÓN DE INTERFAZ Y FASES DE GAMIFICACIÓN ---
        function updateUIState() {
            const varsDiv = document.getElementById("variables-dadas");
            varsDiv.innerHTML = "";

            // Variables a listar (excluyendo la incógnita)
            let keysToShow = [];
            if (mode === "basico") {
                keysToShow = ["m", "h1", "vB", "Ep", "Ek", "h2"];
            } else if (mode === "estandar") {
                keysToShow = ["m", "h1", "d", "mu", "vC", "h2", "Wf"];
            } else if (mode === "avanzado") {
                const p = problemParameters;
                if (p.hasTopSpring && p.hasBottomSpring) {
                    keysToShow = ["m", "h1", "d", "mu", "k1", "x1", "k2", "x2"];
                } else if (p.hasTopSpring) {
                    keysToShow = ["m", "h1", "d", "mu", "k1", "x1", "h2"];
                } else {
                    keysToShow = ["m", "h1", "d", "mu", "k2", "x2"];
                }
            }

            keysToShow.forEach(key => {
                const meta = variableMeta[key];
                if (key !== missingVariableType) {
                    let displayValue = "";
                    if (key === "mu" || key === "x1" || key === "x2") {
                        displayValue = problemParameters[key].toFixed(2);
                    } else {
                        displayValue = problemParameters[key].toFixed(1);
                    }

                    varsDiv.innerHTML += `
                        <div class="glass-card flex flex-col justify-center items-center p-2 rounded-xl text-center">
                            <span class="text-[8px] text-gray-400 font-bold uppercase tracking-widest leading-none">${meta.label}</span>
                            <span class="font-orbitron font-black text-[11px] text-yellow-400 leading-none mt-1.5">${displayValue} <span class="text-[8px] text-yellow-500/70 font-sans font-normal">${meta.unit}</span></span>
                        </div>
                    `;
                } else {
                    document.getElementById("input-title").innerHTML = `Resolver: <span class="text-yellow-400 font-black">${meta.label}</span>`;
                    document.getElementById("unit-label").textContent = meta.unit;
                    document.getElementById("manual-input").value = "";
                }
            });

            // Actualizar HUD superior e intentos
            const phaseBadge = document.getElementById("phase-badge");
            const heartsCont = document.getElementById("hearts-container");

            heartsCont.innerHTML = "";
            for (let i = 0; i < 3; i++) {
                const filled = i < attemptsLeft;
                heartsCont.innerHTML += `
                    <svg class="w-4 h-4 ${filled ? 'text-rose-500 fill-rose-500' : 'text-gray-700'}" fill="${filled ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                `;
            }

            if (attemptsLeft === 3) {
                phaseBadge.textContent = "1 - Entrada Libre";
                phaseBadge.className = "font-orbitron text-[9px] font-black text-cyan-400 leading-none block mt-1 bg-cyan-950/40 px-2 py-0.5 rounded border border-cyan-800/50";
                document.getElementById("manual-input-wrapper").classList.remove("hidden");
                document.getElementById("options-container").classList.add("hidden");
                document.getElementById("manual-input").focus();
            } else {
                document.getElementById("manual-input-wrapper").classList.add("hidden");
                document.getElementById("options-container").classList.remove("hidden");
                if (attemptsLeft === 2) {
                    phaseBadge.textContent = "2 - Cuatro Opciones";
                    phaseBadge.className = "font-orbitron text-[9px] font-black text-yellow-400 leading-none block mt-1 bg-yellow-950/40 px-2 py-0.5 rounded border border-yellow-800/50";
                } else {
                    phaseBadge.textContent = "3 - Binaria (50/50)";
                    phaseBadge.className = "font-orbitron text-[9px] font-black text-rose-400 leading-none block mt-1 bg-rose-950/40 px-2 py-0.5 rounded border border-rose-800/50";
                }
                generateOptionButtons();
            }

            document.getElementById("score-display").textContent = currentScore;
            document.getElementById("lanzarBtn").disabled = false;
        }

        // --- SISTEMA PANEL DESLIZANTE ---
        let isMobileDrawerOpen = false;

        function toggleMobileDrawer(forceState = null) {
            const wrapper = document.getElementById("panels-wrapper");
            const btn = document.getElementById("mobile-drawer-toggle");
            const btnText = document.getElementById("mobile-drawer-text");
            const btnIcon = document.getElementById("mobile-drawer-icon");
            
            if (forceState !== null) {
                isMobileDrawerOpen = forceState;
            } else {
                isMobileDrawerOpen = !isMobileDrawerOpen;
            }
            
            if (isMobileDrawerOpen) {
                wrapper.classList.remove("mobile-hidden");
                btnText.textContent = "Ocultar Panel";
                btnIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>`;
            } else {
                wrapper.classList.add("mobile-hidden");
                btnText.textContent = "Ver Datos y Resolver";
                btnIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>`;
            }
        }

        function toggleLeftPanel() {
            const panel = document.getElementById("left-panel");
            const icon = document.getElementById("toggle-panel-icon");
            
            isPanelHidden = !isPanelHidden;
            if (isPanelHidden) {
                panel.classList.add("left-panel-hidden");
                icon.style.transform = "rotate(180deg)";
            } else {
                panel.classList.remove("left-panel-hidden");
                icon.style.transform = "rotate(0deg)";
            }
        }

        function toggleRightPanel() {
            const panel = document.getElementById("right-panel");
            const icon = document.getElementById("toggle-right-panel-icon");
            
            isRightPanelHidden = !isRightPanelHidden;
            if (isRightPanelHidden) {
                panel.classList.add("right-panel-hidden");
                icon.style.transform = "rotate(180deg)";
            } else {
                panel.classList.remove("right-panel-hidden");
                icon.style.transform = "rotate(0deg)";
            }
        }

        function selectOption(el) {
            const siblings = el.parentNode.children;
            for (let child of siblings) {
                child.classList.remove("border-yellow-400", "bg-yellow-400/20");
                child.classList.add("border-gray-800/80", "bg-black/30");
            }
            el.classList.remove("border-gray-800/80", "bg-black/30");
            el.classList.add("border-yellow-400", "bg-yellow-400/20");
        }

        function generateOptionButtons() {
            const container = document.getElementById("options-container");
            container.innerHTML = "";

            if (currentOptions.length === 0) {
                const optionSet = new Set();
                optionSet.add(correctAnswer);

                const targetSize = attemptsLeft === 2 ? 4 : 2;
                let tries = 0;
                const decimals = (missingVariableType === "mu" || missingVariableType === "x1" || missingVariableType === "x2") ? 2 : 1;

                while (optionSet.size < targetSize && tries < 200) {
                    tries++;
                    const deviation = 0.55 + Math.random() * 0.9;
                    let candidate = parseFloat((correctAnswer * deviation).toFixed(decimals));
                    
                    if (correctAnswer > 0 && candidate <= 0) {
                        candidate = parseFloat((correctAnswer + (Math.random() * 2 + 1)).toFixed(decimals));
                    }
                    if (correctAnswer < 0 && candidate >= 0) {
                        candidate = parseFloat((correctAnswer - (Math.random() * 2 + 1)).toFixed(decimals));
                    }
                    
                    let acceptable = true;
                    for (let existing of optionSet) {
                        if (Math.abs(candidate - existing) < (decimals === 2 ? 0.03 : 0.2)) {
                            acceptable = false;
                            break;
                        }
                    }
                    if (acceptable) optionSet.add(candidate);
                }

                // Fallback de seguridad
                let fallbackOffset = decimals === 2 ? 0.05 : 0.3;
                while (optionSet.size < targetSize) {
                    let valPositive = parseFloat((correctAnswer + fallbackOffset).toFixed(decimals));
                    let valNegative = parseFloat((correctAnswer - fallbackOffset).toFixed(decimals));
                    
                    if (correctAnswer >= 0) {
                        if (valPositive > 0) optionSet.add(valPositive);
                        if (optionSet.size < targetSize && valNegative > 0) optionSet.add(valNegative);
                    } else {
                        if (valPositive < 0) optionSet.add(valPositive);
                        if (optionSet.size < targetSize && valNegative < 0) optionSet.add(valNegative);
                    }
                    fallbackOffset += decimals === 2 ? 0.05 : 0.3;
                }

                currentOptions = Array.from(optionSet).sort(() => Math.random() - 0.5);
            }

            const decimals = (missingVariableType === "mu" || missingVariableType === "x1" || missingVariableType === "x2") ? 2 : 1;
            currentOptions.forEach((opt, idx) => {
                container.innerHTML += `
                    <div class="flex items-center justify-between bg-black/30 hover:bg-cyan-950/20 text-gray-100 px-3 py-1.5 rounded-xl cursor-pointer select-none transition-all border border-gray-800/80 shadow-md text-xs h-[34px]" onclick="document.getElementById('opt-radio-${idx}').checked=true; selectOption(this)">
                        <div class="flex items-center gap-2">
                            <input type="radio" id="opt-radio-${idx}" name="optionGroup" value="${opt}" class="w-3.5 h-3.5 accent-cyan-400 cursor-pointer">
                            <span class="font-orbitron text-xs font-bold leading-none">${opt.toFixed(decimals)}</span>
                        </div>
                        <span class="text-[9px] text-cyan-400 font-bold font-orbitron uppercase tracking-wider leading-none">${variableMeta[missingVariableType].unit}</span>
                    </div>
                `;
            });
        }

        function getSelectedUserAnswer() {
            if (attemptsLeft === 3) {
                const val = parseFloat(document.getElementById("manual-input").value);
                if (isNaN(val)) {
                    updateFeedbackMessage("Ingresa un valor numérico válido.", "border-yellow-500", "text-yellow-400");
                    return null;
                }
                if (missingVariableType === "Wf") {
                    if (val > 0) {
                        updateFeedbackMessage("El trabajo de fricción (W_f) debe ser un valor negativo.", "border-yellow-500", "text-yellow-400");
                        return null;
                    }
                } else if (missingVariableType === "mu") {
                    if (val < 0) {
                        updateFeedbackMessage("El coeficiente de fricción no puede ser negativo.", "border-yellow-500", "text-yellow-400");
                        return null;
                    }
                } else {
                    if (val <= 0) {
                        updateFeedbackMessage("Ingresa un valor mayor a cero.", "border-yellow-500", "text-yellow-400");
                        return null;
                    }
                }
                const decimals = (missingVariableType === "mu" || missingVariableType === "x1" || missingVariableType === "x2") ? 2 : 1;
                return parseFloat(val.toFixed(decimals));
            } else {
                const checked = document.querySelector('input[name="optionGroup"]:checked');
                if (!checked) {
                    updateFeedbackMessage("Selecciona una opción para simular.", "border-yellow-500", "text-yellow-400");
                    return null;
                }
                return parseFloat(checked.value);
            }
        }

        function updateFeedbackMessage(text, borderColorClass = "border-cyan-500", colorClass = "text-cyan-400") {
            const fb = document.getElementById("feedback");
            fb.className = `text-xs leading-snug ${colorClass}`;
            fb.textContent = text;
            
            const panel = document.getElementById("feedback-panel");
            panel.style.borderColor = ""; 
            panel.className = `bg-black/30 rounded-xl p-3 shadow-inner flex flex-col justify-center border-l-4 ${borderColorClass} transition-all duration-300 min-h-[80px]`;
        }

        // --- RESOLUCIÓN FÍSICA ANALÍTICA PARA ANIMAR ---
        function calculateAnimationTimeline(testParams) {
            const m = testParams.m;
            const h1 = testParams.h1;
            const d = testParams.d;
            const mu = testParams.mu;
            const k1 = testParams.k1 || 0;
            const x1 = testParams.x1 || 0;
            const k2 = testParams.k2 || 0;
            const hasTopSpring = testParams.hasTopSpring || false;
            const hasBottomSpring = testParams.hasBottomSpring || false;

            const timeline = [];

            const dx1 = 2.5;
            const dy1 = h1;
            const S1 = Math.sqrt(dx1*dx1 + dy1*dy1);
            const sinTheta1 = dy1 / S1;
            const a1 = GRAVITY * sinTheta1;
            const L_top = 0.8;

            let t_left_end = 0;
            let vB = 0;

            if (hasTopSpring) {
                // Lanzamiento por resorte superior en la rampa izquierda
                const w1 = Math.sqrt(k1 / m);
                const gSin = GRAVITY * sinTheta1;
                
                // C = (m * g * sinTheta1) / (k1 * x1 + m * g * sinTheta1)
                const C = (m * gSin) / (k1 * x1 + m * gSin);
                const tLaunch = Math.acos(Math.min(1.0, Math.max(-1.0, C))) / w1;
                
                const vLaunch = w1 * (x1 + gSin / (w1 * w1)) * Math.sin(w1 * tLaunch);
                
                timeline.push({
                    type: "ramp_launch",
                    tStart: 0,
                    tEnd: tLaunch,
                    distStart: 0,
                    distEnd: L_top,
                    speedStart: 0,
                    speedEnd: vLaunch,
                    w: w1,
                    x1: x1,
                    gSin: gSin,
                    L_top: L_top
                });

                // Deslizamiento libre por el resto de la rampa
                const distRemaining = S1 - L_top;
                const tSlide = (-vLaunch + Math.sqrt(Math.max(0, vLaunch * vLaunch + 2 * a1 * distRemaining))) / a1;
                vB = vLaunch + a1 * tSlide;

                timeline.push({
                    type: "ramp_down",
                    tStart: tLaunch,
                    tEnd: tLaunch + tSlide,
                    distStart: L_top,
                    distEnd: S1,
                    speedStart: vLaunch,
                    speedEnd: vB,
                    a: a1
                });

                t_left_end = tLaunch + tSlide;
            } else {
                // Deslizamiento simple sin resorte superior
                const t1 = Math.sqrt(2 * S1 / a1);
                vB = a1 * t1;

                timeline.push({
                    type: "ramp_down",
                    tStart: 0,
                    tEnd: t1,
                    distStart: 0,
                    distEnd: S1,
                    speedStart: 0,
                    speedEnd: vB,
                    a: a1
                });

                t_left_end = t1;
            }

            // Tramo 2: Valle con Fricción
            const a2 = -mu * GRAVITY;
            const vB_sq = vB * vB;
            const maxFricDist = mu > 0 ? (vB_sq / (2 * mu * GRAVITY)) : Infinity;
            
            let t2 = 0;
            let reachedEnd = true;
            let distCovered = d;
            let speedEndVal = 0;

            if (mu > 0 && maxFricDist <= d) {
                reachedEnd = false;
                distCovered = maxFricDist;
                t2 = vB / (mu * GRAVITY);
                speedEndVal = 0;
            } else {
                if (mu > 0) {
                    t2 = (vB - Math.sqrt(Math.max(0, vB_sq - 2 * mu * GRAVITY * d))) / (mu * GRAVITY);
                    speedEndVal = Math.sqrt(Math.max(0, vB_sq - 2 * mu * GRAVITY * d));
                } else {
                    t2 = d / vB;
                    speedEndVal = vB;
                }
            }

            timeline.push({
                type: "valley",
                tStart: t_left_end,
                tEnd: t_left_end + t2,
                distStart: S1,
                distEnd: S1 + distCovered,
                speedStart: vB,
                speedEnd: speedEndVal,
                a: a2,
                reachedEnd: reachedEnd
            });

            // Tramo 3: Rampa derecha de subida o Resorte inferior
            if (reachedEnd) {
                if (mode === "avanzado" && hasBottomSpring) {
                    // Resorte inferior
                    const w2 = Math.sqrt(k2 / m);
                    const X_max = speedEndVal / w2;
                    const t3 = Math.PI / (2 * w2);

                    timeline.push({
                        type: "spring",
                        tStart: t_left_end + t2,
                        tEnd: t_left_end + t2 + t3,
                        distStart: S1 + d,
                        distEnd: S1 + d + X_max,
                        speedStart: speedEndVal,
                        speedEnd: 0,
                        w: w2,
                        X_max: X_max
                    });
                } else {
                    // Rampa de subida
                    const dx3 = 2.0;
                    const dy3 = 3.0;
                    const S3 = Math.sqrt(dx3*dx3 + dy3*dy3);
                    const theta2 = Math.asin(dy3 / S3);
                    const a3 = -GRAVITY * Math.sin(theta2);

                    const S3_stop = (speedEndVal * speedEndVal) / (2 * GRAVITY * Math.sin(theta2));
                    const t3 = speedEndVal / (GRAVITY * Math.sin(theta2));

                    timeline.push({
                        type: "ramp_up",
                        tStart: t_left_end + t2,
                        tEnd: t_left_end + t2 + t3,
                        distStart: S1 + d,
                        distEnd: S1 + d + S3_stop,
                        speedStart: speedEndVal,
                        speedEnd: 0,
                        a: a3
                    });
                }
            }

            simTimeline = timeline;
            simDuration = timeline[timeline.length - 1].tEnd;
        }

        // --- SISTEMA RUN SIMULACIÓN EN TIEMPO REAL ---
        function runSimulation() {
            if (isSimulating) return;

            const userVal = getSelectedUserAnswer();
            if (userVal === null) return;

            // Creamos los parámetros de prueba usando el valor ingresado por el usuario
            let testParams = { ...problemParameters };
            testParams[missingVariableType] = userVal;

            calculateAnimationTimeline(testParams);

            isSimulating = true;
            document.getElementById("lanzarBtn").disabled = true;
            sfx.playHum(true);

            // Ocultar paneles para centrarse en la visualización
            if (!isPanelHidden) toggleLeftPanel();
            if (!isRightPanelHidden) toggleRightPanel();
            
            // Cerrar cajón móvil si está abierto y ocultar el botón flotante durante la simulación
            toggleMobileDrawer(false);
            document.getElementById("mobile-drawer-toggle").classList.add("hidden-force");

            const decimals = (missingVariableType === "mu" || missingVariableType === "x1" || missingVariableType === "x2") ? 2 : 1;
            const isCorrect = Math.abs(userVal - correctAnswer) <= (decimals === 2 ? 0.015 : 0.15);

            simTime = 0;
            const clock = new THREE.Clock();

            function simTick() {
                if (!isSimulating) return;

                const dt = Math.min(clock.getDelta(), 0.03);
                simTime += dt;

                // Buscar el tramo actual del timeline
                let segment = simTimeline.find(seg => simTime >= seg.tStart && simTime <= seg.tEnd);
                
                if (!segment) {
                    if (simTime >= simDuration) {
                        // Fin de la simulación
                        const lastSeg = simTimeline[simTimeline.length - 1];
                        displacement = lastSeg.distEnd;
                        cartSpeed = 0;
                        isSimulating = false;
                        
                        const finalTopComp = 0;
                        const finalBottomComp = (lastSeg.type === "spring") ? lastSeg.X_max : 0;
                        updateSimulationVisuals(finalTopComp, finalBottomComp);
                        sfx.playClank();
                        evalQuizResult(isCorrect);
                        return;
                    }
                    segment = simTimeline[simTimeline.length - 1];
                }

                // Calcular posición y velocidad según el tramo
                const tLocal = simTime - segment.tStart;
                let currentSegmentDist = 0;
                let topComp = 0;
                let bottomComp = 0;

                if (segment.type === "ramp_launch") {
                    const z = (segment.x1 + segment.gSin / (segment.w * segment.w)) * Math.cos(segment.w * tLocal) - segment.gSin / (segment.w * segment.w);
                    topComp = z;
                    cartSpeed = segment.w * (segment.x1 + segment.gSin / (segment.w * segment.w)) * Math.sin(segment.w * tLocal);
                    displacement = segment.distStart + (segment.L_top - topComp);
                }
                else if (segment.type === "ramp_down") {
                    currentSegmentDist = segment.speedStart * tLocal + 0.5 * segment.a * tLocal * tLocal;
                    cartSpeed = segment.speedStart + segment.a * tLocal;
                    displacement = segment.distStart + currentSegmentDist;
                } 
                else if (segment.type === "valley") {
                    currentSegmentDist = segment.speedStart * tLocal + 0.5 * segment.a * tLocal * tLocal;
                    cartSpeed = segment.speedStart + segment.a * tLocal;
                    displacement = segment.distStart + currentSegmentDist;

                    // Chispas si hay fricción
                    if (problemParameters.mu > 0 && Math.random() < 0.6) {
                        const cartPos = cartGroup.position.clone();
                        triggerSparks(cartPos, cartSpeed);
                    }
                } 
                else if (segment.type === "ramp_up") {
                    currentSegmentDist = segment.speedStart * tLocal + 0.5 * segment.a * tLocal * tLocal;
                    cartSpeed = segment.speedStart + segment.a * tLocal;
                    displacement = segment.distStart + currentSegmentDist;
                } 
                else if (segment.type === "spring") {
                    // SHM compresión
                    const comp = segment.X_max * Math.sin(segment.w * tLocal);
                    bottomComp = comp;
                    cartSpeed = segment.X_max * segment.w * Math.cos(segment.w * tLocal);
                    displacement = segment.distStart + bottomComp;
                }

                // Rotar ruedas del carrito basadas en el desplazamiento
                if (cartGroup && cartGroup.wheels) {
                    const wheelCircumference = 2 * Math.PI * 0.045;
                    const rotationAngle = (displacement / wheelCircumference) * (Math.PI * 2);
                    cartGroup.wheels.forEach(w => {
                        w.rotation.z = -rotationAngle;
                    });
                }

                updateSimulationVisuals(topComp, bottomComp);

                requestAnimationFrame(simTick);
            }

            requestAnimationFrame(simTick);
        }

        function updateSimulationVisuals(springTopCompression, springBottomCompression) {
            if (!cartGroup || !trackCurve) return;

            const trackLength = trackCurve.getLength();
            
            // Capping de seguridad
            let tCurveVal = displacement / trackLength;
            if (tCurveVal > 1.0) tCurveVal = 1.0;
            if (tCurveVal < 0.0) tCurveVal = 0.0;

            const pos = trackCurve.getPointAt(tCurveVal);
            const tangent = trackCurve.getTangentAt(tCurveVal);

            // Posicionar y alinear carrito
            cartGroup.position.copy(pos);
            
            const angleZ = Math.atan2(tangent.y, tangent.x);
            cartGroup.rotation.set(0, 0, angleZ);

            // Ajustar visual de deformación de resorte
            if (mode === "avanzado") {
                updateSpringVisualDeformation("top", springTopCompression);
                updateSpringVisualDeformation("bottom", springBottomCompression);
            }

            updateFBDPositions();
        }

        function resetSimulationPositions() {
            displacement = (mode === "avanzado" && problemParameters.hasTopSpring) ? (0.8 - problemParameters.x1) : 0;
            cartSpeed = 0;
            const initTopComp = (mode === "avanzado" && problemParameters.hasTopSpring) ? problemParameters.x1 : 0;
            updateSimulationVisuals(initTopComp, 0);
        }

        // --- SISTEMA RECEPTOR DE EVALUACIONES ---
        function evalQuizResult(isCorrect) {
            const meta = variableMeta[missingVariableType];
            
            // Volver a mostrar los paneles al terminar la simulación
            if (isPanelHidden) toggleLeftPanel();
            if (isRightPanelHidden) toggleRightPanel();
            
            // Mostrar botón flotante del cajón y abrirlo automáticamente para ver resultados en móviles
            document.getElementById("mobile-drawer-toggle").classList.remove("hidden-force");
            toggleMobileDrawer(true);

            const decimals = (missingVariableType === "mu" || missingVariableType === "x1" || missingVariableType === "x2") ? 2 : 1;

            if (isCorrect) {
                let scoreYield = 0;
                let textResult = "";
                
                if (attemptsLeft === 3) {
                    scoreYield = 100;
                    textResult = "¡EXCELENTE! Cálculo analítico exacto. +100 XP";
                } else if (attemptsLeft === 2) {
                    scoreYield = 50;
                    textResult = "¡MUY BIEN! Logrado en la fase de opción múltiple. +50 XP";
                } else {
                    scoreYield = 20;
                    textResult = "¡BIEN HECHO! Resuelto en la opción de descarte 50/50. +20 XP";
                }

                sfx.playSuccess();
                currentScore += scoreYield;
                document.getElementById("score-display").textContent = currentScore;
                
                updateFeedbackMessage(textResult, "border-emerald-500", "text-emerald-400 font-bold");
                document.getElementById("correct-answer-display").textContent = `Respuesta Exacta: ${correctAnswer.toFixed(decimals)} ${meta.unit}`;
                document.getElementById("lanzarBtn").classList.add("hidden");
            } else {
                attemptsLeft--;
                sfx.playFailure();
                
                if (attemptsLeft === 2) {
                    updateFeedbackMessage("Cálculo incorrecto. La telemetría física no balanceó. ¡Quedan 4 Opciones de ayuda!", "border-red-500", "text-red-400");
                    currentOptions = [];
                    setTimeout(() => {
                        updateUIState();
                        resetSimulationPositions();
                    }, 1500);
                } else if (attemptsLeft === 1) {
                    updateFeedbackMessage("¡Fallo! La conservación de la energía difiere. Se activa el comodín 50/50.", "border-red-500", "text-red-400");
                    const otherOpt = currentOptions.find(o => o !== correctAnswer);
                    currentOptions = [correctAnswer, otherOpt].sort(() => Math.random() - 0.5);
                    setTimeout(() => {
                        updateUIState();
                        resetSimulationPositions();
                    }, 1500);
                } else {
                    updateFeedbackMessage(`SISTEMA AGOTADO. El valor físico real era: ${correctAnswer.toFixed(decimals)} ${meta.unit}`, "border-red-600", "text-red-500 font-extrabold");
                    document.getElementById("correct-answer-display").textContent = "Estudia las fuerzas del DCL y pasa al siguiente ejercicio.";
                    document.getElementById("lanzarBtn").classList.add("hidden");
                }
            }
        }

        function restartSystem() {
            attemptsLeft = 3;
            currentOptions = [];
            isSimulating = false;
            
            // Asegurar que los paneles no queden ocultos al reiniciar (por ejemplo, si se reinicia a mitad de simulación)
            isPanelHidden = false;
            isRightPanelHidden = false;
            const leftPanel = document.getElementById("left-panel");
            const rightPanel = document.getElementById("right-panel");
            if (leftPanel) leftPanel.classList.remove("left-panel-hidden");
            if (rightPanel) rightPanel.classList.remove("right-panel-hidden");
            const leftIcon = document.getElementById("toggle-panel-icon");
            const rightIcon = document.getElementById("toggle-right-panel-icon");
            if (leftIcon) leftIcon.style.transform = "rotate(0deg)";
            if (rightIcon) rightIcon.style.transform = "rotate(0deg)";

            document.getElementById("lanzarBtn").classList.remove("hidden");
            document.getElementById("correct-answer-display").textContent = "";
            updateFeedbackMessage("Nuevo escenario dinámico generado. Analiza las variables y resuelve.", "border-cyan-500", "text-cyan-400");

            generateValidProblem();
            buildCartMesh();
            buildTrackSpline();
            updateUIState();
            
            // Mostrar botón flotante del cajón y abrirlo para el nuevo ejercicio en móviles
            document.getElementById("mobile-drawer-toggle").classList.remove("hidden-force");
            toggleMobileDrawer(true);
        }

        function toggleHelpModal() {
            const modal = document.getElementById("help-modal");
            modal.classList.toggle("hidden");
        }

        // --- BUCLE DE RENDERIZADO Y EFECTO PARALAJE ---
        function animate() {
            requestAnimationFrame(animate);

            // Suavizado dinámico del paralaje 2.5D y paneo horizontal según arrastre de cámara
            smoothPanX += (cameraPanX - smoothPanX) * 0.08;
            const isMobile = window.innerWidth <= 768;
            const targetX = cameraPanX + mouseX * 0.16;
            const targetY = (isMobile ? 0.90 : 1.25) + (mouseY * -0.16);
            camera.position.x += (targetX - camera.position.x) * 0.08;
            camera.position.y += (targetY - camera.position.y) * 0.08;
            camera.position.z += (cameraZoomZ - camera.position.z) * 0.08;
            camera.lookAt(smoothPanX, isMobile ? 0.70 : 1.1, 0);

            // Efecto de pulso neon en la zona de fricción
            if (frictionZoneWarning && frictionZoneWarning.material) {
                const pulse = 0.5 + 0.5 * Math.sin(Date.now() * 0.005);
                frictionZoneWarning.material.emissive.setHex(0x440a00 + Math.floor(pulse * 0x661200));
            }

            updateParticles();
            updateScreenBadges();

            if (renderer && scene && camera) {
                renderer.render(scene, camera);
            }
        }

        // --- ACTIVACIÓN GENERAL ---
        window.onload = function() {
            init3D();
            
            // Cambiar modo según selector
            document.getElementById("mode-selector").addEventListener("change", (e) => {
                mode = e.target.value;
                restartSystem();
            });

            restartSystem();
            animate();
            
            // Event Listeners
            document.getElementById("lanzarBtn").addEventListener("click", runSimulation);
            document.getElementById("resetBtn").addEventListener("click", restartSystem);
            document.getElementById("toggle-panel-btn").addEventListener("click", toggleLeftPanel);
            document.getElementById("toggle-right-panel-btn").addEventListener("click", toggleRightPanel);
            document.getElementById("toggle-fbd").addEventListener("change", () => {
                buildFBDVectors();
                updateFBDPositions();
            });

            document.getElementById("manual-input").addEventListener("keypress", function(e) {
                if (e.key === "Enter") {
                    runSimulation();
                }
            });

            // Renderizar ecuaciones matemáticas LaTeX con KaTeX
            if (typeof renderMathInElement === 'function') {
                renderMathInElement(document.body, {
                    delimiters: [
                        {left: '$$', right: '$$', display: true},
                        {left: '$', right: '$', display: false}
                    ],
                    throwOnError: false
                });
            }
        };
    </script>
</body>
</html>
