<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gran Premio Cinemática: MRU y MRUV</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Rajdhani:wght@500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #03050c;
            overflow: hidden;
            height: 100vh;
            width: 100vw;
        }
        .tech-font {
            font-family: 'Orbitron', sans-serif;
        }
        .sub-font {
            font-family: 'Rajdhani', sans-serif;
        }
        
        /* Opaque Cybernetic Panels (High contrast, no transparencies) */
        .glass-panel {
            background: #080c18;
            border: 1px solid rgba(6, 182, 212, 0.35);
            box-shadow: 0 10px 35px 0 rgba(0, 0, 0, 0.7);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.2s ease-in-out;
        }
        .glass-card:hover {
            background: rgba(6, 182, 212, 0.08);
            border-color: rgba(6, 182, 212, 0.4);
        }
        
        /* Scanning overlay effect */
        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                rgba(18, 16, 16, 0) 50%, 
                rgba(0, 0, 0, 0.12) 50%
            ), linear-gradient(
                90deg,
                rgba(255, 0, 0, 0.015),
                rgba(0, 255, 0, 0.008),
                rgba(0, 0, 255, 0.015)
            );
            background-size: 100% 4px, 6px 100%;
            pointer-events: none;
            z-index: 100;
        }

        /* Radial Vignette */
        .vignette {
            position: fixed;
            inset: 0;
            background: radial-gradient(circle, transparent 40%, rgba(3, 5, 13, 0.9) 95%);
            pointer-events: none;
            z-index: 2;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 5px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.3);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(6, 182, 212, 0.5);
            border-radius: 3px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(6, 182, 212, 0.7);
        }

        /* Highlight para variable incógnita */
        .unknown-highlight {
            background: rgba(245, 158, 11, 0.15);
            border: 1px dashed rgba(245, 158, 11, 0.7);
            border-radius: 4px;
            padding: 2px 6px;
        }

        input[type="number"]::-webkit-inner-spin-button,
        input[type="number"]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        /* Responsive Layout Overrides */
        @media (max-width: 768px) {
            body {
                overflow: hidden !important;
            }
            #mobile-drawer-toggle {
                display: flex !important;
            }
            #panels-wrapper {
                position: absolute !important;
                left: 8px !important;
                right: 8px !important;
                bottom: 8px !important;
                top: auto !important;
                width: auto !important;
                height: auto !important;
                max-height: 48vh !important;
                display: flex !important;
                flex-direction: column !important;
                gap: 8px !important;
                overflow-y: auto !important;
                pointer-events: auto !important;
                z-index: 30 !important;
                padding-right: 4px;
                padding-bottom: 74px !important;
                transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease-out !important;
            }
            #panels-wrapper.mobile-hidden {
                transform: translateY(120%) !important;
                opacity: 0 !important;
                pointer-events: none !important;
            }
            #side-panel, #right-panel {
                position: relative !important;
                left: auto !important;
                right: auto !important;
                top: auto !important;
                bottom: auto !important;
                width: 100% !important;
                height: auto !important;
                transform: none !important;
                margin: 0 !important;
                padding: 0 !important;
                display: flex !important;
                flex-direction: column !important;
                pointer-events: auto !important;
            }
            #side-panel .glass-panel, #right-panel {
                width: 100% !important;
                height: auto !important;
                padding: 12px !important;
                border-radius: 16px !important;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6) !important;
            }
            #togglePanelBtn {
                display: none !important;
            }
            #main-container {
                position: absolute !important;
                top: 8px !important;
                left: 8px !important;
                right: 8px !important;
                bottom: auto !important;
                width: auto !important;
                height: 44vh !important;
                display: flex !important;
                justify-content: center !important;
                align-items: center !important;
            }
            #main-container > div {
                width: 100% !important;
                height: 100% !important;
                padding: 8px !important;
                display: flex !important;
                flex-direction: column !important;
                justify-content: space-between !important;
            }
            #gameCanvas {
                height: 100% !important;
                max-height: calc(44vh - 42px) !important;
                object-fit: contain !important;
            }
            .hud-text {
                font-size: 8px !important;
            }
            #mobile-drawer-toggle.hidden-force {
                display: none !important;
            }
        }
    </style>
</head>
<body class="text-gray-100 relative select-none">

    <!-- CAPAS DE EFECTO CIBERNÉTICO -->
    <div class="scanlines"></div>
    <div class="vignette"></div>

    <!-- BOTÓN DE MOSTRAR/OCULTAR PANEL -->
    <div id="togglePanelBtn" class="absolute z-30 pointer-events-auto" style="left: 286px; top: 12px; transition: left 0.3s ease-out;">
        <button onclick="toggleSidebar()" class="w-8 h-8 bg-slate-900 hover:bg-cyan-500 text-cyan-400 hover:text-slate-900 border border-slate-700 rounded-lg flex items-center justify-center transition-all shadow-lg" title="Ocultar/Mostrar Interfaz">
            <svg id="toggleIcon" class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 19l-7-7 7-7"/>
            </svg>
        </button>
    </div>

    <!-- CONTENEDOR ENVOLVENTE DE PANELES (Para control responsivo en móviles) -->
    <div id="panels-wrapper" class="absolute inset-0 pointer-events-none z-20 flex justify-between mobile-hidden">
        <!-- INTERFAZ FLOTANTE LATERAL IZQUIERDA -->
        <div id="side-panel" class="absolute left-3 top-3 bottom-3 w-[270px] z-20 pointer-events-none flex flex-col gap-2.5" style="transform: translateX(0px); transition: transform 0.3s ease-out;">
            
            <!-- 0. Botón Volver -->
            <a href="./index.html" class="glass-panel rounded-xl p-2.5 pointer-events-auto shadow-md flex items-center justify-center gap-1.5 text-xs text-cyan-400 hover:text-cyan-300 font-bold uppercase tracking-wider font-orbitron transition-all border border-cyan-500/30">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Volver al Inicio
            </a>

            <!-- 1. Cabecera -->
            <div class="glass-panel rounded-xl p-3 pointer-events-auto shadow-lg flex items-center gap-3 border border-cyan-500/30">
                <div class="w-9 h-9 bg-gradient-to-tr from-cyan-500 to-blue-600 rounded-lg flex items-center justify-center shadow-md shrink-0">
                    <svg class="w-5 h-5 text-slate-950" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                    </svg>
                </div>
                <div>
                    <h1 class="font-orbitron text-xs font-black tracking-wider text-cyan-400 leading-none">GP CINEMÁTICA</h1>
                    <p class="text-[8.5px] text-gray-400 font-bold uppercase tracking-widest leading-none mt-1.5">MRU vs MRUV en Pista</p>
                </div>
            </div>

            <!-- 2. Estado de Puntos y Fase -->
            <div class="glass-panel rounded-xl p-2.5 pointer-events-auto shadow-md flex justify-around text-center gap-1 border border-cyan-500/30">
                <div class="flex-1 border-r border-slate-800">
                    <small class="text-gray-400 text-[9px] font-bold block leading-none tracking-wider">PUNTOS</small>
                    <span id="score-display" class="font-orbitron text-base font-black text-emerald-400 leading-none block mt-1.5">0</span>
                </div>
                <div class="flex-1">
                    <small class="text-gray-400 text-[9px] font-bold block leading-none tracking-wider">FASE DE JUEGO</small>
                    <span id="phase-badge" class="font-orbitron text-[10px] font-black text-yellow-400 leading-none block mt-1.5 uppercase">Cargando...</span>
                </div>
            </div>

            <!-- 3. Panel de Telemetría (Datos dados) -->
            <div class="glass-panel rounded-xl p-3.5 pointer-events-auto shadow-md flex flex-col gap-2.5 border border-cyan-500/30">
                <h3 class="text-[9.5px] font-black text-cyan-400 uppercase tracking-wider border-b border-slate-800 pb-1.5">Telemetría Estática</h3>
                
                <!-- Auto A (Red) -->
                <div class="rounded-xl p-2.5 bg-gradient-to-r from-red-950/30 to-slate-900 border border-red-500/30 text-sm">
                    <div class="font-bold text-[10px] text-red-400 uppercase tracking-widest mb-1.5 flex justify-between items-center">
                        <span>Auto A (MRU)</span>
                        <span class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.8)]"></span>
                    </div>
                    <div class="grid grid-cols-2 gap-1 text-xs" id="disp-container-a">
                        <div id="disp-va" class="font-semibold text-slate-300">V = <span class="font-bold font-orbitron text-slate-100">--</span></div>
                        <div id="disp-ta" class="text-right font-semibold text-slate-300">t = <span class="font-bold font-orbitron text-slate-100">--</span></div>
                    </div>
                </div>
                
                <!-- Auto B (Blue) -->
                <div class="rounded-xl p-2.5 bg-gradient-to-r from-blue-950/30 to-slate-900 border border-blue-500/30 text-sm">
                    <div class="font-bold text-[10px] text-blue-400 uppercase tracking-widest mb-1.5 flex justify-between items-center">
                        <span>Auto B (MRUV)</span>
                        <span class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.8)]"></span>
                    </div>
                    <div class="grid grid-cols-2 gap-x-1 gap-y-1 text-xs" id="disp-container-b">
                        <div id="disp-v0b" class="font-semibold text-slate-300">V₀ = <span class="font-bold font-orbitron text-slate-100">--</span></div>
                        <div id="disp-ab" class="text-right font-semibold text-slate-300">a = <span class="font-bold font-orbitron text-slate-100">--</span></div>
                        <div id="disp-tb" class="font-semibold text-slate-300">t = <span class="font-bold font-orbitron text-slate-100">--</span></div>
                        <div id="disp-vfb" class="text-right font-semibold text-slate-300">Vf = <span class="font-bold font-orbitron text-slate-100">--</span></div>
                    </div>
                </div>

                <!-- Meta info -->
                <div class="border-t border-slate-800 pt-2 flex items-center justify-between text-xs font-semibold">
                    <span class="text-slate-400 font-bold text-[10px] uppercase tracking-wider">🏁 META DE PISTA:</span>
                    <span class="font-orbitron font-bold text-cyan-400 text-base"><span id="p-finish">--</span> m</span>
                </div>
            </div>

        </div>

        <!-- INTERFAZ FLOTANTE LATERAL DERECHA (Resolver y Acciones) -->
        <div id="right-panel" class="absolute right-3 top-3 bottom-3 w-[290px] z-20 pointer-events-auto flex flex-col gap-3 bg-[#080c18] border border-cyan-500/35 rounded-2xl p-4 shadow-2xl border-t-2 border-t-cyan-500">
            <span class="text-[11px] font-extrabold text-yellow-400 uppercase tracking-widest font-orbitron block border-b border-slate-800 pb-1.5 flex items-center gap-1.5 shrink-0">
                <svg class="w-4 h-4 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                Resolver Desafío
            </span>
            
            <!-- Fase 1: Entradas Numéricas Manuales -->
            <div id="phase1-inputs" class="flex flex-col gap-2.5">
                <p class="text-[10px] text-slate-400 font-semibold leading-snug">Calcula y escribe las variables faltantes:</p>
                
                <div class="flex flex-col gap-1.5">
                    <label id="lbl-inputA" class="text-[10px] font-bold text-red-400 uppercase tracking-wider">Variable A:</label>
                    <div class="relative rounded-lg overflow-hidden border border-red-500/40 bg-black/50">
                        <input type="number" id="in-valA" step="0.1" 
                               class="w-full bg-transparent text-center font-orbitron text-sm font-black py-2 pl-2 pr-12 focus:outline-none focus:ring-1 focus:ring-red-400 text-yellow-300 placeholder-slate-700" 
                               placeholder="?">
                        <span id="unit-inputA" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-red-400 font-bold font-orbitron text-[10px]">--</span>
                    </div>
                </div>

                <div class="flex flex-col gap-1.5">
                    <label id="lbl-inputB" class="text-[10px] font-bold text-blue-400 uppercase tracking-wider">Variable B:</label>
                    <div class="relative rounded-lg overflow-hidden border border-blue-500/40 bg-black/50">
                        <input type="number" id="in-valB" step="0.1" 
                               class="w-full bg-transparent text-center font-orbitron text-sm font-black py-2 pl-2 pr-12 focus:outline-none focus:ring-1 focus:ring-blue-400 text-yellow-300 placeholder-slate-700" 
                               placeholder="?">
                        <span id="unit-inputB" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-blue-400 font-bold font-orbitron text-[10px]">--</span>
                    </div>
                </div>
            </div>

            <!-- Fases 2 y 3: Opciones de Selección Múltiple -->
            <div id="options-container" class="hidden flex flex-col gap-2.5">
                <!-- Inyectado dinámicamente -->
            </div>

            <!-- Feedback de Sistema -->
            <div id="feedback" class="bg-black/45 rounded-lg p-2.5 text-center text-xs font-bold text-cyan-400 border border-slate-800 min-h-[50px] flex items-center justify-center leading-tight">
                Cargando telemetría...
            </div>

            <!-- Botonera -->
            <div class="flex flex-col gap-2 mt-auto">
                <button id="btn-validate" class="w-full bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-400 hover:to-blue-400 text-slate-950 font-black py-2.5 px-4 rounded-xl shadow-lg transition-all text-xs uppercase tracking-wider font-orbitron flex items-center justify-center gap-1.5 active:scale-95">
                    <svg class="w-4 h-4 text-slate-950 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                    </svg>
                    Validar y Correr
                </button>
                <button id="btn-new" class="w-full bg-slate-900 border border-slate-800 hover:bg-slate-800 text-slate-200 font-bold py-2 px-4 rounded-xl transition-all text-[10px] uppercase tracking-widest font-orbitron flex items-center justify-center gap-1">
                    Siguiente Problema
                </button>
            </div>
        </div>
    </div>

    <!-- BOTÓN FLOTANTE PARA DESPLEGAR PANEL EN MÓVILES -->
    <button id="mobile-drawer-toggle" onclick="toggleMobileDrawer()" class="fixed bottom-4 left-1/2 transform -translate-x-1/2 z-40 hidden font-orbitron font-extrabold text-[10px] uppercase tracking-wider px-4 py-2.5 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-slate-950 rounded-xl shadow-[0_0_20px_rgba(6,182,212,0.5)] border border-cyan-300/30 transition-all duration-300 items-center gap-2 pointer-events-auto">
        <svg id="mobile-drawer-icon" class="w-5 h-5 text-slate-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        <span id="mobile-drawer-text">Ver Datos y Resolver</span>
    </button>

    <!-- SECCIÓN CENTRAL DE SIMULACIÓN -->
    <div id="main-container" class="absolute top-3 bottom-3 pointer-events-none flex flex-col justify-center items-center" style="left: 300px; right: 320px; transition: left 0.3s ease-out, right 0.3s ease-out;">
        <!-- Dashboard Canvas -->
        <div class="w-full max-w-4xl bg-[#080c18] border border-cyan-500/35 rounded-2xl p-4 shadow-2xl pointer-events-auto flex flex-col gap-4 border-t-2 border-t-cyan-500">
            <!-- Telemetría en Vivo Header -->
            <div class="flex justify-between items-center text-xs border-b border-slate-800 pb-2">
                <div class="flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.8)]"></span>
                    <span class="font-orbitron font-bold text-slate-200 uppercase tracking-widest text-[10px] hud-text">MONITOR DE PISTA ACTIVO</span>
                </div>
                <div class="flex items-center gap-4 font-mono text-slate-400 text-xs hud-text">
                    <div>TIEMPO: <span id="tel-time" class="font-bold text-cyan-400">0.00</span> s</div>
                    <div class="w-px h-3 bg-slate-800"></div>
                    <div>DISTANCIA A: <span id="tel-dist-a" class="font-bold text-red-400">0.00</span> m</div>
                    <div class="w-px h-3 bg-slate-800"></div>
                    <div>DISTANCIA B: <span id="tel-dist-b" class="font-bold text-blue-400">0.00</span> m</div>
                </div>
            </div>
            
            <!-- Canvas Wrapper -->
            <div class="relative w-full overflow-hidden rounded-xl border border-cyan-500/20 bg-[#02040a] shadow-inner">
                <canvas id="gameCanvas" width="900" height="350" class="block w-full h-[350px]"></canvas>
            </div>
        </div>
    </div>

    <!-- BOTÓN DE AYUDA / FÓRMULAS -->
    <div class="absolute top-3 right-3 z-10 pointer-events-auto">
        <button onclick="toggleHelpModal()" class="w-8 h-8 bg-slate-900/90 hover:bg-cyan-500 text-cyan-400 hover:text-slate-900 border border-slate-800 rounded-lg flex items-center justify-center transition-all shadow-lg" title="Ayuda de Fórmulas">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364.364l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
        </button>
    </div>

    <!-- MODAL DE TEORÍA Y FÓRMULAS -->
    <div id="help-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-md hidden pointer-events-auto">
        <div class="glass-panel w-full max-w-lg rounded-3xl p-6 shadow-2xl relative border border-cyan-500/30">
            <button onclick="toggleHelpModal()" class="absolute top-4 right-4 text-gray-400 hover:text-white text-2xl font-bold transition-all">&times;</button>
            <h2 class="font-orbitron text-sm font-bold text-cyan-400 mb-4 flex items-center gap-2 tracking-wide uppercase">
                <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
                Fórmulas de Cinemática (MRU y MRUV)
            </h2>
            
            <div class="space-y-4 text-xs text-gray-300 overflow-y-auto max-h-[60vh] pr-2 custom-scrollbar">
                <p class="leading-relaxed">La cinemática describe el movimiento de los cuerpos sin considerar las fuerzas que lo producen.</p>
                
                <div class="bg-black/40 p-3 rounded-xl border border-slate-800">
                    <h3 class="font-bold text-red-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Auto A: Movimiento Rectilíneo Uniforme (M.R.U.)</h3>
                    <p class="leading-relaxed text-[11px]">La velocidad es constante. La posición en cualquier instante $t$ se rige por:</p>
                    <p class="font-mono text-center text-red-300 my-2 text-xs">d = v · t</p>
                    <p class="text-[9.5px] text-gray-400 text-center mt-1">Despejes: v = d / t  ;  t = d / v</p>
                </div>

                <div class="bg-black/40 p-3 rounded-xl border border-slate-800">
                    <h3 class="font-bold text-blue-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Auto B: M.R. Uniformemente Variado (M.R.U.V.)</h3>
                    <p class="leading-relaxed text-[11px]">La aceleración es constante. Las ecuaciones fundamentales son:</p>
                    <p class="font-mono text-center text-blue-300 my-2 text-xs">d = v₀ · t + ½ · a · t²</p>
                    <p class="font-mono text-center text-blue-300 my-2 text-xs">vf = v₀ + a · t</p>
                    <p class="text-[9.5px] text-gray-400 text-center mt-1">Despeje de aceleración: a = 2(d - v₀·t) / t²</p>
                    <p class="text-[9.5px] text-gray-400 text-center mt-1">Despeje de velocidad final: vf = v₀ + a·t</p>
                </div>
            </div>
            
            <div class="mt-4">
                <button onclick="toggleHelpModal()" class="w-full bg-cyan-500 hover:bg-cyan-600 py-2 rounded-lg font-bold font-orbitron uppercase text-[10px] tracking-wider transition-all text-slate-950">Entendido</button>
            </div>
        </div>
    </div>

    <!-- SCRIPTS DE CONTROL Y LÓGICA -->
    <script>
        // --- SINTETIZADOR DE SONIDOS (Web Audio API) ---
        class SoundFX {
            constructor() {
                this.ctx = null;
            }
            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
            }
            playTick() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(800, this.ctx.currentTime);
                gain.gain.setValueAtTime(0.04, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.04);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.04);
            }
            playSuccess() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(523.25, this.ctx.currentTime); // C5
                osc.frequency.setValueAtTime(659.25, this.ctx.currentTime + 0.1); // E5
                osc.frequency.setValueAtTime(783.99, this.ctx.currentTime + 0.2); // G5
                gain.gain.setValueAtTime(0.12, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.005, this.ctx.currentTime + 0.4);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.45);
            }
            playFailure() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(140, this.ctx.currentTime);
                osc.frequency.linearRampToValueAtTime(70, this.ctx.currentTime + 0.25);
                gain.gain.setValueAtTime(0.12, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.005, this.ctx.currentTime + 0.25);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.26);
            }
            playEngine() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(80, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(320, this.ctx.currentTime + 0.5);
                gain.gain.setValueAtTime(0.08, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.65);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.7);
            }
        }
        const sfx = new SoundFX();

        const CONSTANTS = {
            laneHeight: 80,
            colors: { grass: '#02040a', asphalt: '#0b0f19', carA: '#ef4444', carB: '#3b82f6' },
            tolerance: 0.15
        };

        // --- ESTADO ---
        let state = {
            score: 0,
            phase: 1,
            isRunning: false,
            truth: { 
                dist: 0, 
                va: 0, ta: 0, 
                v0b: 0, ab: 0, tb: 0, vfb: 0 
            },
            missing: {
                carA: 'ta', 
                carB: 'tb'  
            },
            animId: null,
            timeElapsed: 0
        };

        // --- DOM ---
        const dom = {
            canvas: document.getElementById('gameCanvas'),
            ctx: document.getElementById('gameCanvas').getContext('2d'),
            score: document.getElementById('score-display'),
            phaseBadge: document.getElementById('phase-badge'),
            inputsDiv: document.getElementById('phase1-inputs'),
            optionsDiv: document.getElementById('options-container'),
            lblA: document.getElementById('lbl-inputA'),
            inA: document.getElementById('in-valA'),
            unitA: document.getElementById('unit-inputA'),
            lblB: document.getElementById('lbl-inputB'),
            inB: document.getElementById('in-valB'),
            unitB: document.getElementById('unit-inputB'),
            
            feedback: document.getElementById('feedback'),
            btnVal: document.getElementById('btn-validate'),
            btnNew: document.getElementById('btn-new'),
            
            dVa: document.getElementById('disp-va'),
            dTa: document.getElementById('disp-ta'),
            dV0b: document.getElementById('disp-v0b'),
            dAb: document.getElementById('disp-ab'),
            dTb: document.getElementById('disp-tb'),
            dVfb: document.getElementById('disp-vfb'),
            
            pFinish: document.getElementById('p-finish')
        };

        // ==========================================
        //  LÓGICA MATEMÁTICA Y GENERACIÓN
        // ==========================================

        function generateProblem() {
            const dist = 100 + Math.floor(Math.random() * 300); // 100 - 400 m
            const tA_target = 5 + Math.random() * 10;
            const tB_target = 5 + Math.random() * 10;

            // --- CAR A (MRU) ---
            const vA = dist / tA_target;

            // --- CAR B (MRUV) ---
            const v0B = Math.floor(Math.random() * 8); 
            const aB = (2 * (dist - (v0B * tB_target))) / (tB_target * tB_target);
            const vfB = v0B + aB * tB_target;

            state.truth = {
                dist: dist,
                va: vA, ta: tA_target,
                v0b: v0B, ab: aB, tb: tB_target, vfb: vfB
            };

            // Seleccionar Incógnitas (Random)
            state.missing.carA = Math.random() > 0.5 ? 'va' : 'ta';

            const randB = Math.random();
            if (randB < 0.33) state.missing.carB = 'tb';
            else if (randB < 0.66) state.missing.carB = 'ab';
            else state.missing.carB = 'vfb'; 

            renderDataPanel();
        }

        function renderDataPanel() {
            const t = state.truth;
            const m = state.missing;

            const show = (val, unit, isMissing) => {
                if (isMissing) return `<span class="unknown-highlight text-yellow-400 font-bold">???</span>`;
                return `${val.toFixed(1)} <span class="text-slate-400 text-[10px] font-sans font-normal">${unit}</span>`;
            };

            dom.pFinish.textContent = t.dist;

            // CAR A
            dom.dVa.innerHTML = `V = ${show(t.va, 'm/s', m.carA === 'va')}`;
            dom.dTa.innerHTML = `t = ${show(t.ta, 's', m.carA === 'ta')}`;

            // CAR B
            dom.dV0b.innerHTML = `V₀ = ${show(t.v0b, 'm/s', false)}`; 
            dom.dAb.innerHTML = `a = ${show(t.ab, 'm/s²', m.carB === 'ab')}`;
            dom.dTb.innerHTML = `t = ${show(t.tb, 's', m.carB === 'tb')}`;
            dom.dVfb.innerHTML = `Vf = ${show(t.vfb, 'm/s', m.carB === 'vfb')}`;

            configureInput(dom.lblA, dom.unitA, m.carA, 'A');
            configureInput(dom.lblB, dom.unitB, m.carB, 'B');
        }

        function configureInput(labelEl, unitEl, type, carName) {
            let txt = "", unit = "";
            switch(type) {
                case 'ta': case 'tb': txt = `Tiempo Auto ${carName}`; unit = "s"; break;
                case 'va': txt = `Velocidad Auto ${carName}`; unit = "m/s"; break;
                case 'ab': txt = `Aceleración Auto ${carName}`; unit = "m/s²"; break;
                case 'vfb': txt = `Vel. Final Auto ${carName}`; unit = "m/s"; break;
            }
            labelEl.textContent = txt + ":";
            unitEl.textContent = unit;
        }

        // ==========================================
        //  SISTEMA DE FASES Y VALIDACIÓN
        // ==========================================

        function updatePhaseUI() {
            const p = state.phase;
            if (p === 1) {
                dom.phaseBadge.textContent = "Fase 1: Entrada Libre (100 Pts)";
                dom.phaseBadge.className = "font-orbitron text-[10px] font-black text-cyan-400 leading-none block mt-1.5 bg-cyan-950/40 px-2 py-1 rounded border border-cyan-800/50 uppercase";
                dom.inputsDiv.classList.remove('hidden');
                dom.optionsDiv.classList.add('hidden');
                dom.btnVal.disabled = false;
                dom.btnVal.classList.remove('hidden');
                dom.inA.value = ""; dom.inB.value = ""; dom.inA.focus();
            } else {
                dom.phaseBadge.textContent = p === 2 ? "Fase 2: Opciones (50 Pts)" : "Fase 3: Ayuda (20 Pts)";
                dom.phaseBadge.className = p === 2 
                    ? "font-orbitron text-[10px] font-black text-yellow-400 leading-none block mt-1.5 bg-yellow-950/40 px-2 py-1 rounded border border-yellow-800/50 uppercase"
                    : "font-orbitron text-[10px] font-black text-rose-400 leading-none block mt-1.5 bg-rose-950/40 px-2 py-1 rounded border border-rose-800/50 uppercase";
                dom.inputsDiv.classList.add('hidden');
                dom.optionsDiv.classList.remove('hidden');
                dom.btnVal.disabled = false;
                dom.btnVal.classList.remove('hidden');
                generateOptions(p === 2 ? 4 : 2);
            }
        }

        function getCorrectValues() {
            return {
                valA: state.truth[state.missing.carA],
                valB: state.truth[state.missing.carB]
            };
        }

        function generateOptions(count) {
            dom.optionsDiv.innerHTML = "";
            const correct = getCorrectValues();
            const opts = [];

            // Opción Correcta
            opts.push({ a: correct.valA, b: correct.valB, isCorrect: true });

            // Generar Distractores con protección contra bucle infinito
            let attempts = 0;
            while(opts.length < count && attempts < 200) {
                attempts++;
                let factorA = 0.8 + Math.random() * 0.4; 
                let factorB = 0.8 + Math.random() * 0.4;
                if(Math.abs(factorA - 1) < 0.1) factorA = 1.2; 

                let fakeA = correct.valA * factorA;
                let fakeB = correct.valB * factorB;
                
                fakeA = parseFloat(fakeA.toFixed(1));
                fakeB = parseFloat(fakeB.toFixed(1));

                let isDuplicate = false;
                for (let opt of opts) {
                    if (Math.abs(opt.a - fakeA) < 0.15 && Math.abs(opt.b - fakeB) < 0.15) {
                        isDuplicate = true;
                        break;
                    }
                }

                if (!isDuplicate && fakeA > 0 && fakeB > 0) {
                    opts.push({ a: fakeA, b: fakeB, isCorrect: false });
                }
            }

            // Fallback en caso de que falle por valores pequeños
            let offset = 0.2;
            while (opts.length < count) {
                let fakeA = correct.valA + (opts.length % 2 === 0 ? offset : -offset);
                let fakeB = correct.valB + (opts.length % 3 === 0 ? offset : -offset);
                fakeA = parseFloat(Math.max(0.1, fakeA).toFixed(1));
                fakeB = parseFloat(Math.max(0.1, fakeB).toFixed(1));

                let isDuplicate = false;
                for (let opt of opts) {
                    if (Math.abs(opt.a - fakeA) < 0.05 && Math.abs(opt.b - fakeB) < 0.05) {
                        isDuplicate = true;
                        break;
                    }
                }
                if (!isDuplicate) {
                    opts.push({ a: fakeA, b: fakeB, isCorrect: false });
                }
                offset += 0.2;
            }

            opts.sort(() => Math.random() - 0.5);

            opts.forEach((opt, idx) => {
                const wrapper = document.createElement('div');
                wrapper.className = "option-btn-wrapper flex items-center justify-between bg-slate-900 border border-slate-700 hover:bg-cyan-500/10 hover:border-cyan-400 p-2.5 rounded-xl cursor-pointer select-none transition-all text-xs font-semibold w-full tracking-wide";
                
                const uA = dom.unitA.textContent;
                const uB = dom.unitB.textContent;
                
                wrapper.innerHTML = `
                    <div class="flex items-center gap-2">
                        <input type="radio" id="opt-radio-${idx}" name="optionGroup" value="${opt.a},${opt.b}" class="w-3.5 h-3.5 accent-cyan-500 cursor-pointer">
                        <label for="opt-radio-${idx}" class="cursor-pointer flex flex-col gap-0.5">
                            <span class="font-orbitron text-red-400">A: ${opt.a.toFixed(1)} ${uA}</span>
                            <span class="font-orbitron text-blue-400">B: ${opt.b.toFixed(1)} ${uB}</span>
                        </label>
                    </div>
                `;
                wrapper.onclick = () => {
                    if (state.isRunning) return;
                    sfx.playTick();
                    document.getElementById(`opt-radio-${idx}`).checked = true;
                    // Highlight visually
                    const siblings = wrapper.parentNode.children;
                    for (let sib of siblings) {
                        sib.classList.remove("border-cyan-400", "bg-cyan-500/10");
                        sib.classList.add("border-slate-700", "bg-slate-900");
                    }
                    wrapper.classList.remove("border-slate-700", "bg-slate-900");
                    wrapper.classList.add("border-cyan-400", "bg-cyan-500/10");
                };
                dom.optionsDiv.appendChild(wrapper);
            });
        }

        function getUserAnswer() {
            if (state.phase === 1) {
                const valA = parseFloat(dom.inA.value);
                const valB = parseFloat(dom.inB.value);
                if (isNaN(valA) || isNaN(valB)) {
                    return null;
                }
                return { a: valA, b: valB };
            } else {
                const selected = document.querySelector('input[name="optionGroup"]:checked');
                if (!selected) {
                    return null;
                }
                const parts = selected.value.split(',');
                return { a: parseFloat(parts[0]), b: parseFloat(parts[1]) };
            }
        }

        function validateRound(valA, valB) {
            if(state.isRunning) return;

            // Deshabilitar botón inmediatamente para prevenir doble click
            dom.btnVal.disabled = true;

            const correct = getCorrectValues();
            const okA = Math.abs(valA - correct.valA) <= Math.max(0.1, correct.valA * 0.05);
            const okB = Math.abs(valB - correct.valB) <= Math.max(0.1, correct.valB * 0.05);

            if (okA && okB) {
                let pts = state.phase === 1 ? 100 : (state.phase === 2 ? 50 : 20);
                state.score += pts;
                dom.score.textContent = state.score;
                dom.feedback.innerHTML = `¡EXCELENTE! Cálculos correctos. +${pts} Pts.<br>Iniciando simulación...`;
                dom.feedback.className = "bg-emerald-950/90 text-emerald-400 border border-emerald-500/50 rounded-lg p-2 text-center text-xs font-bold min-h-[50px] flex items-center justify-center leading-tight shadow-md";
                sfx.playSuccess();
                dom.btnVal.classList.add('hidden'); // Ocultar al resolver correctamente
                startRaceAnimation();
            } else {
                sfx.playFailure();
                if (state.phase < 3) {
                    dom.feedback.textContent = "Incorrecto. Intenta con opciones...";
                    dom.feedback.className = "bg-blue-950/90 text-blue-400 border border-blue-500/50 rounded-lg p-2 text-center text-xs font-bold min-h-[50px] flex items-center justify-center leading-tight shadow-md";
                    state.phase++;
                    setTimeout(updatePhaseUI, 1000);
                } else {
                    dom.feedback.innerHTML = `Se acabaron los intentos.<br>Correctos: A=${correct.valA.toFixed(1)}, B=${correct.valB.toFixed(1)}`;
                    dom.feedback.className = "bg-red-950/90 text-red-400 border border-red-500/50 rounded-lg p-2 text-center text-xs font-bold min-h-[50px] flex items-center justify-center leading-tight shadow-md";
                    dom.btnVal.classList.add('hidden'); // Ocultar al agotarse los intentos
                    setTimeout(startRaceAnimation, 2000);
                }
            }
        }

        // ==========================================
        //  RENDERIZADO CANVAS (ESTILO REALISTA Y PREMIUM)
        // ==========================================
        
        function metersToPx(m) { return 25 + m * ((dom.canvas.width - 70) / state.truth.dist); }

        function drawCar(x, y, color, type) {
            const ctx = dom.ctx;
            ctx.save();
            
            // Engine Vibration during race
            let vibY = 0;
            if (state.isRunning) {
                vibY = Math.sin(performance.now() * 0.08) * 0.7;
            }
            
            ctx.translate(x, y + vibY);

            // --- 0. DROP SHADOW (Sombra 3D en el asfalto) ---
            ctx.save();
            ctx.fillStyle = "rgba(0, 0, 0, 0.55)";
            ctx.filter = "blur(3px)";
            ctx.beginPath();
            ctx.rect(2, 2, 38, 16);
            ctx.fill();
            ctx.restore();

            // --- 1. NEUMÁTICOS REALISTAS CON RINES ---
            const tireGrad = ctx.createLinearGradient(0, -4, 0, 1);
            tireGrad.addColorStop(0, "#090d16");
            tireGrad.addColorStop(0.5, "#272e3f");
            tireGrad.addColorStop(1, "#090d16");

            ctx.fillStyle = tireGrad;
            ctx.fillRect(6, -5, 9, 6);   // Delantera Izq
            ctx.fillRect(6, 19, 9, 6);   // Delantera Der
            ctx.fillRect(26, -5.5, 10, 6.5); // Trasera Izq
            ctx.fillRect(26, 19, 10, 6.5);  // Trasera Der

            // Rines metálicos
            ctx.fillStyle = "#64748b";
            ctx.fillRect(9, -4, 3, 4);
            ctx.fillRect(9, 20, 3, 4);
            ctx.fillRect(29, -4.5, 4, 4.5);
            ctx.fillRect(29, 20, 4, 4.5);

            // Ejes de suspensión
            ctx.fillStyle = "#475569";
            ctx.fillRect(10, 1, 2, 18);
            ctx.fillRect(30, 1, 2, 18);

            // --- 2. CHASIS / CARROCERÍA CON VOLUMEN 2.5D (Gradiente de color) ---
            const bodyGrad = ctx.createLinearGradient(0, 0, 0, 20);
            bodyGrad.addColorStop(0, adjustColorBrightness(color, -25));
            bodyGrad.addColorStop(0.3, color);
            bodyGrad.addColorStop(0.7, adjustColorBrightness(color, 20));
            bodyGrad.addColorStop(1, adjustColorBrightness(color, -40));

            ctx.fillStyle = bodyGrad;
            ctx.beginPath();
            ctx.moveTo(0, 3);
            ctx.lineTo(8, 3);
            ctx.lineTo(12, 1);
            ctx.lineTo(34, 1);
            ctx.lineTo(40, 3);
            ctx.lineTo(40, 17);
            ctx.lineTo(34, 19);
            ctx.lineTo(12, 19);
            ctx.lineTo(8, 17);
            ctx.lineTo(0, 17);
            ctx.closePath();
            ctx.fill();

            // --- 3. SIDE PODS Y CAPÓ (Capas 2.5D de volumen superior) ---
            const hoodGrad = ctx.createLinearGradient(0, 3, 0, 17);
            hoodGrad.addColorStop(0, adjustColorBrightness(color, 15));
            hoodGrad.addColorStop(0.5, adjustColorBrightness(color, 45));
            hoodGrad.addColorStop(1, adjustColorBrightness(color, -10));

            ctx.fillStyle = hoodGrad;
            ctx.beginPath();
            ctx.moveTo(10, 4);
            ctx.lineTo(32, 5);
            ctx.lineTo(35, 10);
            ctx.lineTo(32, 15);
            ctx.lineTo(10, 16);
            ctx.closePath();
            ctx.fill();

            // --- 4. ALERÓN TRASERO ELEVADO ---
            ctx.fillStyle = "rgba(0,0,0,0.45)";
            ctx.fillRect(1, 1, 3, 18); // Sombra del alerón en el chasis

            const wingGrad = ctx.createLinearGradient(0, -3, 0, 23);
            wingGrad.addColorStop(0, "#1e293b");
            wingGrad.addColorStop(0.5, "#0f172a");
            wingGrad.addColorStop(1, "#1e293b");
            
            ctx.fillStyle = wingGrad;
            ctx.fillRect(-2, -3, 4, 26);
            
            ctx.fillStyle = color;
            ctx.fillRect(-2, -4, 4, 2);
            ctx.fillRect(-2, 22, 4, 2);

            // --- 5. CABINA DE CRISTAL FUTURISTA (Relieve y reflexión) ---
            const glassGrad = ctx.createLinearGradient(16, 5, 28, 15);
            glassGrad.addColorStop(0, "rgba(6, 182, 212, 0.9)");
            glassGrad.addColorStop(0.5, "rgba(255, 255, 255, 1)");
            glassGrad.addColorStop(1, "rgba(2, 132, 199, 0.9)");

            ctx.fillStyle = glassGrad;
            ctx.beginPath();
            ctx.moveTo(16, 5);
            ctx.lineTo(26, 6);
            ctx.lineTo(29, 10);
            ctx.lineTo(26, 14);
            ctx.lineTo(16, 15);
            ctx.closePath();
            ctx.fill();

            // Casco del Piloto (Mini esfera 3D)
            const helmetGrad = ctx.createRadialGradient(21, 10, 1, 21, 10, 3);
            helmetGrad.addColorStop(0, "#ffffff");
            helmetGrad.addColorStop(0.7, "#fbbf24");
            helmetGrad.addColorStop(1, "#b45309");
            ctx.fillStyle = helmetGrad;
            ctx.beginPath();
            ctx.arc(21, 10, 3.5, 0, Math.PI * 2);
            ctx.fill();

            ctx.fillStyle = "#000000";
            ctx.fillRect(22, 8.5, 2.5, 3); // Visor

            // --- 6. FAROS LED ---
            ctx.fillStyle = "#ffffff";
            ctx.shadowBlur = 8;
            ctx.shadowColor = "#fef08a";
            ctx.fillRect(39, 3, 2, 2);
            ctx.fillRect(39, 15, 2, 2);
            ctx.shadowBlur = 0;

            // --- 7. PROPULSORES / FUEGO DINÁMICO (Escape de velocidad) ---
            if (state.isRunning) {
                const exhaustPulse = 5 + Math.sin(performance.now() * 0.06) * 5;
                const fireGrad = ctx.createLinearGradient(-12, 10, -2, 10);
                fireGrad.addColorStop(0, "rgba(239, 68, 68, 0)");
                fireGrad.addColorStop(0.5, "rgba(249, 115, 22, 0.85)");
                fireGrad.addColorStop(1, "rgba(253, 224, 71, 0.95)");

                ctx.fillStyle = fireGrad;
                ctx.beginPath();
                ctx.moveTo(-2, 7);
                ctx.lineTo(-2 - exhaustPulse, 10);
                ctx.lineTo(-2, 13);
                ctx.closePath();
                ctx.fill();

                if (Math.random() < 0.45) {
                    ctx.fillStyle = "#fde047";
                    ctx.fillRect(-6 - Math.random()*8, 6 + Math.random()*8, 2, 2);
                }
            }

            ctx.restore();
            
            // Label
            ctx.fillStyle = "rgba(255, 255, 255, 0.9)";
            ctx.font = "bold 9px 'Orbitron', sans-serif";
            ctx.fillText(type, x + 10, y - 7);
        }

        // Función de utilidad para ajustar brillo de colores hexadecimales
        function adjustColorBrightness(hex, percent) {
            let num = parseInt(hex.replace("#",""), 16),
                amt = Math.round(2.55 * percent),
                R = (num >> 16) + amt,
                G = (num >> 8 & 0x00FF) + amt,
                B = (num & 0x0000FF) + amt;
            return "#" + (0x1000000 + (R<255?R<0?0:R:255)*0x10000 + (G<255?G<0?0:G:255)*0x100 + (B<255?B<0?0:B:255)).toString(16).slice(1);
        }

        function drawScene() {
            const ctx = dom.ctx;
            const w = ctx.canvas.width; const h = ctx.canvas.height;
            
            // Fondo de césped / rejilla tecnológico
            ctx.fillStyle = CONSTANTS.colors.grass; ctx.fillRect(0,0,w,h);
            
            // Rejilla de fondo
            ctx.strokeStyle = "rgba(6, 182, 212, 0.035)";
            ctx.lineWidth = 1;
            for(let x=0; x<w; x+=30) {
                ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, h); ctx.stroke();
            }
            for(let y=0; y<h; y+=30) {
                if (y < 60 || y > 300) {
                    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
                }
            }

            // Pista asfaltada (más ancha)
            ctx.fillStyle = CONSTANTS.colors.asphalt; ctx.fillRect(0, 60, w, 240);
            
            // Pista grano / textura realista
            ctx.fillStyle = "rgba(255, 255, 255, 0.015)";
            for (let i = 0; i < 400; i++) {
                let nx = Math.random() * w;
                let ny = 60 + Math.random() * 240;
                ctx.fillRect(nx, ny, 1.5, 1.5);
            }
            
            // Pianos de carrera deportivos (Alternancia roja y blanca en los bordes)
            // Curbs Superior (y = 52)
            ctx.fillStyle = "#ffffff";
            ctx.fillRect(0, 52, w, 8);
            ctx.fillStyle = "#ef4444";
            for (let x = 0; x < w; x += 30) {
                if (Math.floor(x / 30) % 2 === 0) {
                    ctx.fillRect(x, 52, 15, 8);
                }
            }
            // Curbs Inferior (y = 300)
            ctx.fillStyle = "#ffffff";
            ctx.fillRect(0, 300, w, 8);
            ctx.fillStyle = "#ef4444";
            for (let x = 0; x < w; x += 30) {
                if (Math.floor(x / 30) % 2 === 0) {
                    ctx.fillRect(x, 300, 15, 8);
                }
            }

            // Líneas de límite
            ctx.strokeStyle = "rgba(6, 182, 212, 0.4)"; ctx.lineWidth = 2.5;
            ctx.beginPath(); ctx.moveTo(0, 60); ctx.lineTo(w, 60); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(0, 300); ctx.lineTo(w, 300); ctx.stroke();
            
            // Línea central divisoria (Dashed neón morada)
            ctx.strokeStyle = "rgba(168, 85, 247, 0.4)";
            ctx.setLineDash([24,24]); ctx.beginPath(); ctx.moveTo(0, 180); ctx.lineTo(w, 180); ctx.stroke(); ctx.setLineDash([]);

            // Línea de salida (Start line grid boxes)
            ctx.strokeStyle = "rgba(255,255,255,0.2)";
            ctx.lineWidth = 2;
            ctx.strokeRect(20, 95, 45, 50);
            ctx.strokeRect(20, 215, 45, 50);

            // Meta Resplandeciente (Finish Line Area)
            const finishX = metersToPx(state.truth.dist);
            ctx.fillStyle = "rgba(16, 185, 129, 0.08)"; 
            ctx.fillRect(finishX, 60, 40, 240);
            
            // Muro vertical láser de meta
            ctx.save();
            ctx.shadowBlur = 15;
            ctx.shadowColor = "#10b981";
            ctx.strokeStyle = "#10b981";
            ctx.lineWidth = 4;
            ctx.beginPath();
            ctx.moveTo(finishX, 60);
            ctx.lineTo(finishX, 300);
            ctx.stroke();
            ctx.restore();

            // Textura ajedrezada realista
            ctx.fillStyle = "rgba(255, 255, 255, 0.85)";
            for(let i=60; i<300; i+=12) {
                ctx.fillRect(finishX + 5, i, 6, 6);
                ctx.fillStyle = ctx.fillStyle === "rgba(255, 255, 255, 0.85)" ? "rgba(0, 0, 0, 0.85)" : "rgba(255, 255, 255, 0.85)";
                ctx.fillRect(finishX + 11, i, 6, 6);
            }

            // Autos y estelas
            let t = state.timeElapsed;
            let xA = state.truth.va * t;
            let xB = state.truth.v0b * t + 0.5 * state.truth.ab * t * t;

            // Dibujar Estelas neón de velocidad
            ctx.save();
            ctx.shadowBlur = 10;
            
            // Estela Red Auto A
            ctx.shadowColor = "#ef4444";
            ctx.strokeStyle = "rgba(239, 68, 68, 0.4)";
            ctx.lineWidth = 4;
            ctx.beginPath();
            ctx.moveTo(metersToPx(0) + 10, 110 + 10);
            ctx.lineTo(metersToPx(xA) + 10, 110 + 10);
            ctx.stroke();

            // Estela Blue Auto B
            ctx.shadowColor = "#3b82f6";
            ctx.strokeStyle = "rgba(59, 130, 246, 0.4)";
            ctx.beginPath();
            ctx.moveTo(metersToPx(0) + 10, 230 + 10);
            ctx.lineTo(metersToPx(xB) + 10, 230 + 10);
            ctx.stroke();
            ctx.restore();

            drawCar(metersToPx(xA), 110, CONSTANTS.colors.carA, "A");
            drawCar(metersToPx(xB), 230, CONSTANTS.colors.carB, "B");
        }

        function startRaceAnimation() {
            state.isRunning = true;
            state.timeElapsed = 0;
            sfx.playEngine();
            
            // Cerrar cajón móvil si está abierto y ocultar el botón flotante durante la simulación
            toggleMobileDrawer(false);
            document.getElementById("mobile-drawer-toggle").classList.add("hidden-force");

            // Deshabilitar botones de control
            dom.btnVal.disabled = true;
            dom.inA.disabled = true; dom.inB.disabled = true;
            
            // Deshabilitar radios de opciones
            const radios = document.querySelectorAll('input[type="radio"]');
            radios.forEach(r => r.disabled = true);
            const optButtons = document.querySelectorAll('.option-btn-wrapper');
            optButtons.forEach(b => b.style.pointerEvents = 'none');

            state.animId = requestAnimationFrame(loop);
        }

        function loop() {
            state.timeElapsed += 1/30; 
            drawScene();
            
            const tA = state.truth.ta;
            const tB = state.truth.tb;
            const maxT = Math.max(tA, tB) + 1.5;

            // Telemetría dinámica HUD
            const activeTime = Math.min(state.timeElapsed, Math.max(tA, tB));
            let xA = state.truth.va * activeTime;
            let xB = state.truth.v0b * activeTime + 0.5 * state.truth.ab * activeTime * activeTime;

            document.getElementById('tel-time').textContent = activeTime.toFixed(2);
            document.getElementById('tel-dist-a').textContent = Math.min(xA, state.truth.dist).toFixed(1);
            document.getElementById('tel-dist-b').textContent = Math.min(xB, state.truth.dist).toFixed(1);

            if (state.timeElapsed < maxT) {
                state.animId = requestAnimationFrame(loop);
            } else {
                state.isRunning = false;
                let winner = tA < tB ? "Auto A (Rojo)" : "Auto B (Azul)";
                if(Math.abs(tA - tB) < 0.1) winner = "Empate";
                
                dom.feedback.innerHTML = `🏁 ¡Carrera Terminada!<br>Ganador: ${winner}`;
                dom.feedback.className = "bg-cyan-950/90 text-cyan-400 border border-cyan-500/50 rounded-lg p-2.5 text-center text-xs font-bold min-h-[50px] flex items-center justify-center leading-tight shadow-md";

                // Mostrar botón flotante del cajón y abrirlo automáticamente para ver resultados en móviles
                document.getElementById("mobile-drawer-toggle").classList.remove("hidden-force");
                toggleMobileDrawer(true);
            }
        }

        function resetGame() {
            state.isRunning = false;
            state.phase = 1;
            state.timeElapsed = 0;
            if(state.animId) cancelAnimationFrame(state.animId);

            dom.inA.disabled = false; dom.inB.disabled = false;
            dom.btnVal.disabled = false;
            
            document.getElementById('tel-time').textContent = "0.00";
            document.getElementById('tel-dist-a').textContent = "0.00";
            document.getElementById('tel-dist-b').textContent = "0.00";

            dom.feedback.textContent = "Listo para iniciar. Ingresa tus respuestas.";
            dom.feedback.className = "bg-black/45 text-cyan-400 border border-slate-800/85 rounded-lg p-2.5 text-center text-xs font-bold min-h-[50px] flex items-center justify-center leading-tight";

            generateProblem();
            updatePhaseUI();
            drawScene();

            // Mostrar botón flotante del cajón y abrirlo para el nuevo ejercicio en móviles
            document.getElementById("mobile-drawer-toggle").classList.remove("hidden-force");
            toggleMobileDrawer(true);
        }

        // --- SISTEMA PANEL DESLIZANTE ---
        let isMobileDrawerOpen = false;

        function toggleMobileDrawer(forceState = null) {
            const wrapper = document.getElementById("panels-wrapper");
            const btn = document.getElementById("mobile-drawer-toggle");
            const btnText = document.getElementById("mobile-drawer-text");
            const btnIcon = document.getElementById("mobile-drawer-icon");
            
            if (forceState !== null) {
                isMobileDrawerOpen = forceState;
            } else {
                isMobileDrawerOpen = !isMobileDrawerOpen;
            }
            
            if (isMobileDrawerOpen) {
                wrapper.classList.remove("mobile-hidden");
                btnText.textContent = "Ocultar Panel";
                btnIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>`;
            } else {
                wrapper.classList.add("mobile-hidden");
                btnText.textContent = "Ver Datos y Resolver";
                btnIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>`;
            }
        }

        // --- INTERFAZ SIDEBAR ---
        function toggleSidebar() {
            const sidePanel = document.getElementById('side-panel');
            const toggleIcon = document.getElementById('toggleIcon');
            const togglePanelBtn = document.getElementById('togglePanelBtn');
            const mainContainer = document.getElementById('main-container');
            
            if (sidePanel.style.transform === 'translateX(-290px)') {
                // Mostrar
                sidePanel.style.transform = 'translateX(0px)';
                togglePanelBtn.style.left = '286px';
                toggleIcon.style.transform = 'rotate(0deg)';
                if (mainContainer) mainContainer.style.left = '300px';
            } else {
                // Ocultar
                sidePanel.style.transform = 'translateX(-290px)';
                togglePanelBtn.style.left = '12px';
                toggleIcon.style.transform = 'rotate(180deg)';
                if (mainContainer) mainContainer.style.left = '20px';
            }
        }

        function toggleHelpModal() {
            const modal = document.getElementById('help-modal');
            modal.classList.toggle('hidden');
        }

        // Init
        dom.btnVal.addEventListener('click', () => {
            sfx.playTick();
            const ans = getUserAnswer();
            if(!ans) {
                const msg = state.phase === 1 ? "Ingresa números válidos." : "Selecciona una opción antes de validar.";
                dom.feedback.textContent = msg; 
                dom.feedback.className = "bg-red-950/90 text-red-400 border border-red-500/50 rounded-lg p-2.5 text-center text-xs font-bold min-h-[50px] flex items-center justify-center leading-tight shadow-md";
                sfx.playFailure();
                return;
            }
            validateRound(ans.a, ans.b);
        });
        dom.btnNew.addEventListener('click', () => {
            sfx.playTick();
            resetGame();
        });
        window.onload = resetGame;

    </script>
</body>
</html>
