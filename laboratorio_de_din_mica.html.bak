<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laboratorio de Dinámica 2.5D: 2da Ley de Newton</title>
    <!-- Tailwind CSS para diseño moderno -->
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #03050d;
            overflow: hidden;
        }
        .font-orbitron {
            font-family: 'Orbitron', sans-serif;
        }
        /* Glassmorphism de última generación */
        .glass-panel {
            background: rgba(8, 12, 28, 0.85);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 162, 255, 0.15);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover {
            background: rgba(0, 162, 255, 0.05);
            border-color: rgba(0, 162, 255, 0.3);
        }
        /* Neon glowing lines & buttons */
        .neon-border-blue {
            box-shadow: 0 0 10px rgba(0, 162, 255, 0.4);
        }
        .neon-text-blue {
            text-shadow: 0 0 8px rgba(0, 162, 255, 0.6);
        }
        .neon-text-green {
            text-shadow: 0 0 8px rgba(16, 185, 129, 0.6);
        }
        .neon-text-red {
            text-shadow: 0 0 8px rgba(239, 68, 68, 0.6);
        }
        /* Custom scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.2);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(0, 162, 255, 0.4);
            border-radius: 2px;
        }
        /* Sliding classes (for robust panel hiding) */
        .left-panel-hidden {
            transform: translateX(-275px) !important;
        }
        .right-panel-hidden {
            transform: translateX(275px) !important;
        }
        /* Input styling */
        input[type="number"]::-webkit-inner-spin-button,
        input[type="number"]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        /* Botón de despliegue móvil */
        #mobile-drawer-toggle {
            position: fixed !important;
            bottom: 16px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 40;
            display: none !important; /* Oculto en PC */
            transition: bottom 0.4s cubic-bezier(0.25, 1, 0.5, 1), transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.2s, box-shadow 0.2s !important;
        }
        .hidden-force {
            display: none !important;
        }

        /* --- ESTILOS RESPONSIVOS PARA MÓVILES Y TABLETS --- */
        @media (max-width: 768px) {
            /* Mostrar botón de despliegue */
            #mobile-drawer-toggle {
                display: flex !important;
            }

            /* 1. Contenedor de Paneles en la parte inferior */
            #panels-wrapper {
                position: absolute !important;
                left: 8px !important;
                right: 8px !important;
                bottom: 8px !important;
                top: auto !important;
                width: auto !important;
                height: auto !important;
                max-height: 48vh !important;
                display: flex !important;
                flex-direction: column !important;
                gap: 8px !important;
                overflow-y: auto !important;
                pointer-events: auto !important;
                z-index: 30 !important;
                padding-right: 4px;
                padding-bottom: 74px !important;
                transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease-out !important;
            }

            #panels-wrapper.mobile-hidden {
                transform: translateY(120%) !important;
                opacity: 0 !important;
                pointer-events: none !important;
            }

            /* Ocultar botones de pestañas en móviles */
            #left-panel > div:nth-child(2),
            #right-panel > div:nth-child(2) {
                display: none !important;
            }

            /* Paneles izquierdo y derecho apilados */
            #left-panel, #right-panel {
                position: relative !important;
                left: auto !important;
                right: auto !important;
                top: auto !important;
                bottom: auto !important;
                width: 100% !important;
                height: auto !important;
                transform: none !important;
                margin: 0 !important;
                padding: 0 !important;
                display: flex !important;
                flex-direction: column !important;
                pointer-events: auto !important;
                transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease-out !important;
            }

            #left-panel.left-panel-hidden, #right-panel.right-panel-hidden {
                transform: translateY(150%) !important;
                opacity: 0 !important;
                pointer-events: none !important;
                position: absolute !important;
            }

            /* Ajustar ancho y alto de los paneles glass */
            #left-panel .glass-panel, #right-panel .glass-panel {
                width: 100% !important;
                height: auto !important;
                min-height: unset !important;
                padding: 12px !important;
                border-radius: 16px !important;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.6) !important;
            }

            /* 2. HUD Superior Compacto */
            .hud-top-bar {
                top: 8px !important;
                left: 8px !important;
                right: 8px !important;
                gap: 6px !important;
                justify-content: center !important;
            }

            .hud-title-block {
                display: none !important; /* Ocultar título para ganar espacio */
            }

            .hud-mode-block {
                padding: 4px 8px !important;
                border-radius: 10px !important;
            }

            .hud-mode-block span {
                font-size: 7px !important;
            }

            .hud-score-block {
                padding: 4px 6px !important;
                gap: 8px !important;
                border-radius: 10px !important;
            }

            .hud-score-block > div {
                padding-left: 6px !important;
                padding-right: 6px !important;
            }

            .hud-score-block small {
                font-size: 7px !important;
            }

            .hud-score-block span {
                font-size: 10px !important;
            }

            /* 3. Controles de Cámara Centrados y más pequeños, posicionados debajo del HUD */
            .camera-controls {
                top: 96px !important;
                padding: 4px 8px !important;
                border-radius: 10px !important;
                gap: 4px !important;
            }

            .camera-controls button {
                width: 30px !important;
                height: 30px !important;
            }

            .camera-controls svg {
                width: 14px !important;
                height: 14px !important;
            }

            .camera-controls span {
                height: 16px !important;
            }

            /* 4. Elementos Internos de Paneles */
            #variables-dadas {
                grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
                max-height: none !important;
                overflow-y: visible !important;
                gap: 6px !important;
            }

            #variables-dadas .glass-card {
                padding: 4px 6px !important;
                border-radius: 8px !important;
            }

            #variables-dadas span {
                font-size: 10px !important;
            }

            #left-panel a {
                padding: 4px 8px !important;
                font-size: 8px !important;
                border-radius: 8px !important;
            }

            #manual-input-wrapper {
                border-radius: 10px !important;
            }

            #manual-input {
                font-size: 14px !important;
                padding-top: 6px !important;
                padding-bottom: 6px !important;
            }

            #unit-label {
                font-size: 10px !important;
                right: 8px !important;
            }

            #options-container {
                display: grid !important;
                grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
                gap: 6px !important;
            }

            #options-container.hidden {
                display: none !important;
            }

            #options-container > div {
                height: 30px !important;
                padding: 4px 8px !important;
                border-radius: 8px !important;
            }

            #options-container span {
                font-size: 10px !important;
            }

            #feedback-panel {
                min-height: unset !important;
                padding: 8px !important;
                border-radius: 10px !important;
            }

            #feedback-title {
                font-size: 8.5px !important;
            }

            #feedback {
                font-size: 10.5px !important;
            }

            #correct-answer-display {
                font-size: 9px !important;
            }

            #lanzarBtn, #resetBtn {
                padding: 8px 12px !important;
                font-size: 10px !important;
                border-radius: 10px !important;
            }

            #lanzarBtn svg, #resetBtn svg {
                width: 12px !important;
                height: 12px !important;
            }

            /* 5. Escalamiento de Badges Flotantes */
            #badge-m1, #badge-m2 {
                font-size: 7.5px !important;
                padding: 2px 5px !important;
                border-radius: 5px !important;
            }
        }
    </style>

    <!-- Librerías de visualización -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
</head>
<body class="w-full h-screen text-gray-100 relative select-none">

    <!-- CONTENEDOR DE LA ESCENA 3D (Fondo del Laboratorio) -->
    <div id="canvas-container" class="absolute inset-0 w-full h-full z-0"></div>

    <!-- ETIQUETAS FLOTANTES DE ALTA VISIBILIDAD PARA LAS MASAS -->
    <div id="badge-m1" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-red-600 to-rose-500 text-white font-orbitron font-black text-xs px-2.5 py-1 rounded-lg shadow-[0_0_15px_rgba(239,68,68,0.6)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        M1
    </div>
    <div id="badge-m2" class="absolute pointer-events-none hidden z-10 transform -translate-x-1/2 -translate-y-1/2 bg-gradient-to-r from-blue-600 to-indigo-500 text-white font-orbitron font-black text-xs px-2.5 py-1 rounded-lg shadow-[0_0_15px_rgba(59,130,246,0.6)] border border-white/20 select-none uppercase tracking-wider transition-all duration-75">
        M2
    </div>

    <!-- INTERFAZ HUD SUPERIOR (Dashboard de Progreso) -->
    <div class="hud-top-bar absolute top-3 left-3 right-3 z-10 pointer-events-none flex flex-wrap justify-between items-center gap-2">
        <!-- Izquierda: Título Principal -->
        <div class="hud-title-block glass-panel rounded-xl px-4 py-2 pointer-events-auto flex items-center gap-3 shadow-2xl">
            <div class="w-8 h-8 bg-gradient-to-tr from-blue-500 to-cyan-400 rounded-lg flex items-center justify-center shadow-lg neon-border-blue">
                <svg class="w-4 h-4 text-gray-950" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                </svg>
            </div>
            <div>
                <h1 class="font-orbitron text-xs font-black tracking-wider text-cyan-400 leading-none">DINÁMICA 2.5D</h1>
                <p class="text-[8px] text-gray-400 font-bold uppercase tracking-widest leading-none mt-1">Plataforma de Simulación Física</p>
            </div>
        </div>

        <!-- HUD Superior Central: Indicador de Sentido de Movimiento Físico -->
        <div class="hud-mode-block glass-panel rounded-xl px-4 py-2 pointer-events-auto flex items-center gap-3 shadow-2xl border border-cyan-500/20">
            <span class="text-[8px] text-gray-400 font-bold uppercase tracking-widest block font-orbitron">Tendencia del Movimiento:</span>
            <div class="flex items-center gap-1.5">
                <span id="motion-arrow" class="text-xs animate-pulse text-cyan-400">➔</span>
                <span id="motion-text" class="font-orbitron text-xs font-black text-cyan-400 uppercase tracking-wider leading-none">Cargando...</span>
            </div>
        </div>

        <!-- Derecha: Marcadores de Juego -->
        <div class="hud-score-block glass-panel rounded-xl p-1.5 pointer-events-auto flex items-center gap-6 shadow-2xl">
            <div class="px-3 border-r border-gray-800/80 text-center">
                <small class="text-gray-400 text-[8px] font-bold block tracking-wider leading-none">PUNTUACIÓN</small>
                <span id="score-display" class="font-orbitron text-sm font-black text-emerald-400 leading-none block mt-1 neon-text-green">0</span>
            </div>
            <div class="px-3 border-r border-gray-800/80 text-center">
                <small class="text-gray-400 text-[8px] font-bold block tracking-wider leading-none">INTENTOS RESTANTES</small>
                <div id="hearts-container" class="flex gap-0.5 justify-center mt-1">
                    <!-- Corazones / Intentos Dinámicos -->
                </div>
            </div>
            <div class="px-3 text-center">
                <small class="text-gray-400 text-[8px] font-bold block tracking-wider leading-none">FASE DE JUEGO</small>
                <span id="phase-badge" class="font-orbitron text-xs font-black text-yellow-400 leading-none block mt-1 bg-yellow-950/40 px-2 py-0.5 rounded border border-yellow-800/50">1 - Entrada Libre</span>
            </div>
        </div>
    </div>

    <!-- CONTENEDOR ENVOLVENTE DE PANELES (Para control responsivo en móviles) -->
    <div id="panels-wrapper" class="absolute inset-0 pointer-events-none z-20 flex justify-between mobile-hidden">
        <!-- PANEL FLOTANTE IZQUIERDO (Datos del Ejercicio) con cajón deslizable unificado -->
        <div id="left-panel" class="absolute left-3 top-20 bottom-3 z-20 flex flex-row items-start transition-transform duration-500 ease-out pointer-events-none" style="width: 310px;">
            
            <!-- Panel Principal de Variables -->
            <div class="glass-panel rounded-2xl p-4 pointer-events-auto flex flex-col gap-3.5 shadow-2xl w-[260px] h-full justify-between border border-cyan-500/10">
                <div class="flex flex-col gap-3.5">
                    <!-- 0. Botón Volver -->
                    <a href="./index.html" class="glass-card rounded-xl p-2 flex items-center justify-center gap-1.5 text-[8.5px] text-cyan-400 hover:text-cyan-300 font-bold uppercase tracking-wider font-orbitron transition-all">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                        Volver al Inicio
                    </a>
                    <div>
                        <span class="text-[9px] font-extrabold text-cyan-400 uppercase tracking-widest font-orbitron block mb-2">Variables Conocidas</span>
                        <div id="variables-dadas" class="grid grid-cols-2 gap-2">
                            <!-- Inyectados dinámicamente -->
                        </div>
                    </div>
                </div>

                <!-- Interruptor para Visualizar Fuerzas (DCL) -->
                <div class="border-t border-gray-800/80 pt-3 flex items-center justify-between">
                    <div class="flex flex-col">
                        <span class="text-[10px] font-bold text-gray-300">Mostrar Vectores (DCL)</span>
                        <span class="text-[8px] text-gray-500">Muestra las fuerzas físicas en 2.5D</span>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" id="toggle-fbd" class="sr-only peer" checked>
                        <div class="w-9 h-5 bg-gray-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-gray-400 after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-cyan-500 peer-checked:after:bg-gray-950"></div>
                    </label>
                </div>
            </div>

            <!-- Pestaña de Ocultar/Mostrar Acoplada al Panel -->
            <div class="pointer-events-auto ml-1.5 mt-6 self-start">
                <button id="toggle-panel-btn" class="w-10 h-10 bg-gray-950/90 hover:bg-cyan-500 text-cyan-400 hover:text-gray-950 border border-cyan-500/20 rounded-xl flex items-center justify-center transition-all shadow-xl backdrop-blur-md">
                    <svg id="toggle-panel-icon" class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 19l-7-7 7-7" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- PANEL FLOTANTE DERECHO (Resolución y Feedback) -->
        <div id="right-panel" class="absolute right-3 top-20 bottom-3 z-20 flex flex-row-reverse items-start transition-transform duration-500 ease-out pointer-events-none" style="width: 310px;">
            
            <!-- Panel Principal de Resolución -->
            <div class="glass-panel rounded-2xl p-4 pointer-events-auto flex flex-col gap-3.5 shadow-2xl w-[260px] h-full justify-between border border-cyan-500/10">
                <div class="flex flex-col gap-3.5">
                    <!-- Entrada de Datos Principal -->
                    <div>
                        <span id="input-title" class="text-[9.5px] font-extrabold text-yellow-400 uppercase tracking-widest font-orbitron block mb-2">Resolver Incógnita:</span>
                        
                        <!-- Fase 1: Entrada Numérica Libre -->
                        <div id="manual-input-wrapper" class="relative rounded-xl overflow-hidden border border-cyan-500/40 shadow-inner bg-black/40">
                            <input type="number" id="manual-input" step="0.1" 
                                   class="w-full bg-transparent text-center font-orbitron text-base font-black py-2 pl-3 pr-10 focus:outline-none focus:ring-1 focus:ring-cyan-400 text-yellow-300 transition-all placeholder-gray-600" 
                                   placeholder="0.0">
                            <span id="unit-label" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-cyan-400 font-bold font-orbitron text-xs">kg</span>
                        </div>

                        <!-- Fases 2 y 3: Opciones de Opción Múltiple -->
                        <div id="options-container" class="hidden flex flex-col gap-2 mt-1">
                            <!-- Inyectado dinámicamente -->
                        </div>
                    </div>
                </div>

                <div class="flex flex-col gap-3.5">
                    <!-- Panel de Mensajes de Feedback -->
                    <div id="feedback-panel" class="bg-black/30 rounded-xl p-3 shadow-inner flex flex-col justify-center border-l-4 border-cyan-500 transition-all duration-300 min-h-[80px]">
                        <p id="feedback-title" class="text-[10px] font-black text-cyan-400 uppercase tracking-widest font-orbitron mb-1">Diagnóstico de Sistema</p>
                        <p id="feedback" class="text-xs text-gray-300 leading-snug">Cargando el laboratorio de masas vinculadas...</p>
                        <p id="correct-answer-display" class="text-[10px] text-emerald-400 font-orbitron font-semibold mt-1 leading-none"></p>
                    </div>

                    <!-- Botones de Control de Simulación -->
                    <div class="flex flex-col gap-2">
                        <!-- Botón Principal Simular -->
                        <button id="lanzarBtn" class="w-full bg-gradient-to-r from-blue-600 to-cyan-500 hover:from-blue-700 hover:to-cyan-600 active:scale-95 text-gray-950 font-black py-2.5 px-4 rounded-xl shadow-lg transition-all text-xs uppercase tracking-wider font-orbitron flex items-center justify-center gap-2">
                            <svg class="w-4 h-4 text-gray-950" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                            </svg>
                            Iniciar Simulación
                        </button>
                        <!-- Botón Resetear / Siguiente -->
                        <button id="resetBtn" class="w-full bg-gray-900/80 hover:bg-gray-800 text-gray-200 hover:text-white border border-gray-800 font-bold py-2 px-4 rounded-xl transition-all text-[10px] uppercase tracking-widest font-orbitron flex items-center justify-center gap-1.5">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                            </svg>
                            Siguiente Ejercicio
                        </button>
                    </div>
                </div>
            </div>

            <!-- Pestaña de Ocultar/Mostrar Acoplada al Panel Derecho -->
            <div class="pointer-events-auto mr-1.5 mt-6 self-start">
                <button id="toggle-right-panel-btn" class="w-10 h-10 bg-gray-950/90 hover:bg-cyan-500 text-cyan-400 hover:text-gray-950 border border-cyan-500/20 rounded-xl flex items-center justify-center transition-all shadow-xl backdrop-blur-md">
                    <svg id="toggle-right-panel-icon" class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- BOTÓN FLOTANTE PARA DESPLEGAR PANEL EN MÓVILES -->
    <button id="mobile-drawer-toggle" onclick="toggleMobileDrawer()" class="fixed bottom-4 left-1/2 transform -translate-x-1/2 z-40 hidden font-orbitron font-extrabold text-[10px] uppercase tracking-wider px-4 py-2.5 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-gray-950 rounded-xl shadow-[0_0_20px_rgba(0,243,255,0.5)] border border-cyan-300/30 transition-all duration-300 items-center gap-2 pointer-events-auto">
        <svg id="mobile-drawer-icon" class="w-4.5 h-4.5 text-gray-950" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        <span id="mobile-drawer-text">Ver Datos y Resolver</span>
    </button>

    <!-- CONTROLES CENTRALES SUPERIORES (Cámara y Ayuda) -->
    <div class="camera-controls absolute top-20 left-1/2 transform -translate-x-1/2 z-10 pointer-events-auto flex items-center gap-2 bg-gray-950/90 border border-cyan-500/20 rounded-xl px-2.5 py-1.5 shadow-xl backdrop-blur-md">
        <!-- Botón Ayuda -->
        <button onclick="toggleHelpModal()" class="w-9 h-9 bg-gray-900/60 hover:bg-cyan-500 hover:text-gray-950 text-cyan-400 border border-cyan-500/10 hover:border-cyan-400 rounded-lg flex items-center justify-center transition-all" title="Teoría y Fórmulas">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364.364l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
        </button>

        <!-- Separador -->
        <span class="w-[1px] h-5 bg-gray-800/80 mx-1"></span>

        <!-- Botones de Zoom -->
        <div class="flex items-center gap-1.5">
            <!-- Zoom + -->
            <button onclick="adjustZoom(-1.5)" class="w-9 h-9 bg-gray-900/60 hover:bg-cyan-500 hover:text-gray-950 text-cyan-400 border border-cyan-500/10 hover:border-cyan-400 rounded-lg flex items-center justify-center transition-all" title="Acercar Cámara">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
            </button>
            <!-- Zoom default (home) -->
            <button onclick="changeZoom(4.5)" class="w-9 h-9 bg-gray-900/60 hover:bg-cyan-500 hover:text-gray-950 text-cyan-400 border border-cyan-500/10 hover:border-cyan-400 rounded-lg flex items-center justify-center transition-all" title="Restaurar Cámara">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
            </button>
            <!-- Zoom - -->
            <button onclick="adjustZoom(1.5)" class="w-9 h-9 bg-gray-900/60 hover:bg-cyan-500 hover:text-gray-950 text-cyan-400 border border-cyan-500/10 hover:border-cyan-400 rounded-lg flex items-center justify-center transition-all" title="Alejar Cámara">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
                </svg>
            </button>
        </div>
    </div>

    <!-- MODAL DE TEORÍA Y FÓRMULAS -->
    <div id="help-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-md hidden pointer-events-auto">
        <div class="glass-panel w-full max-w-lg rounded-3xl p-6 shadow-2xl relative border border-cyan-500/30">
            <button onclick="toggleHelpModal()" class="absolute top-4 right-4 text-gray-400 hover:text-white text-2xl font-bold transition-all">&times;</button>
            <h2 class="font-orbitron text-sm font-bold text-cyan-400 mb-4 flex items-center gap-2 tracking-wide uppercase">
                <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
                Dinámica de Masas Vinculadas (2.5D)
            </h2>
            
            <div class="space-y-4 text-xs text-gray-300 overflow-y-auto max-h-[60vh] pr-2 custom-scrollbar">
                <p class="leading-relaxed">El sistema estudia el comportamiento de dos bloques unidos por una cuerda ideal inextensible a través de una polea sin masa ni fricción en planos inclinados.</p>
                
                <div class="bg-black/40 p-3 rounded-xl border border-gray-800">
                    <h3 class="font-bold text-cyan-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Leyes de Movimiento:</h3>
                    <p class="leading-relaxed">La aceleración conjunta del sistema se calcula según las componentes de fuerzas:</p>
                    <p class="font-mono text-center text-yellow-300 my-2 text-xs">
                        a = [ m₂·g·sin(θ₂) - m₁·g·sin(θ₁) - f₁ - f₂ ] / (m₁ + m₂)
                    </p>
                    <p class="text-[9.5px] text-gray-400 text-center mt-1">Donde la gravedad se redondea a <b>g = 9.8 m/s²</b>.</p>
                </div>

                <div class="bg-black/40 p-3 rounded-xl border border-gray-800">
                    <h3 class="font-bold text-cyan-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Fuerzas de Fricción (Dinámica):</h3>
                    <p class="font-mono text-yellow-300 text-xs mb-1">f₁ = μ₁ · m₁ · g · cos(θ₁)</p>
                    <p class="font-mono text-yellow-300 text-xs">f₂ = μ₂ · m₂ · g · cos(θ₂)</p>
                    <p class="text-[9.5px] text-gray-400 mt-1.5">Nota: Si la masa 2 cuelga verticalmente, su ángulo θ₂ = 90°, lo que implica sin(90°) = 1 y cos(90°) = 0 (f₂ = 0).</p>
                </div>

                <div class="bg-black/40 p-3 rounded-xl border border-gray-800">
                    <h3 class="font-bold text-cyan-400 mb-1 font-orbitron text-[9px] uppercase tracking-wider">Diagrama de Cuerpo Libre (DCL):</h3>
                    <ul class="list-disc pl-4 space-y-1 mt-1 text-[11px]">
                        <li><b class="text-red-400">Peso (P):</b> Actúa verticalmente hacia abajo (<i>m</i> · <i>g</i>).</li>
                        <li><b class="text-emerald-400">Fuerza Normal (N):</b> Perpendicular a la rampa de contacto (<i>m</i> · <i>g</i> · cos <i>θ</i>).</li>
                        <li><b class="text-blue-400">Tensión (T):</b> Fuerza de tracción transmitida por la cuerda.</li>
                        <li><b class="text-yellow-400">Fuerza de Roce (f):</b> Opuesta a la dirección del movimiento físico.</li>
                    </ul>
                </div>
            </div>
            
            <div class="mt-4 pt-3 border-t border-gray-800">
                <button onclick="toggleHelpModal()" class="w-full bg-gradient-to-r from-blue-600 to-cyan-500 text-gray-950 hover:from-blue-500 hover:to-cyan-400 py-2.5 rounded-xl font-bold font-orbitron uppercase text-[10px] tracking-wider transition-all">Entendido</button>
            </div>
        </div>
    </div>

    <!-- LOGICA DEL SIMULADOR -->
    <script>
        // --- SINTETIZADOR DE EFECTOS DE SONIDO (WEB AUDIO API) ---
        class SoundFX {
            constructor() {
                this.ctx = null;
            }
            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
            }
            playClank() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(140, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(30, this.ctx.currentTime + 0.2);
                gain.gain.setValueAtTime(0.4, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.2);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.2);
            }
            playHum(accelerate = false) {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(80, this.ctx.currentTime);
                if (accelerate) {
                    osc.frequency.linearRampToValueAtTime(180, this.ctx.currentTime + 1.5);
                } else {
                    osc.frequency.linearRampToValueAtTime(100, this.ctx.currentTime + 1.0);
                }
                gain.gain.setValueAtTime(0.12, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 1.2);
                osc.start();
                osc.stop(this.ctx.currentTime + 1.2);
            }
            playSuccess() {
                this.init();
                const chord = [261.63, 329.63, 392.00, 523.25]; // Do Mayor
                chord.forEach((freq, i) => {
                    const osc = this.ctx.createOscillator();
                    const gain = this.ctx.createGain();
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(freq, this.ctx.currentTime + i * 0.08);
                    gain.gain.setValueAtTime(0.15, this.ctx.currentTime + i * 0.08);
                    gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + i * 0.08 + 0.5);
                    osc.start(this.ctx.currentTime + i * 0.08);
                    osc.stop(this.ctx.currentTime + i * 0.08 + 0.5);
                });
            }
            playFailure() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(130, this.ctx.currentTime);
                osc.frequency.linearRampToValueAtTime(75, this.ctx.currentTime + 0.5);
                gain.gain.setValueAtTime(0.2, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.5);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.5);
            }
            playTick() {
                this.init();
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.type = 'sine';
                osc.frequency.setValueAtTime(800, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(400, this.ctx.currentTime + 0.05);
                gain.gain.setValueAtTime(0.08, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.05);
                osc.start();
                osc.stop(this.ctx.currentTime + 0.05);
            }
        }
        const sfx = new SoundFX();

        // --- MOTOR FÍSICO 2.5D CON THREE.JS ---
        let scene, camera, renderer;
        const GRAVITY = 9.8; // Gravedad simplificada para facilitar cálculos escolares
        
        // Elementos tridimensionales de la escena
        let pulleyGroup, supportColumn, pulleyBracket, wedgeLeft, rope;
        let ropeGeometry;
        let wedgeLeftHatching;
        let block1, block2;
        
        // Elementos DCL (Vectores de fuerzas como flechas 3D)
        let arrowsM1 = {}, arrowsM2 = {};

        // Sistema de Partículas para las chispas de fricción
        let particleSystem;
        const particleCount = 60;
        const particlesData = [];

        // Parámetros de simulación física y del problema activo
        let problemParameters = {};
        let missingVariableType = "";
        let correctAnswer = 0;
        let attemptsLeft = 3;
        let currentScore = 0;
        let currentOptions = [];
        const ABS_TOLERANCE = 0.15; // Tolerancia numérica para 1 decimal

        const variableKeys = ["m1", "m2", "ang1", "ang2", "mu1", "mu2", "a"];
        const variableMeta = {
            m1: { label: "Masa 1 (m₁)", unit: "kg" },
            m2: { label: "Masa 2 (m₂)", unit: "kg" },
            ang1: { label: "Ángulo 1 (θ₁)", unit: "°" },
            ang2: { label: "Ángulo 2 (θ₂)", unit: "°" },
            mu1: { label: "Fricción 1 (μ₁)", unit: "" },
            mu2: { label: "Fricción 2 (μ₂)", unit: "" },
            a: { label: "Acel. (a)", unit: "m/s²" }
        };

        // Variables de estado de simulación física
        let isSimulating = false;
        let simTime = 0;
        let displacement = 0;
        let initialM1Pos = new THREE.Vector3();
        let initialM2Pos = new THREE.Vector3();
        let simulatedAcceleration = 0;
        let simDirection = 1; // 1 = m2 tira de m1 (derecha), -1 = m1 tira de m2 (izquierda), 0 = quieto
        let mouseX = 0, mouseY = 0;
        let isPanelHidden = false; // Estado de visibilidad de panel izquierdo
        let cameraZoomZ = 4.5; // Zoom base en Z
        let cameraPanX = 0; // Paneo horizontal de la cámara
        let smoothPanX = 0; // Paneo horizontal suavizado

        function changeZoom(zVal) {
            if (typeof sfx !== 'undefined' && sfx.playTick) sfx.playTick();
            cameraZoomZ = zVal;
            cameraPanX = 0;
            smoothPanX = 0;
        }

        function adjustZoom(amount) {
            let targetZ = cameraZoomZ + amount;
            if (targetZ < 3.0) targetZ = 3.0;
            if (targetZ > 15.0) targetZ = 15.0; // Límite de alejamiento ampliado
            if (targetZ !== cameraZoomZ) {
                changeZoom(targetZ);
            }
        }

        // --- SISTEMA DE PANEO HORIZONTAL DE CÁMARA (Para celulares y arrastre táctil/mouse) ---
        let isPointerDragging = false;
        let previousPointerX = 0;

        window.addEventListener("pointerdown", (e) => {
            if (!e.target || typeof e.target.closest !== "function" || e.target.closest("canvas") === null) return;
            isPointerDragging = true;
            previousPointerX = e.clientX;
        });

        window.addEventListener("pointermove", (e) => {
            if (!isPointerDragging) return;
            const deltaX = e.clientX - previousPointerX;
            previousPointerX = e.clientX;
            const sensitivity = 0.0055 * (cameraZoomZ / 4.5);
            cameraPanX -= deltaX * sensitivity;
            if (cameraPanX < -4.5) cameraPanX = -4.5;
            if (cameraPanX > 4.5) cameraPanX = 4.5;
        });

        window.addEventListener("pointerup", () => { isPointerDragging = false; });
        window.addEventListener("pointercancel", () => { isPointerDragging = false; });

        // Ajustar el canvas al tamaño del contenedor
        function onWindowResize() {
            const container = document.getElementById("canvas-container");
            if (!container) return;
            const w = container.clientWidth;
            const h = container.clientHeight;
            camera.aspect = w / h;
            camera.updateProjectionMatrix();
            renderer.setSize(w, h);
        }

        // Registrar posición del mouse para el efecto de paralaje 2.5D
        window.addEventListener("mousemove", (e) => {
            mouseX = (e.clientX / window.innerWidth) - 0.5;
            mouseY = (e.clientY / window.innerHeight) - 0.5;
        });

        // --- INICIALIZACIÓN DE LA ESCENA 3D ---
        function init3D() {
            const container = document.getElementById("canvas-container");
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x020409);
            scene.fog = new THREE.FogExp2(0x020409, 0.045);

            // Cámara de proyección diagramática lateral (Estilo 2.5D)
            camera = new THREE.PerspectiveCamera(32, container.clientWidth / container.clientHeight, 0.1, 100);
            camera.position.set(0, 1.3, 4.5);

            // Renderer moderno con sombras suaves habilitadas
            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            container.appendChild(renderer.domElement);

            // --- LUCES DE LABORATORIO FUTURISTA ---
            const ambient = new THREE.AmbientLight(0xffffff, 0.18);
            scene.add(ambient);

            // Luz direccional superior con sombras
            const dirLight = new THREE.DirectionalLight(0x00a2ff, 1.8);
            dirLight.position.set(2, 6, 4);
            dirLight.castShadow = true;
            dirLight.shadow.mapSize.width = 1024;
            dirLight.shadow.mapSize.height = 1024;
            dirLight.shadow.bias = -0.0005;
            scene.add(dirLight);

            // Luz de siluetas magenta/rojo
            const fillLight = new THREE.DirectionalLight(0xff0066, 0.5);
            fillLight.position.set(-4, 2, 2);
            scene.add(fillLight);

            // Luz neón sobre la polea
            const neonLight = new THREE.PointLight(0x00f3ff, 2.5, 6);
            neonLight.position.set(0, 1.8, 0.15);
            scene.add(neonLight);

            // --- ESCENARIO ---
            // Suelo plano de laboratorio
            const floorGeo = new THREE.PlaneGeometry(16, 16);
            const floorMat = new THREE.MeshStandardMaterial({ 
                color: 0x050816, 
                roughness: 0.9, 
                metalness: 0.1 
            });
            const floor = new THREE.Mesh(floorGeo, floorMat);
            floor.rotation.x = -Math.PI / 2;
            floor.receiveShadow = true;
            scene.add(floor);

            // Rejilla de fondo (Holografía azul)
            const grid = new THREE.GridHelper(16, 32, 0x00a2ff, 0x071128);
            grid.position.y = 0.005;
            scene.add(grid);

            // --- SOPORTE CENTRAL Y POLEA ---
            buildPulleyAssembly();

            // --- CUERDA NEÓN PREMIUM ---
            const ropeMat = new THREE.LineBasicMaterial({ 
                color: 0x00f3ff, 
                linewidth: 3 
            });
            ropeGeometry = new THREE.BufferGeometry();
            rope = new THREE.Line(ropeGeometry, ropeMat);
            scene.add(rope);

            // --- SISTEMA DE PARTÍCULAS PARA CHISPAS ---
            buildSparkSystem();

            window.addEventListener("resize", onWindowResize);
        }

        function buildPulleyAssembly() {
            const structureMat = new THREE.MeshStandardMaterial({ 
                color: 0x0c132c, 
                roughness: 0.4, 
                metalness: 0.8 
            });
            const steelMat = new THREE.MeshStandardMaterial({ 
                color: 0x00f3ff, 
                emissive: 0x003344,
                roughness: 0.1, 
                metalness: 0.9 
            });

            // Soporte central inferior (columna completa desde el suelo a la polea)
            const columnGeo = new THREE.CylinderGeometry(0.04, 0.05, 1.8, 16);
            supportColumn = new THREE.Mesh(columnGeo, structureMat);
            supportColumn.position.set(0, 0.9, -0.1);
            supportColumn.castShadow = true;
            scene.add(supportColumn);

            // Polea móvil
            pulleyGroup = new THREE.Group();
            pulleyGroup.position.set(0, 1.8, 0);
            scene.add(pulleyGroup);

            const wheelGeo = new THREE.CylinderGeometry(0.18, 0.18, 0.06, 32);
            wheelGeo.rotateX(Math.PI / 2);
            const wheel = new THREE.Mesh(wheelGeo, steelMat);
            wheel.castShadow = true;
            pulleyGroup.add(wheel);

            // Radios para ver el giro
            for (let i = 0; i < 4; i++) {
                const spoke = new THREE.Mesh(new THREE.CylinderGeometry(0.01, 0.01, 0.35, 8), structureMat);
                spoke.rotation.z = (Math.PI / 4) * i;
                pulleyGroup.add(spoke);
            }

            // Perno central
            const bolt = new THREE.Mesh(new THREE.CylinderGeometry(0.025, 0.025, 0.12, 16), structureMat);
            bolt.rotation.x = Math.PI / 2;
            bolt.position.set(0, 1.8, 0);
            scene.add(bolt);
        }

        // --- SISTEMA DE PARTÍCULAS (Chispas) ---
        function buildSparkSystem() {
            const geo = new THREE.BufferGeometry();
            const positions = new Float32Array(particleCount * 3);
            const colors = new Float32Array(particleCount * 3);

            for (let i = 0; i < particleCount; i++) {
                positions[i*3] = 0;
                positions[i*3+1] = -10;
                positions[i*3+2] = 0;

                colors[i*3] = 1.0;
                colors[i*3+1] = 0.6;
                colors[i*3+2] = 0.1;
                
                particlesData.push({
                    active: false,
                    velocity: new THREE.Vector3(),
                    life: 0,
                    maxLife: 0
                });
            }

            geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
            geo.setAttribute('color', new THREE.BufferAttribute(colors, 3));

            const mat = new THREE.PointsMaterial({
                size: 0.035,
                vertexColors: true,
                transparent: true,
                opacity: 0.9,
                blending: THREE.AdditiveBlending
            });

            particleSystem = new THREE.Points(geo, mat);
            scene.add(particleSystem);
        }

        function triggerSparks(originPos, surfaceAngle, isRightSide) {
            const posAttr = particleSystem.geometry.attributes.position;
            const baseDir = isRightSide ? 1 : -1;
            
            for (let i = 0; i < 4; i++) {
                const idx = particlesData.findIndex(p => !p.active);
                if (idx !== -1) {
                    const p = particlesData[idx];
                    p.active = true;
                    p.life = 0;
                    p.maxLife = 20 + Math.random() * 20;
                    
                    posAttr.setXYZ(idx, originPos.x, originPos.y, originPos.z);
                    
                    const angleRad = surfaceAngle * (Math.PI / 180);
                    const speed = 0.5 + Math.random() * 1.5;
                    p.velocity.set(
                        Math.cos(angleRad) * baseDir * speed,
                        Math.sin(angleRad) * -1 * speed,
                        (Math.random() - 0.5) * 0.5
                    );
                }
            }
            posAttr.needsUpdate = true;
        }

        function updateParticles() {
            if (!particleSystem) return;
            const posAttr = particleSystem.geometry.attributes.position;
            let updated = false;

            for (let i = 0; i < particleCount; i++) {
                const p = particlesData[i];
                if (p.active) {
                    const px = posAttr.getX(i);
                    const py = posAttr.getY(i);
                    const pz = posAttr.getZ(i);

                    p.velocity.y -= 0.05; 
                    posAttr.setXYZ(
                        i,
                        px + p.velocity.x * 0.016,
                        py + p.velocity.y * 0.016,
                        pz + p.velocity.z * 0.016
                    );

                    p.life++;
                    if (p.life >= p.maxLife) {
                        p.active = false;
                        posAttr.setXYZ(i, 0, -10, 0);
                    }
                    updated = true;
                }
            }
            if (updated) posAttr.needsUpdate = true;
        }

        // --- EXTRUSIÓN DE PLANOS INCLINADOS LATERALES ---
        function createLateralWedgeGeometry(vertices2D) {
            const shape = new THREE.Shape();
            shape.moveTo(vertices2D[0].x, vertices2D[0].y);
            for (let i = 1; i < vertices2D.length; i++) {
                shape.lineTo(vertices2D[i].x, vertices2D[i].y);
            }
            shape.closePath();

            const extrudeSettings = { depth: 0.35, bevelEnabled: false };
            const geo = new THREE.ExtrudeGeometry(shape, extrudeSettings);
            geo.translate(0, 0, -0.175); // Centrar únicamente en Z
            return geo;
        }

        // --- ALGORITMO DE RAYADO (HATCHING) PARA DIAGRAMAS ---
        function getHatchingLinesForPolygon(vertices, spacing = 0.12, angleRad = Math.PI / 4) {
            const points = [];
            let minX = Infinity, maxX = -Infinity;
            for (let v of vertices) {
                if (v.x < minX) minX = v.x;
                if (v.x > maxX) maxX = v.x;
            }

            const cos = Math.cos(angleRad);
            const sin = Math.sin(angleRad);

            let minD = Infinity;
            let maxD = -Infinity;
            for (let v of vertices) {
                let d = v.x * cos + v.y * sin;
                if (d < minD) minD = d;
                if (d > maxD) maxD = d;
            }

            for (let d = minD + spacing; d < maxD; d += spacing) {
                const intersections = [];
                for (let i = 0; i < vertices.length; i++) {
                    const p1 = vertices[i];
                    const p2 = vertices[(i + 1) % vertices.length];
                    
                    const dx = p2.x - p1.x;
                    const dy = p2.y - p1.y;
                    const denom = dx * cos + dy * sin;
                    if (Math.abs(denom) > 1e-6) {
                        const t = (d - p1.x * cos - p1.y * sin) / denom;
                        if (t >= 0 && t <= 1) {
                            intersections.push(new THREE.Vector3(p1.x + t * dx, p1.y + t * dy, 0.18)); // Ligeramente en frente
                        }
                    }
                }
                if (intersections.length >= 2) {
                    intersections.sort((a, b) => a.x !== b.x ? a.x - b.x : a.y - b.y);
                    points.push(intersections[0], intersections[intersections.length - 1]);
                }
            }
            return points;
        }

        // --- MATERIALES CON TEXTURAS DE TEXTO PARA BLOQUES ---
        function createBlockMaterial(colorHex, labelText) {
            const canvas = document.createElement('canvas');
            canvas.width = 128;
            canvas.height = 128;
            const ctx = canvas.getContext('2d');
            
            // Fondo
            ctx.fillStyle = colorHex;
            ctx.fillRect(0, 0, 128, 128);
            
            // Borde interior blanco de neón
            ctx.strokeStyle = '#ffffff';
            ctx.lineWidth = 6;
            ctx.strokeRect(10, 10, 108, 108);
            
            // Texto centrado (Orbitron)
            ctx.fillStyle = '#ffffff';
            ctx.font = 'black 48px Orbitron, Inter, sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(labelText, 64, 64);
            
            const texture = new THREE.CanvasTexture(canvas);
            return new THREE.MeshStandardMaterial({ 
                map: texture,
                roughness: 0.15,
                metalness: 0.6
            });
        }

        // --- SISTEMA DCL VECTORIAL 3D (FBD) ---
        function createForceArrow(colorHex) {
            const group = new THREE.Group();
            
            // Cuerpo del vector
            const shaftGeo = new THREE.CylinderGeometry(0.008, 0.008, 0.32, 8);
            shaftGeo.translate(0, 0.16, 0); // Eje de pivote en la cola
            const shaftMat = new THREE.MeshBasicMaterial({ color: colorHex, transparent: true, opacity: 0.85 });
            const shaft = new THREE.Mesh(shaftGeo, shaftMat);
            group.add(shaft);

            // Cabeza del vector
            const headGeo = new THREE.ConeGeometry(0.024, 0.08, 8);
            headGeo.translate(0, 0.32, 0);
            const head = new THREE.Mesh(headGeo, shaftMat);
            group.add(head);

            return group;
        }

        function buildFBDVectors() {
            Object.values(arrowsM1).forEach(a => scene.remove(a));
            Object.values(arrowsM2).forEach(a => scene.remove(a));
            arrowsM1 = {};
            arrowsM2 = {};

            const display = document.getElementById("toggle-fbd").checked;
            if (!display) return;

            const colWeight = 0xef4444; // Rojo (Peso)
            const colNormal = 0x10b981; // Verde (Normal)
            const colTension = 0x00f3ff; // Celeste (Tensión)
            const colFriction = 0xf59e0b; // Ámbar (Fricción)

            // Flechas M1
            arrowsM1.weight = createForceArrow(colWeight);
            arrowsM1.normal = createForceArrow(colNormal);
            arrowsM1.tension = createForceArrow(colTension);
            if (problemParameters.mu1 > 0) {
                arrowsM1.friction = createForceArrow(colFriction);
            }

            // Flechas M2
            arrowsM2.weight = createForceArrow(colWeight);
            arrowsM2.tension = createForceArrow(colTension);
            if (!problemParameters.isVertical) {
                arrowsM2.normal = createForceArrow(colNormal);
                if (problemParameters.mu2 > 0) {
                    arrowsM2.friction = createForceArrow(colFriction);
                }
            }

            Object.values(arrowsM1).forEach(a => scene.add(a));
            Object.values(arrowsM2).forEach(a => scene.add(a));
        }

        function setArrowDirection(arrow, dir) {
            arrow.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), dir.clone().normalize());
        }

        function updateFBDPositions() {
            const display = document.getElementById("toggle-fbd").checked;
            if (!display) {
                Object.values(arrowsM1).forEach(a => a.visible = false);
                Object.values(arrowsM2).forEach(a => a.visible = false);
                return;
            }

            const p = problemParameters;
            const rad1 = p.ang1 * (Math.PI / 180);
            const rad2 = p.ang2 * (Math.PI / 180);

            // --- VECTORES M1 ---
            const blockOffsetZ = 0.18; // Desplazar al frente para evitar solapes
            if (arrowsM1.weight) {
                arrowsM1.weight.visible = true;
                arrowsM1.weight.position.copy(block1.position).setZ(blockOffsetZ);
                setArrowDirection(arrowsM1.weight, new THREE.Vector3(0, -1, 0));
            }
            if (arrowsM1.normal) {
                arrowsM1.normal.visible = true;
                arrowsM1.normal.position.copy(block1.position).setZ(blockOffsetZ);
                setArrowDirection(arrowsM1.normal, new THREE.Vector3(-Math.sin(rad1), Math.cos(rad1), 0));
            }
            if (arrowsM1.tension) {
                arrowsM1.tension.visible = true;
                arrowsM1.tension.position.copy(block1.position).setZ(blockOffsetZ);
                setArrowDirection(arrowsM1.tension, new THREE.Vector3(Math.cos(rad1), Math.sin(rad1), 0)); // Tira rampa arriba hacia la polea
            }
            if (arrowsM1.friction) {
                arrowsM1.friction.visible = true;
                arrowsM1.friction.position.copy(block1.position).setZ(blockOffsetZ);
                // Si el sistema va a la derecha (m2 baja, m1 sube), fricción rampa abajo
                const fricDir = simDirection >= 0 ? new THREE.Vector3(-Math.cos(rad1), -Math.sin(rad1), 0) : new THREE.Vector3(Math.cos(rad1), Math.sin(rad1), 0);
                setArrowDirection(arrowsM1.friction, fricDir);
            }

            // --- VECTORES M2 ---
            if (arrowsM2.weight) {
                arrowsM2.weight.visible = true;
                arrowsM2.weight.position.copy(block2.position).setZ(blockOffsetZ);
                setArrowDirection(arrowsM2.weight, new THREE.Vector3(0, -1, 0));
            }
            if (arrowsM2.tension) {
                arrowsM2.tension.visible = true;
                arrowsM2.tension.position.copy(block2.position).setZ(blockOffsetZ);
                if (p.isVertical) {
                    setArrowDirection(arrowsM2.tension, new THREE.Vector3(0, 1, 0));
                } else {
                    setArrowDirection(arrowsM2.tension, new THREE.Vector3(-Math.cos(rad2), Math.sin(rad2), 0));
                }
            }
            if (!p.isVertical) {
                if (arrowsM2.normal) {
                    arrowsM2.normal.visible = true;
                    arrowsM2.normal.position.copy(block2.position).setZ(blockOffsetZ);
                    setArrowDirection(arrowsM2.normal, new THREE.Vector3(Math.sin(rad2), Math.cos(rad2), 0));
                }
                if (arrowsM2.friction) {
                    arrowsM2.friction.visible = true;
                    arrowsM2.friction.position.copy(block2.position).setZ(blockOffsetZ);
                    // Si el sistema va a la derecha (m2 baja), fricción rampa arriba
                    const fricDir = simDirection >= 0 ? new THREE.Vector3(-Math.cos(rad2), Math.sin(rad2), 0) : new THREE.Vector3(Math.cos(rad2), -Math.sin(rad2), 0);
                    setArrowDirection(arrowsM2.friction, fricDir);
                }
            }
        }

        // --- CONSTRUCCIÓN DE CUÑA UNIFICADA DIAGRAMÁTICA ---
        function buildSystemGeometry() {
            // Eliminar geometrías anteriores de la escena
            if (wedgeLeft) scene.remove(wedgeLeft);
            if (wedgeLeftHatching) scene.remove(wedgeLeftHatching);
            if (pulleyBracket) scene.remove(pulleyBracket);
            if (block1) scene.remove(block1);
            if (block2) scene.remove(block2);

            const p = problemParameters;
            const blockHeight = 0.16;
            const R = 0.18;

            // Material azul holográfico translúcido para los planos
            const wedgeMat = new THREE.MeshStandardMaterial({ 
                color: 0x071a35, 
                transparent: true,
                opacity: 0.65,
                roughness: 0.2,
                metalness: 0.8,
                side: THREE.DoubleSide
            });

            const hatchingMat = new THREE.LineBasicMaterial({ color: 0x00a2ff, transparent: true, opacity: 0.35 });

            // --- LADO IZQUIERDO (Masa 1) ---
            const rad1 = p.ang1 * (Math.PI / 180);
            
            // Puntos de tangencia exactos en la polea
            const T1 = new THREE.Vector3(-R * Math.sin(rad1), 1.8 + R * Math.cos(rad1), 0);
            const n1 = new THREE.Vector3(-Math.sin(rad1), Math.cos(rad1), 0);

            // El pico superior del plano izquierdo se ajusta para que la cuerda toque exactamente el bloque
            const P1 = T1.clone().sub(n1.clone().multiplyScalar(blockHeight));

            let polyUnified = [];
            let y_V = 0;
            let x_V = 0;

            if (p.isVertical) {
                // Intersección del plano inclinado izquierdo con el límite vertical en x = R = 0.18
                x_V = R;
                y_V = Math.tan(rad1) * (R - P1.x) + P1.y;
                
                // El plano izquierdo cae hasta el suelo (y = 0)
                const x_L = P1.x - P1.y / Math.tan(rad1);

                polyUnified = [
                    { x: x_L, y: 0 },
                    { x: R, y: y_V },
                    { x: R, y: 0 }
                ];

                // Bloque 1
                const b1Size = 0.15 + p.m1 * 0.008;
                block1 = new THREE.Mesh(
                    new THREE.BoxGeometry(b1Size, blockHeight, b1Size), 
                    createBlockMaterial('#ef4444', 'M1')
                );
                block1.castShadow = true;
                scene.add(block1);

                // Bloque 2 (Cuelga vertical)
                const b2Size = 0.15 + p.m2 * 0.008;
                block2 = new THREE.Mesh(
                    new THREE.BoxGeometry(b2Size, blockHeight, b2Size), 
                    createBlockMaterial('#3b82f6', 'M2')
                );
                block2.castShadow = true;
                scene.add(block2);

            } else {
                const rad2 = p.ang2 * (Math.PI / 180);
                const T2 = new THREE.Vector3(R * Math.sin(rad2), 1.8 + R * Math.cos(rad2), 0);
                const n2 = new THREE.Vector3(Math.sin(rad2), Math.cos(rad2), 0);

                const P2 = T2.clone().sub(n2.clone().multiplyScalar(blockHeight));

                // Intersección analítica de dos líneas:
                // y - P1.y = tan(rad1) * (x - P1.x)
                // y - P2.y = -tan(rad2) * (x - P2.x)
                const C1 = P1.y - Math.tan(rad1) * P1.x;
                const C2 = P2.y + Math.tan(rad2) * P2.x;

                x_V = (C2 - C1) / (Math.tan(rad1) + Math.tan(rad2));
                y_V = Math.tan(rad1) * x_V + C1;

                const x_L = P1.x - P1.y / Math.tan(rad1);
                const x_R = P2.x + P2.y / Math.tan(rad2);

                polyUnified = [
                    { x: x_L, y: 0 },
                    { x: x_V, y: y_V },
                    { x: x_R, y: 0 }
                ];

                // Bloque 1
                const b1Size = 0.15 + p.m1 * 0.008;
                block1 = new THREE.Mesh(
                    new THREE.BoxGeometry(b1Size, blockHeight, b1Size), 
                    createBlockMaterial('#ef4444', 'M1')
                );
                block1.castShadow = true;
                scene.add(block1);

                // Bloque 2
                const b2Size = 0.15 + p.m2 * 0.008;
                block2 = new THREE.Mesh(
                    new THREE.BoxGeometry(b2Size, blockHeight, b2Size), 
                    createBlockMaterial('#3b82f6', 'M2')
                );
                block2.castShadow = true;
                scene.add(block2);
            }

            // Construir la única cuña extruida unificada en su posición analítica real
            wedgeLeft = new THREE.Mesh(createLateralWedgeGeometry(polyUnified), wedgeMat);
            wedgeLeft.position.set(0, 0, -0.175);
            wedgeLeft.receiveShadow = true;
            scene.add(wedgeLeft);

            // Añadir soporte o abrazadera metálica que conecta el ápice con el eje central de la polea
            const bracketHeight = Math.sqrt(x_V*x_V + (1.8 - y_V)*(1.8 - y_V));
            if (bracketHeight > 0.05) {
                const bracketGeo = new THREE.CylinderGeometry(0.02, 0.025, bracketHeight, 16);
                const bracketMat = new THREE.MeshStandardMaterial({ color: 0x1e293b, roughness: 0.3, metalness: 0.8 });
                pulleyBracket = new THREE.Mesh(bracketGeo, bracketMat);
                pulleyBracket.position.set(x_V / 2, (1.8 + y_V) / 2, -0.05);
                const angleZ = Math.atan2(1.8 - y_V, -x_V) - Math.PI / 2;
                pulleyBracket.rotation.z = angleZ;
                scene.add(pulleyBracket);
            }

            resetSimulationPositions();
            buildFBDVectors();
        }

        // --- POSICIONAMIENTO Y DESPLAZAMIENTO COHERENTE ---
        function resetSimulationPositions() {
            displacement = 0;
            updateSimulationVisuals();
        }

        // --- ENROLLAMIENTO Y ACOPLADO PERFECTO DEL CABLE ---
        function updateRopeGeometry() {
            const p = problemParameters;
            const R = 0.18;
            const points = [];

            // 1. Enganche superior de M1 (Cara frontal superior del cubo)
            const hook1Local = new THREE.Vector3(0, 0.08, 0);
            const hook1World = hook1Local.clone().applyMatrix4(block1.matrixWorld);
            points.push(hook1World);

            // 2. Tangencia rampa izquierda en polea
            const rad1 = p.ang1 * (Math.PI / 180);
            const T1 = new THREE.Vector3(-R * Math.sin(rad1), 1.8 + R * Math.cos(rad1), 0);
            points.push(T1);

            // 3. Enrollamiento circular alrededor del cilindro de la polea
            const angleStart = Math.PI / 2 + rad1;
            const angleEnd = p.isVertical ? Math.PI / 2 : Math.PI / 2 - (p.ang2 * (Math.PI / 180));
            const steps = 16;
            for (let i = 0; i <= steps; i++) {
                const alpha = angleStart + (angleEnd - angleStart) * (i / steps);
                points.push(new THREE.Vector3(R * Math.cos(alpha), 1.8 + R * Math.sin(alpha), 0));
            }

            // 4. Tangencia rampa derecha
            const rad2 = p.isVertical ? Math.PI/2 : p.ang2 * (Math.PI / 180);
            const T2 = new THREE.Vector3(R * Math.sin(rad2), 1.8 + R * Math.cos(rad2), 0);
            points.push(T2);

            // 5. Enganche superior de M2
            const hook2Local = new THREE.Vector3(0, 0.08, 0);
            const hook2World = hook2Local.clone().applyMatrix4(block2.matrixWorld);
            points.push(hook2World);

            ropeGeometry.setFromPoints(points);
        }

        // --- PROYECCIÓN DE ETIQUETAS M1 Y M2 A COORDENADAS DE PANTALLA ---
        function updateScreenBadges() {
            if (!block1 || !block2) return;
            
            const p1 = getScreenCoords(block1);
            const p2 = getScreenCoords(block2);
            
            const badge1 = document.getElementById("badge-m1");
            const badge2 = document.getElementById("badge-m2");
            
            if (badge1) {
                if (p1) {
                    badge1.style.left = `${p1.x}px`;
                    badge1.style.top = `${p1.y - 42}px`; // Un poco por encima de la masa
                    badge1.style.display = 'block';
                } else {
                    badge1.style.display = 'none';
                }
            }
            if (badge2) {
                if (p2) {
                    badge2.style.left = `${p2.x}px`;
                    badge2.style.top = `${p2.y - 42}px`;
                    badge2.style.display = 'block';
                } else {
                    badge2.style.display = 'none';
                }
            }
        }

        // --- OBTENER COORDENADAS DE PANTALLA ---
        function getScreenCoords(mesh) {
            const vector = new THREE.Vector3();
            mesh.updateMatrixWorld();
            vector.setFromMatrixPosition(mesh.matrixWorld);
            vector.project(camera);
            
            const container = document.getElementById("canvas-container");
            const width = container.clientWidth;
            const height = container.clientHeight;
            
            const x = (vector.x * 0.5 + 0.5) * width;
            const y = (vector.y * -0.5 + 0.5) * height;
            
            if (vector.z > 1) return null;
            return { x, y };
        }

        // --- SISTEMA REGENERADOR DE PROBLEMAS (Operaciones con 1 DECIMAL EXACTO y Balanceo) ---
        function generateValidProblem() {
            let valid = false, tries = 0;
            let p = {};
            
            // Decidimos equilibrar activamente el sentido del movimiento esperado (50% izquierda, 50% derecha)
            const targetDir = Math.random() < 0.5 ? 1 : -1;

            while (!valid && tries < 600) {
                tries++;
                
                p.m1 = parseFloat((Math.random() * 6 + 3).toFixed(1)); // 3.0 a 9.0 kg
                p.ang1 = Math.round(Math.random() * 5 + 3) * 5; // 15° a 40°
                p.mu1 = Math.random() > 0.4 ? parseFloat((Math.random() * 0.15 + 0.05).toFixed(1)) : 0;

                p.isVertical = Math.random() < 0.4; // 40% vertical, 60% doble rampa

                if (p.isVertical) {
                    p.ang2 = 90;
                    p.mu2 = 0;
                    if (targetDir === 1) {
                        p.m2 = parseFloat((Math.random() * 5 + p.m1 * Math.sin(p.ang1 * Math.PI / 180) + 1).toFixed(1));
                    } else {
                        const maxM2 = Math.max(1.5, p.m1 * Math.sin(p.ang1 * Math.PI / 180) - 0.5);
                        p.m2 = parseFloat((Math.random() * (maxM2 - 1.5) + 1.5).toFixed(1));
                    }
                } else {
                    p.ang2 = Math.round(Math.random() * 5 + 3) * 5; // 15° a 40°
                    p.mu2 = Math.random() > 0.4 ? parseFloat((Math.random() * 0.15 + 0.05).toFixed(1)) : 0;
                    
                    if (targetDir === 1) {
                        p.m2 = parseFloat((Math.random() * 4 + 5).toFixed(1)); // m2 más pesado
                        p.m1 = parseFloat((Math.random() * 4 + 2).toFixed(1)); // m1 más liviano
                    } else {
                        p.m1 = parseFloat((Math.random() * 4 + 5).toFixed(1)); // m1 más pesado
                        p.m2 = parseFloat((Math.random() * 4 + 2).toFixed(1)); // m2 más liviano
                    }
                }

                // Cálculo físico formal con gravedad de un decimal (g = 9.8)
                const r1 = p.ang1 * (Math.PI / 180);
                const r2 = p.ang2 * (Math.PI / 180);

                const compM1 = p.m1 * GRAVITY * Math.sin(r1);
                const fricM1 = p.mu1 * p.m1 * GRAVITY * Math.cos(r1);

                const compM2 = p.isVertical ? p.m2 * GRAVITY : p.m2 * GRAVITY * Math.sin(r2);
                const fricM2 = p.isVertical ? 0 : p.mu2 * p.m2 * GRAVITY * Math.cos(r2);

                const netDrivingForce = compM2 - compM1; // Positivo tira a la derecha, Negativo a la izquierda
                const totalFric = fricM1 + fricM2;

                let calculatedAcc = 0;
                if (Math.abs(netDrivingForce) > totalFric) {
                    calculatedAcc = (Math.abs(netDrivingForce) - totalFric) / (p.m1 + p.m2);
                    p.simDir = netDrivingForce > 0 ? 1 : -1;
                } else {
                    calculatedAcc = 0;
                    p.simDir = 0;
                }

                // Guardar la aceleración con exactamente 1 decimal
                p.a = parseFloat(calculatedAcc.toFixed(1));

                // Aceptar únicamente si se cumple la aceleración mínima y el sentido buscado
                if (p.a > 0.3 && p.a < 4.5 && p.simDir === targetDir) {
                    valid = true;
                    problemParameters = p;
                }
            }

            if (!valid) {
                problemParameters = { m1: 6.0, ang1: 30, mu1: 0.1, m2: 8.0, ang2: 90, mu2: 0, a: 1.8, isVertical: true, simDir: 1 };
            }

            // Seleccionar incógnita aleatoria (m1, m2, a, mu1 o mu2)
            let eligibleVariables = ["m1", "m2", "a"];
            if (problemParameters.mu1 > 0) eligibleVariables.push("mu1");
            if (problemParameters.mu2 > 0 && !problemParameters.isVertical) eligibleVariables.push("mu2");

            missingVariableType = eligibleVariables[Math.floor(Math.random() * eligibleVariables.length)];
            correctAnswer = parseFloat(problemParameters[missingVariableType].toFixed(1));
        }

        // --- ACTUALIZACIÓN DE INTERFAZ Y FASES DE GAMIFICACIÓN ---
        function updateUIState() {
            const varsDiv = document.getElementById("variables-dadas");
            varsDiv.innerHTML = "";

            variableKeys.forEach(key => {
                const meta = variableMeta[key];
                if (key !== missingVariableType) {
                    if (key === "mu2" && problemParameters.isVertical) return;

                    const displayValue = problemParameters[key].toFixed(1);
                    varsDiv.innerHTML += `
                        <div class="glass-card flex flex-col justify-center items-center p-2 rounded-xl text-center">
                            <span class="text-[8px] text-gray-400 font-bold uppercase tracking-widest">${meta.label}</span>
                            <span class="font-orbitron font-black text-xs text-yellow-400 leading-none mt-1.5">${displayValue} <span class="text-[8.5px] text-yellow-200/60 font-sans font-normal">${meta.unit}</span></span>
                        </div>
                    `;
                } else {
                    document.getElementById("input-title").innerHTML = `Resolver: <span class="text-cyan-400 font-black">${meta.label}</span>`;
                    document.getElementById("unit-label").textContent = meta.unit;
                    document.getElementById("manual-input").value = "";
                }
            });

            // Actualizar HUD central de Sentido Físico de Movimiento
            const motionArrow = document.getElementById("motion-arrow");
            const motionText = document.getElementById("motion-text");
            if (problemParameters.simDir === 1) {
                motionArrow.textContent = "➔";
                motionArrow.className = "text-sm animate-pulse text-blue-400 neon-text-blue";
                motionText.textContent = "Hacia M2 (Derecha)";
                motionText.className = "font-orbitron text-xs font-black text-blue-400 uppercase tracking-wider leading-none";
            } else {
                motionArrow.textContent = "←";
                motionArrow.className = "text-sm animate-pulse text-red-500 neon-text-red";
                motionText.textContent = "Hacia M1 (Izquierda)";
                motionText.className = "font-orbitron text-xs font-black text-red-500 uppercase tracking-wider leading-none";
            }

            const phaseBadge = document.getElementById("phase-badge");
            const heartsCont = document.getElementById("hearts-container");

            heartsCont.innerHTML = "";
            for (let i = 0; i < 3; i++) {
                const filled = i < attemptsLeft;
                heartsCont.innerHTML += `
                    <svg class="w-4 h-4 ${filled ? 'text-rose-500 fill-rose-500' : 'text-gray-700'}" fill="${filled ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                `;
            }

            if (attemptsLeft === 3) {
                phaseBadge.textContent = "1 - Entrada Libre";
                phaseBadge.className = "font-orbitron text-[9px] font-black text-cyan-400 leading-none block mt-1 bg-cyan-950/40 px-2 py-0.5 rounded border border-cyan-800/50";
                document.getElementById("manual-input-wrapper").classList.remove("hidden");
                document.getElementById("options-container").classList.add("hidden");
                document.getElementById("manual-input").focus();
            } else {
                document.getElementById("manual-input-wrapper").classList.add("hidden");
                document.getElementById("options-container").classList.remove("hidden");
                if (attemptsLeft === 2) {
                    phaseBadge.textContent = "2 - Cuatro Opciones";
                    phaseBadge.className = "font-orbitron text-[9px] font-black text-yellow-400 leading-none block mt-1 bg-yellow-950/40 px-2 py-0.5 rounded border border-yellow-800/50";
                } else {
                    phaseBadge.textContent = "3 - Binaria (50/50)";
                    phaseBadge.className = "font-orbitron text-[9px] font-black text-rose-400 leading-none block mt-1 bg-rose-950/40 px-2 py-0.5 rounded border border-rose-800/50";
                }
                generateOptionButtons();
            }

            document.getElementById("score-display").textContent = currentScore;
            document.getElementById("lanzarBtn").disabled = false;
        }

        // --- SISTEMA PANEL DESLIZANTE ---
        let isMobileDrawerOpen = false;

        function toggleMobileDrawer(forceState = null) {
            const wrapper = document.getElementById("panels-wrapper");
            const btn = document.getElementById("mobile-drawer-toggle");
            const btnText = document.getElementById("mobile-drawer-text");
            const btnIcon = document.getElementById("mobile-drawer-icon");
            
            if (forceState !== null) {
                isMobileDrawerOpen = forceState;
            } else {
                isMobileDrawerOpen = !isMobileDrawerOpen;
            }
            
            if (isMobileDrawerOpen) {
                wrapper.classList.remove("mobile-hidden");
                btnText.textContent = "Ocultar Panel";
                btnIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>`;
            } else {
                wrapper.classList.add("mobile-hidden");
                btnText.textContent = "Ver Datos y Resolver";
                btnIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>`;
            }
        }

        // --- SISTEMA DE CONTROL DE VISIBILIDAD DEL PANEL IZQUIERDO ---
        function toggleLeftPanel() {
            const panel = document.getElementById("left-panel");
            const icon = document.getElementById("toggle-panel-icon");
            
            isPanelHidden = !isPanelHidden;
            if (isPanelHidden) {
                panel.classList.add("left-panel-hidden");
                icon.style.transform = "rotate(180deg)";
            } else {
                panel.classList.remove("left-panel-hidden");
                icon.style.transform = "rotate(0deg)";
            }
        }

        let isRightPanelHidden = false;
        function toggleRightPanel() {
            const panel = document.getElementById("right-panel");
            const icon = document.getElementById("toggle-right-panel-icon");
            
            isRightPanelHidden = !isRightPanelHidden;
            if (isRightPanelHidden) {
                panel.classList.add("right-panel-hidden");
                icon.style.transform = "rotate(180deg)";
            } else {
                panel.classList.remove("right-panel-hidden");
                icon.style.transform = "rotate(0deg)";
            }
        }

        function selectOption(el) {
            const siblings = el.parentNode.children;
            for (let child of siblings) {
                child.classList.remove("border-yellow-400", "bg-yellow-400/20");
                child.classList.add("border-gray-800/80", "bg-black/30");
            }
            el.classList.remove("border-gray-800/80", "bg-black/30");
            el.classList.add("border-yellow-400", "bg-yellow-400/20");
        }

        function generateOptionButtons() {
            const container = document.getElementById("options-container");
            container.innerHTML = "";

            if (currentOptions.length === 0) {
                const optionSet = new Set();
                optionSet.add(correctAnswer);

                const targetSize = attemptsLeft === 2 ? 4 : 2;
                let attempts = 0;

                while (optionSet.size < targetSize && attempts < 200) {
                    attempts++;
                    const deviation = 0.6 + Math.random() * 0.8;
                    let candidate = parseFloat((correctAnswer * deviation).toFixed(1));
                    if (candidate <= 0) candidate = parseFloat((correctAnswer + (Math.random() * 2 + 1)).toFixed(1));
                    
                    let acceptable = true;
                    for (let existing of optionSet) {
                        if (Math.abs(candidate - existing) < 0.2) {
                            acceptable = false;
                            break;
                        }
                    }
                    if (acceptable) {
                        optionSet.add(candidate);
                    }
                }

                // Fallback de seguridad
                let fallbackOffset = 0.3;
                while (optionSet.size < targetSize) {
                    let valPositive = parseFloat((correctAnswer + fallbackOffset).toFixed(1));
                    let valNegative = parseFloat((correctAnswer - fallbackOffset).toFixed(1));
                    
                    if (valPositive > 0) {
                        let ok = true;
                        for (let existing of optionSet) {
                            if (Math.abs(valPositive - existing) < 0.19) ok = false;
                        }
                        if (ok) optionSet.add(valPositive);
                    }
                    if (optionSet.size < targetSize && valNegative > 0) {
                        let ok = true;
                        for (let existing of optionSet) {
                            if (Math.abs(valNegative - existing) < 0.19) ok = false;
                        }
                        if (ok) optionSet.add(valNegative);
                    }
                    fallbackOffset += 0.3;
                }

                currentOptions = Array.from(optionSet).sort(() => Math.random() - 0.5);
            }

            currentOptions.forEach((opt, idx) => {
                container.innerHTML += `
                    <div class="flex items-center justify-between bg-black/30 hover:bg-cyan-950/20 text-gray-100 px-3 py-1.5 rounded-xl cursor-pointer select-none transition-all border border-gray-800/80 shadow-md text-xs h-[34px]" onclick="document.getElementById('opt-radio-${idx}').checked=true; selectOption(this)">
                        <div class="flex items-center gap-2">
                            <input type="radio" id="opt-radio-${idx}" name="optionGroup" value="${opt}" class="w-3.5 h-3.5 accent-cyan-400 cursor-pointer">
                            <span class="font-orbitron text-xs font-bold leading-none">${opt.toFixed(1)}</span>
                        </div>
                        <span class="text-[9px] text-cyan-400 font-bold font-orbitron uppercase tracking-wider leading-none">${variableMeta[missingVariableType].unit}</span>
                    </div>
                `;
            });
        }

        function getSelectedUserAnswer() {
            if (attemptsLeft === 3) {
                const val = parseFloat(document.getElementById("manual-input").value);
                if (isNaN(val) || val < 0) {
                    if (missingVariableType === "a" && val === 0) return 0;
                    updateFeedbackMessage("Ingresa un valor positivo de un decimal.", "border-yellow-500", "text-yellow-400");
                    return null;
                }
                return parseFloat(val.toFixed(1));
            } else {
                const checked = document.querySelector('input[name="optionGroup"]:checked');
                if (!checked) {
                    updateFeedbackMessage("Selecciona una opción para simular.", "border-yellow-500", "text-yellow-400");
                    return null;
                }
                return parseFloat(checked.value);
            }
        }

        function updateFeedbackMessage(text, borderColorClass = "border-cyan-500", colorClass = "text-cyan-400") {
            const fb = document.getElementById("feedback");
            fb.className = `text-xs leading-snug ${colorClass}`;
            fb.textContent = text;
        }

        // --- SISTEMA RUN SIMULACIÓN EN TIEMPO REAL ---
        function runSimulation() {
            if (isSimulating) return;

            const userVal = getSelectedUserAnswer();
            if (userVal === null) return;

            let testParams = { ...problemParameters };
            testParams[missingVariableType] = userVal;

            const r1 = testParams.ang1 * (Math.PI / 180);
            const r2 = testParams.ang2 * (Math.PI / 180);

            const compM1 = testParams.m1 * GRAVITY * Math.sin(r1);
            const fricM1 = testParams.mu1 * testParams.m1 * GRAVITY * Math.cos(r1);

            const compM2 = testParams.isVertical ? testParams.m2 * GRAVITY : testParams.m2 * GRAVITY * Math.sin(r2);
            const fricM2 = testParams.isVertical ? 0 : testParams.mu2 * testParams.m2 * GRAVITY * Math.cos(r2);

            const netForce = compM2 - compM1;
            const totalFriction = fricM1 + fricM2;

            if (Math.abs(netForce) > totalFriction) {
                simulatedAcceleration = (Math.abs(netForce) - totalFriction) / (testParams.m1 + testParams.m2);
                simDirection = netForce > 0 ? 1 : -1;
            } else {
                simulatedAcceleration = 0;
                simDirection = 0;
            }

            if (missingVariableType === "a") {
                simulatedAcceleration = userVal;
                simDirection = problemParameters.simDir;
            }

            isSimulating = true;
            document.getElementById("lanzarBtn").disabled = true;
            sfx.playHum(simulatedAcceleration > 0);

            // Ocultar paneles automáticamente al iniciar la simulación
            if (!isPanelHidden) {
                toggleLeftPanel();
            }
            if (!isRightPanelHidden) {
                toggleRightPanel();
            }
            
            // Cerrar cajón móvil si está abierto y ocultar el botón flotante durante la simulación
            toggleMobileDrawer(false);
            document.getElementById("mobile-drawer-toggle").classList.add("hidden-force");

            const isCorrect = Math.abs(userVal - correctAnswer) <= ABS_TOLERANCE;

            simTime = 0;
            const simDurationLimit = 2.4; 
            const clock = new THREE.Clock();

            function simTick() {
                if (!isSimulating) return;

                const dt = Math.min(clock.getDelta(), 0.03);
                simTime += dt;

                // MRUA: s = 0.5 * a * t^2
                displacement = 0.5 * simulatedAcceleration * Math.pow(simTime, 1.6);

                if (displacement > 0.85) {
                    displacement = 0.85;
                }

                updateSimulationVisuals();

                // Chispas alineadas exactamente con el roce en rampa M1
                if (problemParameters.mu1 > 0 && simulatedAcceleration > 0 && Math.random() < 0.6) {
                    const offset1 = new THREE.Vector3(-Math.sin(r1), Math.cos(r1), 0).multiplyScalar(-0.08);
                    const sparkPos1 = block1.position.clone().add(offset1);
                    triggerSparks(sparkPos1, problemParameters.ang1, false);
                }
                // Chispas en M2
                if (!problemParameters.isVertical && problemParameters.mu2 > 0 && simulatedAcceleration > 0 && Math.random() < 0.6) {
                    const offset2 = new THREE.Vector3(Math.sin(r2), Math.cos(r2), 0).multiplyScalar(-0.08);
                    const sparkPos2 = block2.position.clone().add(offset2);
                    triggerSparks(sparkPos2, problemParameters.ang2, true);
                }

                if (simTime >= simDurationLimit) {
                    isSimulating = false;
                    sfx.playClank();
                    evalQuizResult(isCorrect);
                    return;
                }

                requestAnimationFrame(simTick);
            }

            requestAnimationFrame(simTick);
        }

        function updateSimulationVisuals() {
            const p = problemParameters;
            const R = 0.18;
            const blockHeight = 0.16;

            // --- BLOQUE 1 (M1) ---
            const rad1 = p.ang1 * (Math.PI / 180);
            const T1 = new THREE.Vector3(-R * Math.sin(rad1), 1.8 + R * Math.cos(rad1), 0);
            const u1 = new THREE.Vector3(-Math.cos(rad1), -Math.sin(rad1), 0); // Vector rampa abajo izquierda
            const n1 = new THREE.Vector3(-Math.sin(rad1), Math.cos(rad1), 0);  // Normal rampa izquierda

            // Si simDirection = 1 (M2 baja), M1 sube por la rampa (distancia a la polea disminuye: 0.9 - displacement)
            // Si simDirection = -1 (M1 baja), M1 baja por la rampa (distancia aumenta: 0.9 + displacement)
            const currentDist1 = 0.9 - (displacement * simDirection);
            
            block1.position.copy(T1)
                .add(u1.clone().multiplyScalar(currentDist1))
                .sub(n1.clone().multiplyScalar(blockHeight / 2));
            
            // CORREGIDO: Ángulo de rotación de M1 corregido a positivo (+rad1) para alineación perfecta con la rampa
            block1.rotation.set(0, 0, rad1);

            // --- BLOQUE 2 (M2) ---
            if (p.isVertical) {
                // Si simDirection = 1 (M2 baja), la masa cae verticalmente (distancia de la polea aumenta: 0.8 + displacement)
                const currentDist2 = 0.8 + (displacement * simDirection);
                block2.position.set(R, 1.8 - currentDist2, 0);
                block2.rotation.set(0, 0, 0);
            } else {
                const rad2 = p.ang2 * (Math.PI / 180);
                const T2 = new THREE.Vector3(R * Math.sin(rad2), 1.8 + R * Math.cos(rad2), 0);
                const u2 = new THREE.Vector3(Math.cos(rad2), -Math.sin(rad2), 0); // Vector rampa abajo derecha
                const n2 = new THREE.Vector3(Math.sin(rad2), Math.cos(rad2), 0);  // Normal rampa derecha

                // Si simDirection = 1 (M2 baja), la masa se aleja de la polea (distancia aumenta: 0.9 + displacement)
                const currentDist2 = 0.9 + (displacement * simDirection);
                
                block2.position.copy(T2)
                    .add(u2.clone().multiplyScalar(currentDist2))
                    .sub(n2.clone().multiplyScalar(blockHeight / 2));

                // CORREGIDO: Ángulo de rotación de M2 corregido a negativo (-rad2) para alineación perfecta con la rampa
                block2.rotation.set(0, 0, -rad2);
            }

            // Sincronizar giro físico e hilo de la polea en sentido real (positivo/negativo)
            pulleyGroup.rotation.z = -(displacement * simDirection) / R;

            updateRopeGeometry();
            updateFBDPositions();
        }

        // --- SISTEMA RECEPTOR DE EVALUACIONES ---
        function evalQuizResult(isCorrect) {
            const meta = variableMeta[missingVariableType];
            
            // Volver a mostrar los paneles al terminar la simulación
            if (isPanelHidden) {
                toggleLeftPanel();
            }
            if (isRightPanelHidden) {
                toggleRightPanel();
            }
            
            // Mostrar botón flotante del cajón y abrirlo automáticamente para ver resultados en móviles
            document.getElementById("mobile-drawer-toggle").classList.remove("hidden-force");
            toggleMobileDrawer(true);

            if (isCorrect) {
                let scoreYield = 0;
                let textResult = "";
                
                if (attemptsLeft === 3) {
                    scoreYield = 100;
                    textResult = "¡EXCELENTE! Cálculo perfecto con un decimal. +100 XP";
                } else if (attemptsLeft === 2) {
                    scoreYield = 50;
                    textResult = "¡MUY BIEN! Logrado en la fase de opción múltiple. +50 XP";
                } else {
                    scoreYield = 20;
                    textResult = "¡BIEN HECHO! Resuelto en la prueba binaria. +20 XP";
                }

                sfx.playSuccess();
                currentScore += scoreYield;
                document.getElementById("score-display").textContent = currentScore;
                
                updateFeedbackMessage(textResult, "border-emerald-500", "text-emerald-400 font-bold");
                document.getElementById("correct-answer-display").textContent = `Respuesta Exacta: ${correctAnswer.toFixed(1)} ${meta.unit}`;
                
                document.getElementById("lanzarBtn").classList.add("hidden");
            } else {
                attemptsLeft--;
                sfx.playFailure();
                
                if (attemptsLeft === 2) {
                    updateFeedbackMessage("El sistema se movió de forma distinta. ¡Te quedan las Opciones de Ayuda!", "border-red-500", "text-red-400");
                    currentOptions = [];
                    setTimeout(() => {
                        updateUIState();
                        resetSimulationPositions();
                    }, 1200);
                } else if (attemptsLeft === 1) {
                    updateFeedbackMessage("¡Fallo! El equilibrio no era ese. Activado comodín binario 50/50.", "border-red-500", "text-red-400");
                    const otherOpt = currentOptions.find(o => o !== correctAnswer);
                    currentOptions = [correctAnswer, otherOpt].sort(() => Math.random() - 0.5);
                    setTimeout(() => {
                        updateUIState();
                        resetSimulationPositions();
                    }, 1200);
                } else {
                    updateFeedbackMessage(`SISTEMA AGOTADO. El valor real correcto era: ${correctAnswer.toFixed(1)} ${meta.unit}`, "border-red-600", "text-red-500 font-extrabold");
                    document.getElementById("correct-answer-display").textContent = "Estudia los vectores en el DCL e intenta el siguiente.";
                    document.getElementById("lanzarBtn").classList.add("hidden");
                }
            }
        }

        function restartSystem() {
            attemptsLeft = 3;
            currentOptions = [];
            isSimulating = false;
            
            // Asegurar que los paneles no queden ocultos al reiniciar (por ejemplo, si se reinicia a mitad de simulación)
            isPanelHidden = false;
            isRightPanelHidden = false;
            const leftPanel = document.getElementById("left-panel");
            const rightPanel = document.getElementById("right-panel");
            if (leftPanel) leftPanel.classList.remove("left-panel-hidden");
            if (rightPanel) rightPanel.classList.remove("right-panel-hidden");
            const leftIcon = document.getElementById("toggle-panel-icon");
            const rightIcon = document.getElementById("toggle-right-panel-icon");
            if (leftIcon) leftIcon.style.transform = "rotate(0deg)";
            if (rightIcon) rightIcon.style.transform = "rotate(0deg)";
            
            document.getElementById("lanzarBtn").classList.remove("hidden");
            document.getElementById("correct-answer-display").textContent = "";
            updateFeedbackMessage("Nuevo sistema dinámico acoplado. Redondea tu cálculo a un decimal.", "border-cyan-500", "text-cyan-400");

            generateValidProblem();
            buildSystemGeometry();
            updateUIState();
            
            // Mostrar botón flotante del cajón y abrirlo para el nuevo ejercicio en móviles
            document.getElementById("mobile-drawer-toggle").classList.remove("hidden-force");
            toggleMobileDrawer(true);
        }

        function toggleHelpModal() {
            const modal = document.getElementById("help-modal");
            modal.classList.toggle("hidden");
        }

        // --- BUCLE DE RENDERIZADO Y EFECTO PARALAJE ---
        function animate() {
            requestAnimationFrame(animate);

            // Suavizado dinámico del paralaje 2.5D y paneo horizontal según arrastre de cámara
            smoothPanX += (cameraPanX - smoothPanX) * 0.08;
            const isMobile = window.innerWidth <= 768;
            const targetX = cameraPanX + mouseX * 0.15;
            const targetY = (isMobile ? 0.90 : 1.35) + (mouseY * -0.15);
            camera.position.x += (targetX - camera.position.x) * 0.08;
            camera.position.y += (targetY - camera.position.y) * 0.08;
            camera.position.z += (cameraZoomZ - camera.position.z) * 0.08; // Suavizado de zoom
            camera.lookAt(smoothPanX, isMobile ? 0.85 : 1.2, 0);

            updateParticles();
            
            // Proyección de las etiquetas en pantalla
            updateScreenBadges();

            if (renderer && scene && camera) {
                renderer.render(scene, camera);
            }
        }

        // --- ACTIVACIÓN GENERAL ---
        window.onload = function() {
            init3D();
            restartSystem();
            animate();
            
            // Listeners
            document.getElementById("lanzarBtn").addEventListener("click", runSimulation);
            document.getElementById("resetBtn").addEventListener("click", restartSystem);
            document.getElementById("toggle-panel-btn").addEventListener("click", toggleLeftPanel);
            document.getElementById("toggle-right-panel-btn").addEventListener("click", toggleRightPanel);
            document.getElementById("toggle-fbd").addEventListener("change", () => {
                buildFBDVectors();
                updateFBDPositions();
            });

            document.getElementById("manual-input").addEventListener("keypress", function(e) {
                if (e.key === "Enter") {
                    runSimulation();
                }
            });
        };
    </script>
</body>
</html>